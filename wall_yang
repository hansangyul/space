// ── Camera state ──
// This camera system keeps orbitTarget as the REAL reference point,
// and when locked, we lerp orbitTarget to the live planet position every frame.
const cam={
  orbitTarget:new THREE.Vector3(),
  radius:380,
  theta:0.2,
  phi:1.05,
  dragging:false,
  lastX:0,lastY:0,
  minR:2, maxR:2000,
  animating:false,
  animT:0,
  animFrom:{pos:new THREE.Vector3(),target:new THREE.Vector3(),r:380,phi:1.05,theta:0.2},
  animTo:{target:new THREE.Vector3(),r:50,phi:1.05,theta:0.2},
};

function applyCam(){
  cam.phi=Math.max(.05,Math.min(Math.PI-.05,cam.phi));
  cam.radius=Math.max(cam.minR,Math.min(cam.maxR,cam.radius));
  const x=cam.orbitTarget.x+cam.radius*Math.sin(cam.phi)*Math.cos(cam.theta);
  const y=cam.orbitTarget.y+cam.radius*Math.cos(cam.phi);
  const z=cam.orbitTarget.z+cam.radius*Math.sin(cam.phi)*Math.sin(cam.theta);
  camera.position.set(x,y,z);
  camera.lookAt(cam.orbitTarget);
}


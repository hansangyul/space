function makeTexture(bodyDef, radN=1.0, atmN=0.5){
  const S=512;
  const cv=document.createElement('canvas'); cv.width=cv.height=S;
  const g=cv.getContext('2d');
  const cx=S/2, cy=S/2, R=S/2-2;

  // Base gradient (sphere illusion)
  const bg=g.createRadialGradient(cx-R*.3,cy-R*.3,R*.05,cx,cy,R);
  const c=new THREE.Color(bodyDef.col);
  // Heat shift: increase red, decrease blue when radiation high
  const heat=Math.max(0,radN-1);
  const r=Math.min(1,c.r+heat*.35), gr=Math.max(0,c.g-heat*.15), bl=Math.max(0,c.b-heat*.25);
  bg.addColorStop(0,`rgba(${Math.round(r*255+80)},${Math.round(gr*255+80)},${Math.round(bl*255+80)},1)`);
  bg.addColorStop(.4,`rgb(${Math.round(r*255)},${Math.round(gr*255)},${Math.round(bl*255)})`);
  bg.addColorStop(1,`rgb(${Math.round(r*80)},${Math.round(gr*70)},${Math.round(bl*80)})`);
  g.beginPath(); g.arc(cx,cy,R,0,Math.PI*2); g.fillStyle=bg; g.fill();

  // Bands
  g.save(); g.beginPath(); g.arc(cx,cy,R,0,Math.PI*2); g.clip();
  bodyDef.bands.forEach(b=>{
    const by=cy+b.y*S, bh=b.w*S;
    // Heat makes bands redder
    const bandCol=b.c.replace('rgba(','').replace(')','').split(',');
    const br=Math.min(255,parseInt(bandCol[0])+heat*60);
    const bg2=g.createLinearGradient(0,by-bh/2,0,by+bh/2);
    bg2.addColorStop(0,`rgba(${br},${bandCol[1]},${bandCol[2]},0)`);
    bg2.addColorStop(.5,`rgba(${br},${bandCol[1]},${bandCol[2]},${bandCol[3]}`);
    bg2.addColorStop(1,`rgba(${br},${bandCol[1]},${bandCol[2]},0)`);
    g.fillStyle=bg2; g.fillRect(0,by-bh/2,S,bh);
  });

  // Jupiter Great Red Spot
  if(bodyDef.grs){
    const grsX=cx+S*.18, grsY=cy+S*.02;
    const grsRx=S*.12*(1+heat*.3), grsRy=S*.075;
    const grsG=g.createRadialGradient(grsX,grsY,0,grsX,grsY,grsRx);
    grsG.addColorStop(0,`rgba(${Math.min(255,200+heat*55)},${Math.max(30,80-heat*40)},20,.95)`);
    grsG.addColorStop(.5,`rgba(${Math.min(255,180+heat*40)},${Math.max(20,50-heat*30)},10,.6)`);
    grsG.addColorStop(1,'rgba(0,0,0,0)');
    g.save(); g.scale(1,grsRy/grsRx);
    g.beginPath(); g.arc(grsX,grsY*(grsRx/grsRy),grsRx,0,Math.PI*2);
    g.fillStyle=grsG; g.fill(); g.restore();
    // Swirl lines
    for(let i=0;i<4;i++){
      const sa=i*Math.PI/2, ea=sa+Math.PI*.8;
      g.beginPath(); g.ellipse(grsX,grsY,grsRx*(1.1+i*.1),grsRy*(1.1+i*.1),0,sa,ea);
      g.strokeStyle=`rgba(${Math.min(255,160+heat*40)},80,30,.2)`; g.lineWidth=1.5; g.stroke();
    }
  }

  // Polar caps
  const pc=bodyDef.polar;
  if(pc){
    const capH=S*.12+atmN*S*.04;
    const ng=g.createLinearGradient(0,0,0,capH);
    ng.addColorStop(0,pc.n); ng.addColorStop(1,'rgba(0,0,0,0)');
    g.fillStyle=ng; g.fillRect(0,0,S,capH);
    const sg2=g.createLinearGradient(0,S-capH,0,S);
    sg2.addColorStop(0,'rgba(0,0,0,0)'); sg2.addColorStop(1,pc.s);
    g.fillStyle=sg2; g.fillRect(0,S-capH,S,capH);
  }
  g.restore();

  // Atmosphere glow overlay (density slider)
  if(atmN>0.1){
    const ag=g.createRadialGradient(cx,cy,R*.7,cx,cy,R);
    const atmC=bodyDef.id==='venus'?`rgba(240,210,80,${atmN*.4})`
              :bodyDef.id==='mars'?`rgba(210,110,60,${atmN*.3})`
              :bodyDef.id==='jupiter'||bodyDef.id==='saturn'?`rgba(200,160,80,${atmN*.2})`
              :bodyDef.id==='uranus'?`rgba(80,220,220,${atmN*.25})`
              :bodyDef.id==='neptune'?`rgba(60,100,240,${atmN*.25})`:`rgba(100,180,255,${atmN*.2})`;
    ag.addColorStop(0,'rgba(0,0,0,0)'); ag.addColorStop(1,atmC);
    g.beginPath(); g.arc(cx,cy,R,0,Math.PI*2); g.fillStyle=ag; g.fill();
  }

  // Rim highlight
  const rim=g.createRadialGradient(cx,cy,R*.82,cx,cy,R);
  rim.addColorStop(0,'rgba(255,255,255,0)'); rim.addColorStop(1,'rgba(255,255,255,.08)');
  g.beginPath(); g.arc(cx,cy,R,0,Math.PI*2); g.fillStyle=rim; g.fill();

  return new THREE.CanvasTexture(cv);
}

function makeMoonTexture(moon){
  const S=128; const cv=document.createElement('canvas'); cv.width=cv.height=S;
  const g=cv.getContext('2d'); const cx=S/2,cy=S/2,R=S/2-2;
  const c=new THREE.Color(moon.col);
  const bg=g.createRadialGradient(cx-R*.3,cy-R*.3,R*.05,cx,cy,R);
  bg.addColorStop(0,`rgb(${Math.min(255,c.r*255+70)},${Math.min(255,c.g*255+70)},${Math.min(255,c.b*255+70)})`);
  bg.addColorStop(.5,`rgb(${Math.round(c.r*255)},${Math.round(c.g*255)},${Math.round(c.b*255)})`);
  bg.addColorStop(1,`rgb(${Math.round(c.r*80)},${Math.round(c.g*80)},${Math.round(c.b*80)})`);
  g.beginPath(); g.arc(cx,cy,R,0,Math.PI*2); g.fillStyle=bg; g.fill();
  // Surface features
  if(moon.id==='io'){// Volcanic yellow-orange
    for(let i=0;i<8;i++){const x=Math.random()*S,y=Math.random()*S;
      const lg=g.createRadialGradient(x,y,0,x,y,8+Math.random()*10);
      lg.addColorStop(0,'rgba(255,80,0,.7)'); lg.addColorStop(1,'rgba(0,0,0,0)');
      g.beginPath();g.arc(x,y,12,0,Math.PI*2);g.fillStyle=lg;g.fill();}
  }
  if(moon.id==='europa'){// Ice cracks
    g.strokeStyle='rgba(180,160,220,.5)';g.lineWidth=1;
    for(let i=0;i<6;i++){g.beginPath();g.moveTo(Math.random()*S,Math.random()*S);g.lineTo(Math.random()*S,Math.random()*S);g.stroke();}
  }
  if(moon.id==='titan'){// Orange haze
    const haze=g.createRadialGradient(cx,cy,R*.6,cx,cy,R);
    haze.addColorStop(0,'rgba(0,0,0,0)'); haze.addColorStop(1,'rgba(200,120,20,.4)');
    g.beginPath();g.arc(cx,cy,R,0,Math.PI*2);g.fillStyle=haze;g.fill();
  }
  if(moon.id==='triton'){// Nitrogen geysers (dark streaks)
    g.strokeStyle='rgba(40,60,100,.5)';g.lineWidth=1.5;
    for(let i=0;i<4;i++){const sx=cx+Math.random()*30-15,sy=cy+20;
      g.beginPath();g.moveTo(sx,sy);g.lineTo(sx+(Math.random()-0.5)*20,sy-30);g.stroke();}
  }
  // Craters
  const nCraters=moon.id==='callisto'||moon.id==='rhea'?12:4;
  for(let i=0;i<nCraters;i++){
    const x=Math.random()*S,y=Math.random()*S,r=2+Math.random()*7;
    g.beginPath();g.arc(x,y,r,0,Math.PI*2);
    g.strokeStyle='rgba(0,0,0,.3)';g.lineWidth=1;g.stroke();
    const ch=g.createRadialGradient(x-r*.3,y-r*.3,r*.1,x,y,r);
    ch.addColorStop(0,'rgba(255,255,255,.15)');ch.addColorStop(1,'rgba(0,0,0,.2)');
    g.fillStyle=ch;g.fill();
  }
  return new THREE.CanvasTexture(cv);
}

// Atmosphere shell (glow halo)
function makeAtmoShell(body,atmN){
  const c=body.id==='venus'?new THREE.Color(.95,.82,.3)
          :body.id==='mars'?new THREE.Color(.85,.42,.22)
          :body.id==='jupiter'?new THREE.Color(.8,.65,.35)
          :body.id==='uranus'?new THREE.Color(.35,.88,.88)
          :body.id==='neptune'?new THREE.Color(.25,.38,.95)
          :new THREE.Color(.4,.7,1);
  return new THREE.MeshBasicMaterial({color:c,transparent:true,opacity:atmN*.18+.03,
    blending:THREE.AdditiveBlending,side:THREE.BackSide,depthWrite:false});
}


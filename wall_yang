function getAllMeshes(){return[...Object.values(P_MESH),...Object.values(M_MESH)];}
function getHit(ex,ey){
  const rc=cv.getBoundingClientRect();
  m2v.x=((ex-rc.left)/rc.width)*2-1; m2v.y=-((ey-rc.top)/rc.height)*2+1;
  ray.setFromCamera(m2v,camera);
  const hits=ray.intersectObjects(getAllMeshes(),false);
  return hits.length>0&&hits[0].object.userData.bid?hits[0]:null;
}

cv.addEventListener('mousemove',e=>{
  const hit=getHit(e.clientX,e.clientY);
  if(hit&&!cam.dragging){
    cv.style.cursor='pointer';tip.style.opacity='1';
    tip.style.left=(e.clientX+14)+'px'; tip.style.top=(e.clientY-8)+'px';
    const bd=ALL_BODIES[hit.object.userData.bid];
    tip.innerHTML=`<b>${bd?.name||''}</b> ${bd?.en||''}<br><span style="opacity:.5;font-size:.52rem">클릭 → Lock-On 추적</span>`;
  } else {cv.style.cursor=cam.dragging?'grabbing':'grab';tip.style.opacity='0';}
  if(cam.dragging){
    const dx=(e.clientX-cam.lx)*.0052, dy=(e.clientY-cam.ly)*.0052;
    cam.theta-=dx; cam.phi-=dy;
    cam.lx=e.clientX; cam.ly=e.clientY;
    wasDragged=true;
  }
});
cv.addEventListener('mousedown',e=>{
  cam.dragging=true; cam.lx=e.clientX; cam.ly=e.clientY;
  mdp={x:e.clientX,y:e.clientY}; wasDragged=false;
});
cv.addEventListener('mouseup',e=>{
  cam.dragging=false;
  if(!wasDragged&&Math.hypot(e.clientX-mdp.x,e.clientY-mdp.y)<5){
    const hit=getHit(e.clientX,e.clientY);
    if(hit){ lockOn(hit.object.userData.bid); }
    else if(!e.target.closest('#plist')&&!e.target.closest('#simpanel')&&!e.target.closest('#livepanel')){
      releaseLock(); closeSP();
    }
  }
});
cv.addEventListener('wheel',e=>{
  e.preventDefault();
  cam.radius*=e.deltaY>0?1.1:.9;
  cam.radius=Math.max(cam.minR,Math.min(cam.maxR,cam.radius));
},{passive:false});

document.addEventListener('keydown',e=>{
  if(e.target.tagName==='INPUT') return;
  if(e.code==='Space'){e.preventDefault();togglePause();}
  if(e.key==='Escape'){releaseLock();closeSP();}
  if(e.key.toLowerCase()==='n') toggleNBody();
});
window.addEventListener('resize',()=>{
  camera.aspect=innerWidth/innerHeight;camera.updateProjectionMatrix();
  renderer.setSize(innerWidth,innerHeight);
});


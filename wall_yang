function dr2(k,v,u,cls=''){
  return`<div class="dr"><span class="dk">${k}</span><span class="dv ${cls}">${v}${u?` <span style="opacity:.35;font-size:.48rem">${u}</span>`:''}</span></div>`;
}
function updSl(bid,param,val){

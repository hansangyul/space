//  MINI CANVAS ANIMATIONS
// ═══════════════════════════════════════════════════════════════════════════
let miniT = 0;
function startMiniSims(bodyId){
  stopMiniSims();
  miniT = 0;
  miniParticles = {solar:[], impact:[], tidal:[]};

  function tick(){
    miniT++;
    const ss = bodyId==='europa' ? europaSimState : simState[bodyId] || {solarRad:1,gravConst:1,atmoDensity:0.5};
    drawSolarMini(bodyId, ss);
    drawGravMini(bodyId, ss);
    drawImpactMini(bodyId, ss);
    if(bodyId==='europa') drawTidalMini();
    miniAnimIds.id = requestAnimationFrame(tick);
  }
  tick();
}
function stopMiniSims(){
  if(miniAnimIds.id) cancelAnimationFrame(miniAnimIds.id);
}

function getMiniCtx(id){
  const c = document.getElementById('mc-'+id);
  if(!c) return null;
  if(!c._sized){
    c.width = c.offsetWidth||290;
    c.height = 100;
    c._sized = true;
  }
  return c.getContext('2d');
}

function drawSolarMini(bodyId, ss){
  const g = getMiniCtx('solar'); if(!g) return;
  const W=g.canvas.width, H=g.canvas.height, cx=W/2, cy=H/2;
  g.fillStyle='rgba(0,2,12,.2)'; g.fillRect(0,0,W,H);

  const radN = ss.solarRad;
  const spawnN = Math.ceil(radN*8);
  for(let i=0;i<spawnN;i++){
    miniParticles.solar.push({
      x:-5, y:Math.random()*H,
      vx:2+radN*3+Math.random()*2,
      vy:(Math.random()-.5)*.8,
      life:1,
      r:radN>1.5?255:radN>1?200:100,
      gb:radN>1.5?100:160,
    });
  }
  miniParticles.solar = miniParticles.solar.filter(p=>p.life>0);
  miniParticles.solar.forEach(p=>{
    p.x+=p.vx; p.y+=p.vy; p.life-=0.012;
    if(p.x>W||p.y<0||p.y>H){p.life=0;return;}
    const d=Math.hypot(p.x-cx,p.y-cy);
    if(d<16){p.life=0;return;}
    g.beginPath();
    g.moveTo(p.x-p.vx*5,p.y); g.lineTo(p.x,p.y);
    g.strokeStyle=`rgba(${p.r},${p.gb},50,${p.life*.7})`;
    g.lineWidth=1.2; g.stroke();
    g.beginPath(); g.arc(p.x,p.y,1.5,0,Math.PI*2);
    g.fillStyle=`rgba(${p.r},${p.gb},50,${p.life})`; g.fill();
  });

  // Planet
  const col = radN>1.5?'#ff4400':radN>1?'#ff8800':'#44aaff';
  const pg=g.createRadialGradient(cx-4,cy-4,1,cx,cy,16);
  pg.addColorStop(0,'#ffffff'); pg.addColorStop(1,col);
  g.beginPath(); g.arc(cx,cy,16,0,Math.PI*2); g.fillStyle=pg; g.fill();

  // Magnetosphere compression
  const magR = Math.max(18, 35-radN*8);
  const mg=g.createRadialGradient(cx,cy,16,cx,cy,magR+12);
  mg.addColorStop(0,'rgba(0,150,255,0)');
  mg.addColorStop(.7,`rgba(0,150,255,${.06+radN*.04})`);
  mg.addColorStop(1,'rgba(0,150,255,0)');
  g.beginPath(); g.arc(cx,cy,magR+12,0,Math.PI*2); g.fillStyle=mg; g.fill();

  // Temperature display
  const body=BODIES.find(b=>b.id===bodyId)||EUROPA;
  const tempNow = (body.baseTemp||0) + (radN-1)*80;
  g.font="9px 'Share Tech Mono'"; g.fillStyle='rgba(0,200,255,.5)'; g.textAlign='left';
  g.fillText(`복사강도: ×${radN.toFixed(2)}  |  표면온도: ${Math.round(tempNow)}°C`,6,H-6);
}

function drawGravMini(bodyId, ss){
  const g = getMiniCtx('grav'); if(!g) return;
  const W=g.canvas.width, H=g.canvas.height, cx=W*.38, cy=H/2;
  g.fillStyle='rgba(0,2,12,.2)'; g.fillRect(0,0,W,H);

  const gN = ss.gravConst;
  const body=BODIES.find(b=>b.id===bodyId)||EUROPA;
  const gReal = body.gravity * gN;
  const escV = escapeVel(body.mass||4.867e24, body.radius||6.052e6, gN) / 1000;

  // Field lines
  const lines = 3+Math.round(gN*2);
  for(let i=0;i<lines;i++){
    const a = miniT*0.01 + i*(Math.PI*2/lines);
    const rx = 50+gN*20, ry = 30+gN*12;
    g.beginPath();
    g.ellipse(cx,cy,rx,ry,a,0,Math.PI*2);
    g.strokeStyle=`rgba(155,80,255,${.08+gN*.06})`; g.lineWidth=1; g.stroke();
  }
  // Planet (tidal deformation if gravity high)
  const stretch = 1+Math.max(0,gN-1)*0.08;
  g.save(); g.translate(cx,cy); g.scale(stretch,1/stretch);
  const pg2=g.createRadialGradient(-5,-5,1,0,0,18);
  pg2.addColorStop(0,'#fff'); pg2.addColorStop(1,'#4466ff');
  g.beginPath(); g.arc(0,0,18,0,Math.PI*2); g.fillStyle=pg2; g.fill();
  g.restore();

  // Orbiting test mass
  const mR=40+gN*10, mA=miniT*.02;
  const mx=cx+Math.cos(mA)*mR, my=cy+Math.sin(mA)*(mR*.4);
  g.beginPath(); g.arc(mx,my,5,0,Math.PI*2); g.fillStyle='rgba(200,220,255,.9)'; g.fill();

  // External gravity source
  if(gN>1.2){
    g.beginPath(); g.arc(W*.82,cy,12+gN*4,0,Math.PI*2);
    g.fillStyle=`rgba(255,150,50,${.5+gN*.2})`; g.fill();
    g.setLineDash([4,6]);
    g.beginPath(); g.moveTo(W*.82-14,cy); g.lineTo(cx+20,cy);
    g.strokeStyle=`rgba(255,150,50,${.3+gN*.2})`; g.lineWidth=1.5+gN; g.stroke();
    g.setLineDash([]);
  }

  g.font="9px 'Share Tech Mono'"; g.fillStyle='rgba(155,80,255,.6)'; g.textAlign='left';
  g.fillText(`g=${gReal.toFixed(2)}m/s²  |  v_esc=${escV.toFixed(2)}km/s`,6,H-6);
}

function drawImpactMini(bodyId, ss){
  const g = getMiniCtx('impact'); if(!g) return;
  const W=g.canvas.width, H=g.canvas.height, cx=W/2, cy=H/2;
  g.fillStyle='rgba(0,2,12,.2)'; g.fillRect(0,0,W,H);

  const adN = ss.atmoDensity;
  const body=BODIES.find(b=>b.id===bodyId)||EUROPA;

  // Atmosphere shield
  if(adN > 0.1){
    const sg=g.createRadialGradient(cx,cy,18,cx,cy,18+adN*25);
    sg.addColorStop(0,'rgba(100,200,255,0)');
    sg.addColorStop(1,`rgba(100,200,255,${adN*.15})`);
    g.beginPath(); g.arc(cx,cy,18+adN*25,0,Math.PI*2); g.fillStyle=sg; g.fill();
  }

  // Spawn asteroids
  const interval = Math.max(20, 120-adN*80);
  if(miniT%Math.round(interval)===0){
    const ang = Math.random()*Math.PI*2;
    const spd = 1.5+Math.random()*2;
    miniParticles.impact.push({
      x:cx+Math.cos(ang)*150, y:cy+Math.sin(ang)*90,
      vx:-Math.cos(ang)*spd, vy:-Math.sin(ang)*spd*.6,
      life:1, size:3, exploded:false, shielded:false,
      col:`hsl(${20+Math.random()*30},80%,60%)`
    });
  }
  miniParticles.impact=miniParticles.impact.filter(p=>p.life>0);
  miniParticles.impact.forEach(p=>{
    p.x+=p.vx; p.y+=p.vy; p.life-=.014;
    const d=Math.hypot(p.x-cx,p.y-cy);
    const shieldR = 18+adN*25;
    if(d<shieldR+3&&!p.exploded&&!p.shielded){
      if(adN>0.4&&Math.random()<adN*.9){
        // atmosphere burns up
        p.shielded=true; p.life=0;
        for(let i=0;i<6;i++) miniParticles.impact.push({
          x:p.x,y:p.y,vx:(Math.random()-.5)*4,vy:(Math.random()-.5)*2,
          life:.5,size:1,exploded:true,col:'rgba(255,200,50,1)'
        });
        return;
      }
    }
    if(d<20&&!p.exploded){
      p.exploded=true; p.life=0;
      for(let i=0;i<20;i++) miniParticles.impact.push({
        x:p.x,y:p.y,vx:(Math.random()-.5)*6,vy:(Math.random()-.5)*3,
        life:.8,size:2,exploded:true,col:`hsl(${15+Math.random()*30},100%,65%)`
      });
    }
    g.beginPath(); g.arc(p.x,p.y,p.size,0,Math.PI*2);
    g.fillStyle=p.col; g.globalAlpha=p.life; g.fill(); g.globalAlpha=1;
  });

  // Planet
  const pg3=g.createRadialGradient(cx-5,cy-5,2,cx,cy,18);
  pg3.addColorStop(0,'#aaf'); pg3.addColorStop(1,'#003');
  g.beginPath(); g.arc(cx,cy,18,0,Math.PI*2); g.fillStyle=pg3; g.fill();

  g.font="9px 'Share Tech Mono'"; g.fillStyle='rgba(255,100,50,.6)'; g.textAlign='left';
  g.fillText(`대기밀도: ${(adN*100).toFixed(0)}%  방어율: ${Math.round(adN*90)}%`,6,H-6);
}

function drawTidalMini(){
  const g = getMiniCtx('tidal'); if(!g) return;
  const W=g.canvas.width, H=g.canvas.height;
  const jcx=W*.25, jcy=H*.5;
  const ecx=W*.72, ecy=H*.5;
  g.fillStyle='rgba(0,2,12,.22)'; g.fillRect(0,0,W,H);

  const gN = europaSimState.gravConst;
  const jupMass = 1.898e27 * gN;
  const d = EUROPA.orbit_r;
  const tf = tidalForce(jupMass, EUROPA.mass, d, EUROPA.radius);
  const tidalHeat = EUROPA.tidalHeat * gN;

  // Jupiter
  const jg=g.createRadialGradient(jcx-4,jcy-4,2,jcx,jcy,22);
  jg.addColorStop(0,'#ffe'); jg.addColorStop(.3,'#c8a870'); jg.addColorStop(1,'#705030');
  g.beginPath(); g.arc(jcx,jcy,22,0,Math.PI*2); g.fillStyle=jg; g.fill();

  // Tidal force arrows
  const tfScale = Math.min(30, tf/1e15*gN*30);
  g.strokeStyle='rgba(255,100,50,.7)'; g.lineWidth=2;
  // Left-right tidal stretch
  g.beginPath(); g.moveTo(ecx-12,ecy); g.lineTo(ecx-12-tfScale,ecy);
  g.stroke();
  g.beginPath(); g.moveTo(ecx+12,ecy); g.lineTo(ecx+12+tfScale,ecy);
  g.stroke();
  // Top-bottom compression
  g.strokeStyle='rgba(50,150,255,.7)';
  g.beginPath(); g.moveTo(ecx,ecy-12); g.lineTo(ecx,ecy-12+tfScale*.5);
  g.stroke();
  g.beginPath(); g.moveTo(ecx,ecy+12); g.lineTo(ecx,ecy+12-tfScale*.5);
  g.stroke();

  // Europa (tidally deformed ellipse)
  const stretch = 1+gN*.04;
  g.save(); g.translate(ecx,ecy); g.scale(stretch,1/stretch);
  const pulse = 1 + Math.sin(miniT*.1)*.03*gN;
  g.save(); g.scale(pulse,pulse);
  const eg2=g.createRadialGradient(-3,-3,1,0,0,12);
  eg2.addColorStop(0,'#ffffff'); eg2.addColorStop(.5,'#aacce8'); eg2.addColorStop(1,'#335588');
  g.beginPath(); g.arc(0,0,12,0,Math.PI*2); g.fillStyle=eg2; g.fill();
  // Ice crack lines
  g.strokeStyle=`rgba(255,150,100,${.2+gN*.15})`; g.lineWidth=.8;
  g.beginPath(); g.moveTo(-8,0); g.lineTo(8,0); g.stroke();
  g.beginPath(); g.moveTo(0,-8); g.lineTo(0,8); g.stroke();
  g.beginPath(); g.moveTo(-6,-6); g.lineTo(6,6); g.stroke();
  g.restore(); g.restore();

  // Internal heat visualization (glow from below ice)
  const heatA = Math.min(.5, gN*.2);
  const hg=g.createRadialGradient(ecx,ecy,0,ecx,ecy,12);
  hg.addColorStop(0,`rgba(255,100,0,${heatA})`);
  hg.addColorStop(1,'rgba(255,100,0,0)');
  g.beginPath(); g.arc(ecx,ecy,12,0,Math.PI*2); g.fillStyle=hg; g.fill();

  // Arrow from Jupiter to Europa
  g.setLineDash([3,4]);
  g.strokeStyle='rgba(255,165,0,.25)'; g.lineWidth=1;
  g.beginPath(); g.moveTo(jcx+24,jcy); g.lineTo(ecx-15,ecy); g.stroke();
  g.setLineDash([]);

  g.font="8px 'Share Tech Mono'"; g.fillStyle='rgba(255,165,0,.55)'; g.textAlign='left';
  g.fillText(`조석력: ${(tf/1e18).toFixed(2)}×10¹⁸N`,6,H-16);
  g.fillText(`내부열: ${(tidalHeat/1e9).toFixed(0)}GW`,6,H-5);
}


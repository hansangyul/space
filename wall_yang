<title>Interactive Solar Physics Lab v2</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@300;400;600;700&family=Share+Tech+Mono&family=Exo+2:wght@200;400;700&display=swap');
*{margin:0;padding:0;box-sizing:border-box;}
html,body{width:100%;height:100%;overflow:hidden;background:#000;font-family:'Exo 2',sans-serif;}
#c{display:block;width:100%;height:100%;cursor:grab;}
#c:active{cursor:grabbing;}

#hud-top{position:fixed;top:0;left:0;right:0;height:50px;background:linear-gradient(to bottom,rgba(0,3,18,.96),transparent);display:flex;align-items:center;justify-content:space-between;padding:0 22px;z-index:100;pointer-events:none;border-bottom:1px solid rgba(0,200,255,.07);}
.hud-logo{font-family:'Rajdhani',sans-serif;font-size:1rem;font-weight:700;color:#00c8ff;letter-spacing:5px;text-transform:uppercase;text-shadow:0 0 18px rgba(0,200,255,.5);}
.hud-center{font-family:'Share Tech Mono',monospace;font-size:.58rem;color:rgba(0,200,255,.45);letter-spacing:2px;display:flex;gap:24px;}
.hud-right{display:flex;align-items:center;gap:12px;}
.live-dot{width:5px;height:5px;border-radius:50%;background:#00ff88;box-shadow:0 0 5px #00ff88;animation:blink 1.8s infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
.live-txt{font-family:'Share Tech Mono',monospace;font-size:.55rem;color:rgba(0,255,136,.6);letter-spacing:2px;}

/* ── SIDEBAR ── */
#sidebar{position:fixed;right:0;top:0;bottom:0;width:350px;background:rgba(0,3,18,.97);border-left:1px solid rgba(0,200,255,.14);transform:translateX(100%);transition:transform .45s cubic-bezier(.16,1,.3,1);z-index:50;display:flex;flex-direction:column;backdrop-filter:blur(24px);}
#sidebar.open{transform:translateX(0);}
.sb-hdr{padding:16px 18px 0;border-bottom:1px solid rgba(0,200,255,.09);}
.sb-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.sb-namerow{display:flex;align-items:center;gap:10px;}
.sb-dot{width:11px;height:11px;border-radius:50%;flex-shrink:0;}
.sb-name{font-family:'Rajdhani',sans-serif;font-size:1.25rem;font-weight:700;color:#fff;letter-spacing:2px;}
.sb-en{font-family:'Share Tech Mono',monospace;font-size:.58rem;color:rgba(0,200,255,.55);letter-spacing:3px;margin-top:2px;}
#sb-close{width:26px;height:26px;background:rgba(0,200,255,.07);border:1px solid rgba(0,200,255,.22);color:#00c8ff;border-radius:2px;cursor:pointer;font-size:.85rem;display:flex;align-items:center;justify-content:center;transition:all .2s;}
#sb-close:hover{background:rgba(0,200,255,.18);}
.sb-tabs{display:flex;}
.sbt{flex:1;font-family:'Share Tech Mono',monospace;font-size:.55rem;letter-spacing:1px;text-transform:uppercase;padding:9px 4px;background:none;border:none;color:rgba(0,200,255,.3);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .2s;}
.sbt.on,.sbt:hover{color:#00c8ff;border-bottom-color:#00c8ff;}
.sb-body{flex:1;overflow-y:auto;padding:12px 16px;}
.sb-body::-webkit-scrollbar{width:2px;}
.sb-body::-webkit-scrollbar-thumb{background:rgba(0,200,255,.18);}

/* data */
.dr{display:flex;justify-content:space-between;align-items:baseline;padding:5px 0;border-bottom:1px solid rgba(0,200,255,.045);}
.dk{font-family:'Share Tech Mono',monospace;font-size:.56rem;color:rgba(0,200,255,.38);letter-spacing:1px;}
.dv{font-family:'Share Tech Mono',monospace;font-size:.65rem;color:#d8f4ff;text-align:right;}
.dv.b{color:#00c8ff;} .dv.w{color:#ffaa00;} .dv.r{color:#ff4040;} .dv.g{color:#00ff88;}
.sd{font-family:'Share Tech Mono',monospace;font-size:.52rem;letter-spacing:3px;color:#00c8ff;margin:11px 0 7px;display:flex;align-items:center;gap:6px;}
.sd::after{content:'';flex:1;height:1px;background:rgba(0,200,255,.13);}
.pt{font-size:.63rem;color:rgba(0,200,255,.48);line-height:1.7;margin-bottom:6px;}

/* phys boxes */
.pg{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin:8px 0;}
.pb{background:rgba(0,200,255,.04);border:1px solid rgba(0,200,255,.09);border-radius:3px;padding:9px;}
.pl{font-family:'Share Tech Mono',monospace;font-size:.5rem;color:rgba(0,200,255,.38);margin-bottom:3px;}
.pv{font-family:'Rajdhani',sans-serif;font-size:.95rem;font-weight:600;color:#00c8ff;}
.pu{font-family:'Share Tech Mono',monospace;font-size:.48rem;color:rgba(0,200,255,.35);}

/* sliders */
.slb{margin-bottom:13px;}
.slh{display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;}
.sll{font-family:'Share Tech Mono',monospace;font-size:.58rem;color:rgba(0,200,255,.55);letter-spacing:1px;}
.slv{font-family:'Rajdhani',sans-serif;font-size:.82rem;font-weight:600;color:#00c8ff;}
input[type=range]{width:100%;-webkit-appearance:none;height:2px;background:rgba(0,200,255,.14);border-radius:1px;outline:none;margin:3px 0;}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:11px;height:11px;border-radius:50%;background:#00c8ff;cursor:pointer;box-shadow:0 0 7px rgba(0,200,255,.8);}
.sld{font-size:.6rem;color:rgba(0,200,255,.3);line-height:1.55;margin-top:2px;}

/* mini canvases */
.fcw{margin:8px 0;border:1px solid rgba(0,200,255,.09);border-radius:3px;overflow:hidden;background:rgba(0,0,8,.7);}
.fcl{font-family:'Share Tech Mono',monospace;font-size:.5rem;letter-spacing:2px;color:rgba(0,200,255,.38);padding:4px 7px;border-bottom:1px solid rgba(0,200,255,.06);}
.fc{display:block;width:100%;height:90px;}

/* tidal special */
.tp{background:rgba(255,140,0,.04);border:1px solid rgba(255,140,0,.14);border-radius:3px;padding:11px;margin-top:8px;}
.tt{font-family:'Share Tech Mono',monospace;font-size:.55rem;color:#ffaa00;letter-spacing:2px;margin-bottom:8px;}


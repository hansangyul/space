// ═══════════════════════════════════════════════════
function lockOn(bid){
  const bd=ALL_BODIES[bid];if(!bd)return;
  const mesh=P_MESH[bid]||M_MESH[bid];if(!mesh)return;

  lockedId=bid;lockedMesh=mesh;

  // Start smooth camera transition
  startTransition(bid,mesh);

  // Update lock badge
  document.getElementById('lockbanner').classList.add('on');
  document.getElementById('lbn').textContent=bd.en||bd.name;
  document.getElementById('htrack').textContent='🔒 '+bd.en.toUpperCase();

  // Show live panel & sim panel
  document.getElementById('livepanel').classList.add('on');
  openSP(bid);

  // Highlight list item
  document.querySelectorAll('.pl-item').forEach(el=>{
    el.classList.toggle('active',el.dataset.bid===bid);
  });

  refreshLivePanel();
}

function releaseLock(){
  lockedId=null;lockedMesh=null;
  document.getElementById('lockbanner').classList.remove('on');
  document.getElementById('htrack').textContent='FREE CAM';
  document.getElementById('livepanel').classList.remove('on');
  cam.minR=2;cam.maxR=2000;
  document.querySelectorAll('.pl-item').forEach(el=>el.classList.remove('active'));
}

// ── Reset to overview ──
function resetCamera(){
  releaseLock();
  cam.animFrom.target.copy(cam.orbitTarget);
  cam.animFrom.r=cam.radius;cam.animFrom.phi=cam.phi;cam.animFrom.theta=cam.theta;
  cam.animTo.target.set(0,0,0);cam.animTo.r=380;cam.animTo.phi=1.05;cam.animTo.theta=0.2;
  cam.animating=true;cam.animT=0;
  cam.minR=2;cam.maxR=2000;
  closeSP();
}


const swP = [];

function spawnSW(rN) {
  const n=Math.ceil(rN*5);
  for(let i=0;i<n;i++){
    const t2=Math.random()*Math.PI*2, p2=Math.acos(2*Math.random()-1), r2=5.5;
    swP.push({
      x:r2*Math.sin(p2)*Math.cos(t2), y:r2*Math.sin(p2)*Math.sin(t2)*.18, z:r2*Math.sin(p2)*Math.sin(t2),
      vx:Math.sin(p2)*Math.cos(t2)*(1.8+rN*1.5), vy:Math.sin(p2)*Math.sin(t2)*.14*(1.8+rN), vz:Math.sin(p2)*Math.sin(t2)*(1.8+rN*1.5),
      life:1, maxR:80+Math.random()*80,
      r:rN>1.8?1:.7, g2:rN>1.8?.36:.72, b:rN>1.5?.12:.92
    });
  }
  while(swP.length>SW_MAX) swP.shift();
}

function flushSW() {
  for(let i=0;i<swP.length;i++){
    const p=swP[i], idx=i*3;
    swBuf.pos[idx]=p.x; swBuf.pos[idx+1]=p.y; swBuf.pos[idx+2]=p.z;
    swBuf.col[idx]=p.r*p.life; swBuf.col[idx+1]=p.g2*p.life*.8; swBuf.col[idx+2]=p.b*p.life;
  }
  for(let i=swP.length;i<SW_MAX;i++) swBuf.pos[i*3]=swBuf.pos[i*3+1]=swBuf.pos[i*3+2]=9999;
  swGeo.attributes.position.needsUpdate=true;
  swGeo.attributes.color.needsUpdate=true;
}

// ═══════════════════════════════════════════════════════════════════════
//  MODULE 6: N-BODY PHYSICS ENGINE
//  Implements simplified gravitational N-body: F = G*m1*m2/r^2
//  Positions are in scene units; masses scaled for stable simulation
// ═══════════════════════════════════════════════════════════════════════
// Scale factor: 1 scene unit = 1e9 m, 1 year = 1 sim time unit
// Mass scale: 1e24 kg → 1 mass unit for stability
const NB_MASS_SCALE = 1e24;
const NB_DIST_SCALE = 1e9;        // scene units to metres
const NB_TIME_SCALE = 3.15e7;     // seconds per sim-year
const NB_G = PHYS.G * NB_MASS_SCALE * NB_TIME_SCALE**2 / NB_DIST_SCALE**3;

// Body registry for N-body: planets only (moons follow parent Kepler for performance)
function getNBodyBodies() {
  return BODIES.map(pl => ({
    id: pl.id,
    mass: pl.mass / NB_MASS_SCALE,
    pos: P_MESH[pl.id].position.clone(),
    vel: nbVel[pl.id].clone(),
  }));
}

// Initialize N-body velocities from Kepler circular orbit
function initNBodyVelocities() {
  BODIES.forEach(pl => {
    const T = pl.a**1.5;  // Kepler period in years
    const omega = Math.PI*2/T;
    const r = logOrb(pl.a);
    // Circular velocity perpendicular to radius vector
    nbVel[pl.id].set(-Math.sin(0)*omega*r, 0, Math.cos(0)*omega*r);
  });
}

// RK4 integrator step for N-body
function nbodyStep(bodies, dt) {
  const n = bodies.length;
  function accel(bs) {
    return bs.map((bi,i) => {
      const a = new THREE.Vector3();
      bs.forEach((bj,j) => {
        if(i===j) return;
        const d = bj.pos.clone().sub(bi.pos);
        const r2 = Math.max(d.lengthSq(), 4); // softening: min 2 units
        const f = NB_G * bj.mass / r2;
        a.addScaledVector(d.normalize(), f);
      });
      return a;
    });
  }

  // k1
  const a1 = accel(bodies);
  // k2 (midpoint)
  const bs2 = bodies.map((b,i) => ({
    ...b,
    pos: b.pos.clone().addScaledVector(b.vel, dt*.5).addScaledVector(a1[i], dt**2*.125),
    vel: b.vel.clone().addScaledVector(a1[i], dt*.5)
  }));
  const a2 = accel(bs2);
  // k3
  const bs3 = bodies.map((b,i) => ({
    ...b,
    pos: b.pos.clone().addScaledVector(b.vel, dt*.5).addScaledVector(a2[i], dt**2*.125),
    vel: b.vel.clone().addScaledVector(a2[i], dt*.5)
  }));
  const a3 = accel(bs3);
  // k4
  const bs4 = bodies.map((b,i) => ({
    ...b,
    pos: b.pos.clone().addScaledVector(b.vel, dt).addScaledVector(a3[i], dt**2*.5),
    vel: b.vel.clone().addScaledVector(a3[i], dt)
  }));
  const a4 = accel(bs4);

  // Combine RK4
  bodies.forEach((b,i) => {
    b.pos.addScaledVector(b.vel, dt);
    b.pos.addScaledVector(a1[i].clone().add(a2[i].clone().multiplyScalar(2)).add(a3[i].clone().multiplyScalar(2)).add(a4[i]), dt**2/6);
    b.vel.addScaledVector(a1[i].clone().add(a2[i].clone().multiplyScalar(2)).add(a3[i].clone().multiplyScalar(2)).add(a4[i]), dt/6);
  });
  return bodies;
}

// Shared N-body state (persisted between frames)
let nbBodies = null;
let nbForces = {}; // id -> gravitational force magnitude on planet from sun

function updateNBody(physDt) {
  if(!nbodyEnabled) return;
  if(!nbBodies) {
    nbBodies = getNBodyBodies();
    initNBodyVelocities();
    // Transfer initial positions
    nbBodies.forEach(b => b.pos.copy(P_MESH[b.id].position));
  }
  // Step with small sub-steps for accuracy
  const SUB = 4;
  const subDt = physDt * PHYS.BASE_SPEED / SUB;
  for(let s=0;s<SUB;s++) nbodyStep(nbBodies, subDt);

  // Apply positions back to meshes
  nbBodies.forEach(b => {
    P_MESH[b.id].position.copy(b.pos);
    nbVel[b.id].copy(b.vel);
    // Calculate gravitational force from sun for display
    const d = b.pos.length() * NB_DIST_SCALE;
    if(d>0) nbForces[b.id] = PHYS.G * PHYS.SUN_M * (b.mass*NB_MASS_SCALE) / (d*d);
  });
}

// ═══════════════════════════════════════════════════════════════════════
//  MODULE 7: MAIN ANIMATION LOOP
// ═══════════════════════════════════════════════════════════════════════
let lastT=0, frameC=0, lastFpsT=performance.now(), lastTexT=0;

function animate() {
  requestAnimationFrame(animate);
  const now = performance.now();
  // Real elapsed dt — always advances for camera, rendering, transitions
  const dt = Math.min((now-lastT)/1000, .05);
  lastT = now;
  // Physics dt — ZERO when paused; scaled by timeScale
  const physDt = isPaused ? 0 : dt * timeScale;

  // Advance simulation clock
  simTime += physDt * PHYS.BASE_SPEED;

  // FPS
  frameC++;
  if(now-lastFpsT>600){
    document.getElementById('hfps').textContent=Math.round(frameC*1000/(now-lastFpsT))+' FPS';
    frameC=0; lastFpsT=now;
  }
  const tStr = 'T+'+simTime.toFixed(2)+'yr';
  document.getElementById('htime').textContent = tStr;
  document.getElementById('btime').textContent = tStr;
  document.getElementById('tb-elapsed').textContent = tStr;

  // ── N-BODY or KEPLER planet positions ──
  if(nbodyEnabled) {
    updateNBody(physDt);
  }

  BODIES.forEach(pl => {
    // Kepler position (used when N-body OFF, or for moon parent tracking)
    const T = pl.a**1.5;
    const omega = Math.PI*2/T;
    const ang = simTime * omega;
    const r = logOrb(pl.a);

    if(!nbodyEnabled) {
      // Pure Kepler
      P_MESH[pl.id].position.set(Math.cos(ang)*r, 0, Math.sin(ang)*r);
      if(nbBodies) nbBodies = null; // reset on toggle
    }

    const mesh = P_MESH[pl.id];
    const px = mesh.position.x, pz = mesh.position.z;

    // Planet self-rotation (physDt → stops when paused)
    mesh.rotation.y += physDt * (pl.id==='venus' ? -.28 : .36);

    // Texture rebuild when sliders changed
    if(TEX_DIRTY[pl.id] && now-lastTexT>90) {
      const ss = SIM[pl.id];
      mesh.material.map = makePlanetTex(pl, ss.rad, ss.atm);
      mesh.material.map.needsUpdate = true;
      TEX_DIRTY[pl.id] = false; lastTexT = now;
    }

    // Atmosphere shader
    const ss = SIM[pl.id], heat = Math.max(0, ss.rad-1);
    if(P_ATMO[pl.id]?.material?.uniforms) {
      P_ATMO[pl.id].material.uniforms.vv.value = camera.position.clone().sub(mesh.position).normalize();
      P_ATMO[pl.id].material.uniforms.c.value = .08 + ss.atm*.18 + heat*.12;
      P_ATMO[pl.id].scale.setScalar(1 + ss.atm*.2 + heat*.14);
    }
    // Glow update
    const gs = 1 + ss.atm*.72 + heat*1.0;
    P_GLOW[pl.id].scale.set(pl.sz*4.8*gs, pl.sz*4.8*gs, 1);
    P_GLOW[pl.id].material.opacity = .18 + ss.atm*.15 + heat*.22;
    // Emissive heat
    const ec = new THREE.Color(pl.ec);
    mesh.material.emissive.set(ec.r*heat*.7, ec.g*heat*.45, ec.b*heat*.2);
    mesh.material.emissiveIntensity = heat*.6;

    // ── MOONS: 3D Inclined Kepler Orbits ──
    pl.moons.forEach(mn => {
      const retro = mn.T<0;
      const mT = Math.abs(mn.T)/365.25;
      const mOm = Math.PI*2/mT;
      const ma = simTime * mOm * (retro?-1:1);
      const incl = mn.incl ?? 0;
      const az   = mn.az   ?? 0;

      // 3D inclined orbit calculation
      const lx = Math.cos(ma)*mn.orb;
      const ly = Math.sin(ma)*mn.orb * Math.sin(incl);
      const lz = Math.sin(ma)*mn.orb * Math.cos(incl);
      const cosAz=Math.cos(az), sinAz=Math.sin(az);
      const wx = lx*cosAz - lz*sinAz;
      const wy = ly;
      const wz = lx*sinAz + lz*cosAz;

      M_MESH[mn.id].position.set(px+wx, wy, pz+wz);
      M_MESH[mn.id].rotation.y += physDt*.38; // stops when paused

      // Move orbit line with planet
      if(M_OL[mn.id]) M_OL[mn.id].position.set(px, 0, pz);

      // Tidal glow (io, europa, enceladus, triton)
      if(mn.tidal) {
        const mss = SIM[mn.id] || SIM[pl.id];
        const tg = Math.max(0, (mss.grav||1)-1);
        M_MESH[mn.id].material.emissive = new THREE.Color(tg*.52, tg*.08, 0);
        M_MESH[mn.id].material.emissiveIntensity = tg*.9;
        const mgl = M_MESH[mn.id].children[0];
        if(mgl?.isSprite){ mgl.material.color.set(tg>.2?0xff5500:mn.col); mgl.material.opacity=.1+tg*.36; }
      }
    });
  });

  // ── LOCK-ON CAMERA TRACKING (0 error — lerps to live position every frame) ──
  if(lockedMesh) {
    cam.orbitTarget.lerp(lockedMesh.position, .1);
  }

  // ── CAMERA TRANSITION ANIMATION ──
  if(cam.animating) {
    cam.animT = Math.min(1, cam.animT + dt*1.1);
    const e = 1 - Math.pow(1-cam.animT, 4); // ease-out quart
    cam.orbitTarget.lerpVectors(cam.animFrom.target, cam.animTo.target, e);
    cam.radius = cam.animFrom.r + (cam.animTo.r - cam.animFrom.r)*e;
    cam.phi    = cam.animFrom.phi + (cam.animTo.phi - cam.animFrom.phi)*e;
    cam.theta  = cam.animFrom.theta + (cam.animTo.theta - cam.animFrom.theta)*e;
    if(cam.animT>=1) cam.animating=false;
  }
  applyCam();

  // ── SOLAR WIND PARTICLES (physDt → freeze when paused) ──
  const maxRad = Math.max(...Object.values(SIM).map(s=>s.rad||1));
  if(!isPaused) {
    spawnSW(maxRad);
    for(let i=swP.length-1;i>=0;i--){
      const p=swP[i];
      p.life -= (.008+.004*(maxRad-1))*timeScale;
      if(p.life<=0||Math.hypot(p.x,p.y,p.z)>p.maxR){ swP.splice(i,1); continue; }
      p.x+=p.vx*physDt*55; p.y+=p.vy*physDt*55; p.z+=p.vz*physDt*55;
    }
  }
  flushSW();

  // ── SUN PULSE ──
  const sp = 1+Math.sin(simTime*5)*.022;
  sunMesh.scale.set(sp,sp,sp);

  // ── LIVE PANEL UPDATE ──
  if(lockedId && Math.floor(now/200)!==Math.floor((now-dt*1000)/200)) refreshLivePanel();

  const totalBod = BODIES.length + Object.keys(M_MESH).length + 1;
  document.getElementById('hbod').textContent = 'BODIES: '+totalBod;

  renderer.render(scene, camera);
}
animate();


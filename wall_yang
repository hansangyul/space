#xhair{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;z-index:90;opacity:0;transition:opacity .35s;}
#xhair.on{opacity:1;}
.xr1{width:36px;height:36px;border-radius:50%;border:1px solid rgba(0,200,255,.45);animation:xspin 4s linear infinite;}
.xr2{position:absolute;top:5px;left:5px;width:26px;height:26px;border-radius:50%;border:1px dashed rgba(0,200,255,.25);animation:xspin 7s linear infinite reverse;}
@keyframes xspin{to{transform:rotate(360deg)}}

#tip{position:fixed;pointer-events:none;z-index:200;background:rgba(0,3,18,.93);border:1px solid rgba(0,200,255,.28);border-radius:2px;padding:7px 11px;font-family:'Share Tech Mono',monospace;font-size:.6rem;color:#d8f4ff;letter-spacing:1px;opacity:0;transition:opacity .1s;max-width:200px;}

#scanl{position:fixed;inset:0;pointer-events:none;z-index:999;background:repeating-linear-gradient(0deg,rgba(0,0,0,.03) 0px,rgba(0,0,0,.03) 1px,transparent 1px,transparent 4px);}
</style>
</head>

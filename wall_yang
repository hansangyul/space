function spawnSolarWind(radN){
  const N=Math.ceil(radN*4);
  for(let i=0;i<N;i++){
    const theta=Math.random()*Math.PI*2, phi=Math.acos(2*Math.random()-1);
    const r=6; // near sun
    swParticles.push({
      x:r*Math.sin(phi)*Math.cos(theta),y:r*Math.sin(phi)*Math.sin(theta)*.2,z:r*Math.sin(phi)*Math.sin(theta),
      vx:Math.sin(phi)*Math.cos(theta)*(1.5+radN*1.2),
      vy:Math.sin(phi)*Math.sin(theta)*.15*(1.5+radN),
      vz:Math.sin(phi)*Math.sin(theta)*(1.5+radN*1.2),
      life:1, maxR:Math.random()*120+40,
      r:radN>1.5?1:.7, g:radN>1.5?.4:.75, b:radN>1.5?.1:.9
    });
  }
  // trim
  while(swParticles.length>SWP_MAX) swParticles.shift();
}
function updateSolarWindGPU(){
  for(let i=0;i<swParticles.length;i++){
    const p=swParticles[i];
    const idx=i*3;
    swpPos[idx]=p.x;swpPos[idx+1]=p.y;swpPos[idx+2]=p.z;
    swpCol[idx]=p.r*p.life;swpCol[idx+1]=p.g*p.life*.8;swpCol[idx+2]=p.b*p.life;
  }
  // zero rest
  for(let i=swParticles.length;i<SWP_MAX;i++){swpPos[i*3]=swpPos[i*3+1]=swpPos[i*3+2]=9999;}
  swpGeo.attributes.position.needsUpdate=true;
  swpGeo.attributes.color.needsUpdate=true;
}

// Global max radiation for solar wind intensity
function getMaxRad(){return Math.max(...Object.values(simS).map(s=>s.rad||1));}


<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>☀ Solar Physics Lab — Ultimate Edition</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@300;400;600;700&family=Share+Tech+Mono&family=Exo+2:wght@200;400;700&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════
   ROOT VARIABLES & RESET
═══════════════════════════════════════════════ */
:root {
  --c1:#00c8ff; --c1a:rgba(0,200,255,.14); --c1b:rgba(0,200,255,.07);
  --c1c:rgba(0,200,255,.04); --c2:#00ff88; --cr:#ff4444;
  --cw:#ffaa00; --cp:#a855ff; --cg:#00ff88;
  --bg:rgba(0,3,18,.96); --bga:rgba(0,3,18,.88); --bgb:rgba(0,3,18,.75);
  --border:rgba(0,200,255,.14); --border2:rgba(0,200,255,.07);
  --txt:rgba(0,200,255,.6); --txt2:rgba(0,200,255,.38); --txt3:rgba(0,200,255,.22);
  --radius:3px; --radius-lg:6px;
  --trans:.22s cubic-bezier(.16,1,.3,1);
}
*{margin:0;padding:0;box-sizing:border-box;}
html,body{width:100%;height:100%;overflow:hidden;background:#000;
  font-family:'Exo 2',sans-serif;color:#c8f0ff;}
canvas#c{position:fixed;inset:0;display:block;width:100%;height:100%;}

/* ── ANIMATIONS ── */
@keyframes blink{0%,100%{opacity:1}50%{opacity:.15}}
@keyframes xspin{to{transform:rotate(360deg)}}
@keyframes fadein{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
@keyframes scanline{from{transform:translateY(-100%)}to{transform:translateY(100vh)}}
@keyframes pulse-glow{0%,100%{box-shadow:0 0 12px rgba(0,200,255,.3)}
  50%{box-shadow:0 0 28px rgba(0,200,255,.7)}}
@keyframes pb-blink{0%,100%{opacity:1}50%{opacity:.1}}
@keyframes shimmer{from{opacity:.5}to{opacity:1}}

/* ── SCANLINES ── */
#scl{position:fixed;inset:0;pointer-events:none;z-index:1000;
  background:repeating-linear-gradient(0deg,
    rgba(0,0,0,.022) 0,rgba(0,0,0,.022) 1px,
    transparent 1px,transparent 4px);}

/* ═══════════════════════════════════════════════
   TOP HUD
═══════════════════════════════════════════════ */
#hud{position:fixed;top:0;left:0;right:0;height:48px;z-index:500;
  pointer-events:none;display:flex;align-items:center;
  justify-content:space-between;padding:0 20px;
  background:linear-gradient(to bottom,rgba(0,3,18,.98) 60%,transparent);
  border-bottom:1px solid var(--border2);}
.hl{font-family:'Rajdhani',sans-serif;font-size:.92rem;font-weight:700;
  color:var(--c1);letter-spacing:5px;text-transform:uppercase;
  text-shadow:0 0 18px rgba(0,200,255,.55);
  pointer-events:all;cursor:pointer;transition:text-shadow .3s;}
.hl:hover{text-shadow:0 0 32px rgba(0,200,255,.9);}
.hud-center{display:flex;gap:18px;font-family:'Share Tech Mono',monospace;
  font-size:.55rem;color:var(--txt2);letter-spacing:2px;}
.hud-right{display:flex;align-items:center;gap:10px;}
.live-dot{width:5px;height:5px;border-radius:50%;background:var(--c2);
  box-shadow:0 0 5px var(--c2);animation:blink 1.8s infinite;}
.live-txt{font-family:'Share Tech Mono',monospace;font-size:.5rem;
  color:rgba(0,255,136,.5);letter-spacing:2px;}
.hud-nbody{font-family:'Share Tech Mono',monospace;font-size:.5rem;
  color:rgba(155,93,229,.6);letter-spacing:2px;}

/* ── LOCK-ON BANNER ── */
#lockbanner{position:fixed;top:52px;left:50%;transform:translateX(-50%);
  z-index:500;display:flex;align-items:center;gap:8px;
  font-family:'Share Tech Mono',monospace;font-size:.6rem;letter-spacing:3px;
  color:var(--c1);background:rgba(0,200,255,.07);
  border:1px solid rgba(0,200,255,.25);border-radius:var(--radius);
  padding:5px 16px;pointer-events:none;
  opacity:0;transition:opacity .4s;white-space:nowrap;}
#lockbanner.on{opacity:1;}

/* ═══════════════════════════════════════════════
   PLANET LIST — LEFT PANEL
═══════════════════════════════════════════════ */
#plist{position:fixed;left:0;top:48px;bottom:0;width:195px;z-index:400;
  background:var(--bg);border-right:1px solid var(--border);
  backdrop-filter:blur(24px);display:flex;flex-direction:column;overflow:hidden;}
.pl-hdr{padding:12px 14px 10px;border-bottom:1px solid var(--border2);}
.pl-title{font-family:'Share Tech Mono',monospace;font-size:.5rem;
  letter-spacing:3px;color:var(--txt2);margin-bottom:2px;}
.pl-sub{font-size:.56rem;color:rgba(0,200,255,.38);}
.pl-reset-btn{width:100%;margin-top:9px;
  font-family:'Share Tech Mono',monospace;font-size:.54rem;letter-spacing:1px;
  background:var(--c1b);border:1px solid rgba(0,200,255,.22);
  color:rgba(0,200,255,.7);border-radius:var(--radius);padding:6px 0;
  cursor:pointer;transition:all var(--trans);
  text-transform:uppercase;display:flex;align-items:center;
  justify-content:center;gap:5px;}
.pl-reset-btn:hover{background:var(--c1a);border-color:var(--c1);color:#fff;}
.pl-body{flex:1;overflow-y:auto;padding:6px 0;}
.pl-body::-webkit-scrollbar{width:2px;}
.pl-body::-webkit-scrollbar-thumb{background:rgba(0,200,255,.18);}
.pl-sect{font-family:'Share Tech Mono',monospace;font-size:.44rem;
  letter-spacing:3px;color:var(--txt3);padding:7px 14px 3px;}
.pl-item{display:flex;align-items:center;gap:8px;padding:7px 14px;
  cursor:pointer;transition:background .18s;border-left:2px solid transparent;}
.pl-item:hover{background:var(--c1a);}
.pl-item.active{background:var(--c1a);border-left-color:var(--c1);}
.pl-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.pl-info{flex:1;min-width:0;}
.pl-name{font-family:'Rajdhani',sans-serif;font-size:.78rem;font-weight:600;
  color:#d8f0ff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.pl-sub2{font-family:'Share Tech Mono',monospace;font-size:.44rem;color:var(--txt2);}
.pl-moon-item{padding:5px 14px 5px 28px;}
.pl-moon-item .pl-name{font-size:.68rem;color:rgba(200,230,240,.65);}

/* ═══════════════════════════════════════════════
   LIVE DATA PANEL — CENTER-LEFT
═══════════════════════════════════════════════ */
#livepanel{position:fixed;left:195px;top:48px;bottom:0;width:202px;
  z-index:400;background:var(--bga);border-right:1px solid var(--border);
  backdrop-filter:blur(20px);display:flex;flex-direction:column;
  transform:translateX(-202px);transition:transform var(--trans);}
#livepanel.on{transform:translateX(0);}
.lv-hdr{padding:10px 13px 8px;border-bottom:1px solid var(--border2);}
.lv-tag{font-family:'Share Tech Mono',monospace;font-size:.46rem;
  letter-spacing:3px;color:var(--txt2);}
.lv-name{font-family:'Rajdhani',sans-serif;font-size:1rem;font-weight:700;
  color:#fff;letter-spacing:2px;}
.lv-en{font-family:'Share Tech Mono',monospace;font-size:.5rem;
  color:rgba(0,200,255,.5);letter-spacing:2px;}
.lv-body{flex:1;overflow-y:auto;padding:9px 12px;}
.lv-body::-webkit-scrollbar{width:2px;}
.lv-body::-webkit-scrollbar-thumb{background:rgba(0,200,255,.13);}
.lrow{display:flex;justify-content:space-between;align-items:baseline;
  padding:4px 0;border-bottom:1px solid var(--border2);}
.lk{font-family:'Share Tech Mono',monospace;font-size:.47rem;color:var(--txt2);}
.lval{font-family:'Share Tech Mono',monospace;font-size:.57rem;color:#c8f0ff;}
.lval.b{color:var(--c1);} .lval.r{color:var(--cr);}
.lval.w{color:var(--cw);} .lval.g{color:var(--c2);}
.lv-sec{font-family:'Share Tech Mono',monospace;font-size:.45rem;letter-spacing:3px;
  color:var(--txt2);margin:7px 0 4px;border-top:1px solid var(--border2);padding-top:5px;}
.lbar-wrap{margin:4px 0;}
.lbar-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:2px;}
.lbar-k{font-family:'Share Tech Mono',monospace;font-size:.45rem;color:var(--txt2);}
.lbar-v{font-family:'Share Tech Mono',monospace;font-size:.45rem;color:var(--c1);}
.lbar{height:3px;background:rgba(0,200,255,.08);border-radius:2px;overflow:hidden;margin-bottom:3px;}
.lbar-f{height:100%;border-radius:2px;transition:width .3s ease;}
/* N-body section */
.nbody-box{background:rgba(155,93,229,.05);border:1px solid rgba(155,93,229,.2);
  border-radius:var(--radius);padding:8px;margin-top:6px;}
.nbody-title{font-family:'Share Tech Mono',monospace;font-size:.46rem;
  color:rgba(155,93,229,.7);letter-spacing:2px;margin-bottom:5px;}
.nbody-val{font-family:'Rajdhani',sans-serif;font-size:.75rem;font-weight:600;
  color:var(--cp);}

/* ═══════════════════════════════════════════════
   SIM PANEL — RIGHT
═══════════════════════════════════════════════ */
#simpanel{position:fixed;right:0;top:48px;bottom:0;width:315px;z-index:400;
  background:var(--bg);border-left:1px solid var(--border);
  backdrop-filter:blur(24px);display:flex;flex-direction:column;
  transform:translateX(100%);transition:transform var(--trans);}
#simpanel.on{transform:translateX(0);}
.sp-hdr{padding:13px 16px 0;border-bottom:1px solid var(--border2);}
.sp-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:9px;}
.sp-nr{display:flex;align-items:center;gap:9px;}
.sp-dot{width:10px;height:10px;border-radius:50%;}
.sp-nm{font-family:'Rajdhani',sans-serif;font-size:1.1rem;font-weight:700;
  color:#fff;letter-spacing:2px;}
.sp-en{font-family:'Share Tech Mono',monospace;font-size:.52rem;
  color:rgba(0,200,255,.5);letter-spacing:3px;margin-top:1px;}
#spc{width:24px;height:24px;background:var(--c1b);
  border:1px solid rgba(0,200,255,.2);color:var(--c1);border-radius:var(--radius);
  cursor:pointer;font-size:.78rem;display:flex;align-items:center;
  justify-content:center;transition:all .2s;}
#spc:hover{background:var(--c1a);}
.sp-tabs{display:flex;}
.sptab{flex:1;font-family:'Share Tech Mono',monospace;font-size:.5rem;
  letter-spacing:1px;text-transform:uppercase;padding:8px 4px;background:none;
  border:none;color:rgba(0,200,255,.28);cursor:pointer;
  border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .18s;}
.sptab.on,.sptab:hover{color:var(--c1);border-bottom-color:var(--c1);}
.sp-body{flex:1;overflow-y:auto;padding:10px 14px;}
.sp-body::-webkit-scrollbar{width:2px;}
.sp-body::-webkit-scrollbar-thumb{background:rgba(0,200,255,.13);}

/* data rows */
.dr{display:flex;justify-content:space-between;align-items:baseline;
  padding:4px 0;border-bottom:1px solid var(--border2);}
.dk{font-family:'Share Tech Mono',monospace;font-size:.5rem;color:var(--txt2);}
.dv{font-family:'Share Tech Mono',monospace;font-size:.6rem;color:#d0f0ff;text-align:right;}
.dv.b{color:var(--c1);} .dv.r{color:var(--cr);}
.dv.w{color:var(--cw);} .dv.g{color:var(--c2);}
.sd{font-family:'Share Tech Mono',monospace;font-size:.48rem;letter-spacing:3px;
  color:var(--c1);margin:10px 0 6px;display:flex;align-items:center;gap:5px;}
.sd::after{content:'';flex:1;height:1px;background:rgba(0,200,255,.1);}
.pt{font-size:.6rem;color:rgba(0,200,255,.42);line-height:1.68;margin-bottom:4px;}

/* phys boxes */
.pg{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin:6px 0;}
.pb{background:var(--c1c);border:1px solid var(--border2);
  border-radius:var(--radius);padding:8px;}
.pbl{font-family:'Share Tech Mono',monospace;font-size:.46rem;color:var(--txt2);margin-bottom:2px;}
.pbv{font-family:'Rajdhani',sans-serif;font-size:.88rem;font-weight:600;color:var(--c1);}
.pbu{font-family:'Share Tech Mono',monospace;font-size:.44rem;color:var(--txt2);}

/* sliders */
.slb{margin-bottom:12px;}
.slh{display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;}
.sll{font-family:'Share Tech Mono',monospace;font-size:.54rem;color:rgba(0,200,255,.5);}
.slv{font-family:'Rajdhani',sans-serif;font-size:.78rem;font-weight:600;color:var(--c1);}
input[type=range]{width:100%;-webkit-appearance:none;height:2px;
  background:rgba(0,200,255,.13);border-radius:1px;outline:none;cursor:pointer;}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:11px;height:11px;
  border-radius:50%;background:var(--c1);cursor:pointer;
  box-shadow:0 0 7px rgba(0,200,255,.8);}
.sld{font-size:.56rem;color:var(--txt2);line-height:1.5;margin-top:2px;}

/* mini canvases */
.fcw{margin:7px 0;border:1px solid var(--border2);border-radius:var(--radius);
  overflow:hidden;background:rgba(0,0,8,.8);}
.fcl{font-family:'Share Tech Mono',monospace;font-size:.46rem;letter-spacing:2px;
  color:var(--txt2);padding:4px 7px;border-bottom:1px solid var(--border2);}
.fc{display:block;width:100%;height:80px;}

/* tidal */
.tp{background:rgba(255,140,0,.03);border:1px solid rgba(255,140,0,.12);
  border-radius:var(--radius);padding:9px;margin-top:6px;}
.tt{font-family:'Share Tech Mono',monospace;font-size:.5rem;color:var(--cw);
  letter-spacing:2px;margin-bottom:6px;}
.ml{display:flex;flex-wrap:wrap;gap:4px;margin-top:5px;}
.mc{display:inline-flex;align-items:center;gap:4px;background:var(--c1b);
  border:1px solid var(--border);border-radius:var(--radius);padding:3px 7px;
  font-family:'Share Tech Mono',monospace;font-size:.5rem;
  color:rgba(0,200,255,.65);cursor:pointer;transition:all .18s;}
.mc:hover{background:var(--c1a);color:#fff;}
.mcd{width:5px;height:5px;border-radius:50%;}

/* ═══════════════════════════════════════════════
   TIME CONTROL BAR
═══════════════════════════════════════════════ */
#timebar{position:fixed;bottom:48px;left:50%;transform:translateX(-50%);
  z-index:600;display:flex;align-items:center;gap:10px;
  background:rgba(0,3,18,.9);border:1px solid rgba(0,200,255,.24);
  border-radius:40px;padding:8px 20px;
  backdrop-filter:blur(20px);
  box-shadow:0 0 30px rgba(0,200,255,.12),0 4px 24px rgba(0,0,0,.5);}
.tb-sep{width:1px;height:22px;background:rgba(0,200,255,.15);margin:0 2px;}
#btn-pp{width:36px;height:36px;border-radius:50%;
  background:rgba(0,200,255,.14);border:1.5px solid rgba(0,200,255,.5);
  color:var(--c1);font-size:1rem;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  transition:all .2s;flex-shrink:0;}
#btn-pp:hover{background:rgba(0,200,255,.28);
  box-shadow:0 0 14px rgba(0,200,255,.5);}
#btn-pp.paused{background:rgba(0,255,136,.12);
  border-color:rgba(0,255,136,.5);color:var(--c2);}
.tb-speed-btns{display:flex;gap:4px;}
.spbtn{font-family:'Share Tech Mono',monospace;font-size:.54rem;letter-spacing:1px;
  padding:5px 10px;border-radius:20px;cursor:pointer;
  background:rgba(0,200,255,.07);border:1px solid rgba(0,200,255,.2);
  color:rgba(0,200,255,.6);transition:all .18s;white-space:nowrap;}
.spbtn:hover{background:rgba(0,200,255,.16);color:var(--c1);}
.spbtn.active{background:rgba(0,200,255,.22);border-color:var(--c1);color:#fff;
  box-shadow:0 0 8px rgba(0,200,255,.3);}
.tb-slider-wrap{display:flex;align-items:center;gap:7px;}
.tb-slider-lbl{font-family:'Share Tech Mono',monospace;font-size:.5rem;
  color:rgba(0,200,255,.45);white-space:nowrap;}
#ts-slider{-webkit-appearance:none;width:80px;height:2px;
  background:rgba(0,200,255,.18);border-radius:1px;outline:none;cursor:pointer;}
#ts-slider::-webkit-slider-thumb{-webkit-appearance:none;width:13px;height:13px;
  border-radius:50%;background:var(--c1);cursor:pointer;
  box-shadow:0 0 7px rgba(0,200,255,.8);}
#ts-val{font-family:'Rajdhani',sans-serif;font-size:.8rem;font-weight:600;
  color:var(--c1);min-width:36px;text-align:center;}
.tb-time{font-family:'Share Tech Mono',monospace;font-size:.54rem;
  color:rgba(0,200,255,.45);letter-spacing:1px;white-space:nowrap;}

/* ── PAUSED BADGE ── */
#paused-badge{position:fixed;top:56px;right:20px;z-index:600;
  font-family:'Share Tech Mono',monospace;font-size:.56rem;letter-spacing:3px;
  color:#ff8800;background:rgba(255,136,0,.08);
  border:1px solid rgba(255,136,0,.35);border-radius:var(--radius);
  padding:5px 12px;pointer-events:none;
  opacity:0;transition:opacity .35s;display:flex;align-items:center;gap:6px;}
#paused-badge.on{opacity:1;}
.pb-dot{width:6px;height:6px;border-radius:50%;background:#ff8800;
  animation:pb-blink 1s infinite;}

/* ── NBODY TOGGLE ── */
#nbody-toggle{position:fixed;bottom:92px;right:20px;z-index:600;
  font-family:'Share Tech Mono',monospace;font-size:.52rem;letter-spacing:2px;
  background:rgba(155,93,229,.1);border:1px solid rgba(155,93,229,.35);
  color:rgba(155,93,229,.8);border-radius:var(--radius);
  padding:7px 14px;cursor:pointer;transition:all .22s;white-space:nowrap;}
#nbody-toggle:hover{background:rgba(155,93,229,.2);color:#c084fc;}
#nbody-toggle.active{background:rgba(155,93,229,.22);border-color:#a855ff;color:#e0a0ff;
  box-shadow:0 0 12px rgba(155,93,229,.4);}

/* ── BACK TO SPACE ── */
#btn-back{position:fixed;left:200px;bottom:48px;z-index:500;
  display:flex;align-items:center;gap:7px;
  font-family:'Share Tech Mono',monospace;font-size:.58rem;letter-spacing:2px;
  color:#fff;background:rgba(0,200,255,.14);
  border:1px solid rgba(0,200,255,.42);border-radius:var(--radius);
  padding:8px 16px;cursor:pointer;transition:all .22s;white-space:nowrap;
  box-shadow:0 0 14px rgba(0,200,255,.18);text-transform:uppercase;
  opacity:0;pointer-events:none;}
#btn-back.on{opacity:1;pointer-events:all;}
#btn-back:hover{background:rgba(0,200,255,.28);border-color:var(--c1);
  box-shadow:0 0 24px rgba(0,200,255,.4);transform:translateY(-1px);}

/* ═══════════════════════════════════════════════
   ENCYCLOPEDIA MODAL
═══════════════════════════════════════════════ */
#encyc{position:fixed;inset:0;z-index:1900;display:flex;
  background:rgba(0,3,18,.96);backdrop-filter:blur(24px);
  transition:opacity .4s;opacity:0;pointer-events:none;}
#encyc.on{opacity:1;pointer-events:all;}
.enc-left{width:240px;flex-shrink:0;border-right:1px solid var(--border);
  display:flex;flex-direction:column;background:rgba(0,5,22,.85);}
.enc-lhdr{padding:20px 18px 12px;border-bottom:1px solid var(--border2);}
.enc-title{font-family:'Rajdhani',sans-serif;font-size:1.3rem;font-weight:700;
  color:var(--c1);letter-spacing:4px;margin-bottom:4px;}
.enc-sub2{font-family:'Share Tech Mono',monospace;font-size:.5rem;color:var(--txt2);}
.enc-list{flex:1;overflow-y:auto;padding:8px 0;}
.enc-list::-webkit-scrollbar{width:2px;}
.enc-list::-webkit-scrollbar-thumb{background:rgba(0,200,255,.2);}
.enc-item{display:flex;align-items:center;gap:10px;padding:10px 18px;
  cursor:pointer;transition:all .18s;border-left:2px solid transparent;}
.enc-item:hover{background:var(--c1a);border-left-color:rgba(0,200,255,.4);}
.enc-item.sel{background:var(--c1a);border-left-color:var(--c1);}
.enc-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.enc-iname{font-family:'Rajdhani',sans-serif;font-size:.88rem;font-weight:600;color:#d8f0ff;}
.enc-ien{font-family:'Share Tech Mono',monospace;font-size:.46rem;color:var(--txt2);}
.enc-right{flex:1;display:flex;flex-direction:column;overflow:hidden;}
.enc-rhdr{display:flex;align-items:center;justify-content:space-between;
  padding:18px 26px;border-bottom:1px solid var(--border2);}
.enc-pname{font-family:'Rajdhani',sans-serif;font-size:1.8rem;font-weight:700;
  color:#fff;letter-spacing:3px;}
.enc-pen{font-family:'Share Tech Mono',monospace;font-size:.62rem;
  color:var(--c1);letter-spacing:4px;margin-top:2px;}
.enc-close{font-family:'Share Tech Mono',monospace;font-size:.56rem;letter-spacing:2px;
  background:var(--c1b);border:1px solid var(--border);color:var(--c1);
  padding:7px 14px;border-radius:var(--radius);cursor:pointer;transition:all .2s;}
.enc-close:hover{background:var(--c1a);}
.enc-body{flex:1;overflow-y:auto;padding:22px 26px;}
.enc-body::-webkit-scrollbar{width:3px;}
.enc-body::-webkit-scrollbar-thumb{background:rgba(0,200,255,.2);}
.enc-section{margin-bottom:22px;animation:fadein .3s ease;}
.enc-sh{font-family:'Share Tech Mono',monospace;font-size:.56rem;letter-spacing:3px;

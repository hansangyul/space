// ── Build encyclopedia list ──
(function buildEncList(){
  const list=document.getElementById('enclist');
  const planetsOnly=BODIES; // only planets in main list
  let html='';
  planetsOnly.forEach(pl=>{
    const col=`#${new THREE.Color(pl.col).getHexString()}`;
    html+=`<div class="enc-item" data-eid="${pl.id}" onclick="showEnc('${pl.id}')">
      <div class="enc-dot" style="background:${col};box-shadow:0 0 5px ${col}60"></div>
      <div>
        <div class="enc-iname">${pl.emoji} ${pl.name}</div>
        <div class="enc-ien">${pl.en}</div>
      </div>
    </div>`;
  });
  list.innerHTML=html;
})();

function showEnc(pid){
  const data=ENC_DATA[pid];
  const bd=BODIES.find(p=>p.id===pid);
  if(!data||!bd)return;

  // Highlight list item
  document.querySelectorAll('.enc-item').forEach(el=>el.classList.toggle('sel',el.dataset.eid===pid));

  // Header
  const col=`#${new THREE.Color(bd.col).getHexString()}`;
  document.getElementById('encpname').textContent=`${bd.emoji} ${bd.name}`;
  document.getElementById('encpname').style.color='#fff';
  document.getElementById('encpen').textContent=bd.en.toUpperCase()+' — '+bd.a.toFixed(3)+' AU';

  // Body
  const body=document.getElementById('encbody');
  let html=`
    <div class="enc-section">
      <div class="enc-sh">개요</div>
      <div class="enc-txt">${data.overview}</div>
    </div>
    <div class="enc-section">
      <div class="enc-sh">핵심 데이터</div>
      <div class="enc-grid">
        ${data.facts.map(f=>`<div class="enc-box">
          <div class="enc-bl">${f.l}</div>
          <div class="enc-bv">${f.v}</div>
          <div class="enc-bu">${f.u}</div>
        </div>`).join('')}
      </div>
    </div>
    ${data.sections.map(s=>`<div class="enc-section">
      <div class="enc-sh">${s.icon} ${s.title}</div>
      <div class="enc-txt">${s.text}</div>
    </div>`).join('')}
    <div class="enc-section">
      <div class="enc-sh">키워드</div>
      <div>${data.tags.map(t=>`<span class="enc-badge enc-badge-${t.cls}">${t.t}</span>`).join('')}</div>
    </div>
    <div style="margin-top:20px">
      <button class="enc-go" onclick="closeEncycAndExplore('${pid}')">🚀 ${bd.name} 탐험하기</button>
    </div>
  `;
  body.innerHTML=html;
  body.scrollTop=0;
}

function closeEncycAndExplore(pid){
  closeEncyc();
  // If intro still showing, start exploration first
  const intro=document.getElementById('intro');
  if(!intro.classList.contains('hidden')){
    intro.classList.add('hidden');
    setTimeout(()=>{intro.style.display='none'; lockOn(pid);},900);
  } else {
    lockOn(pid);
  }
}


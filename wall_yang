// ── MINI SIMULATORS ──
function stopMini(){if(miniRAF){cancelAnimationFrame(miniRAF);miniRAF=null;}MP.solar=[];MP.impact=[];}
function gmc2(id){const c=document.getElementById('mc'+id);if(!c)return null;if(!c._ok){c.width=c.offsetWidth||285;c.height=82;c._ok=true;}return c.getContext('2d');}
function startMini(bid){
  stopMini();mT=0;
  const tick=()=>{mT++;const ss=SIM[bid]||{rad:1,grav:1,atm:.5};const bd=ALL_BODIES[bid];
    ms(ss,bd);mg2(ss,bd);mi(ss,bd);if(bd?.tidal)mt2(ss,bd);miniRAF=requestAnimationFrame(tick);};
  tick();
}
function ms(ss,bd){
  const g=gmc2('s');if(!g)return;const W=g.canvas.width,H=g.canvas.height,cx=W/2,cy=H/2;
  g.fillStyle='rgba(0,1,10,.2)';g.fillRect(0,0,W,H);
  const rN=ss.rad||1,ht=Math.max(0,rN-1);
  for(let i=0;i<Math.ceil(rN*7);i++) MP.solar.push({x:-3,y:Math.random()*H,vx:2.8+rN*3.2,vy:(Math.random()-.5)*.85,life:1,r:rN>1.8?255:rN>1.2?215:75,g2:rN>1.8?55:rN>1.2?115:158,b:rN>1.5?14:205});
  MP.solar=MP.solar.filter(p=>p.life>0);
  MP.solar.forEach(p=>{p.x+=p.vx;p.y+=p.vy;p.life-=.012;if(p.x>W||p.y<0||p.y>H||Math.hypot(p.x-cx,p.y-cy)<17){p.life=0;return;}
    g.beginPath();g.moveTo(p.x-p.vx*5,p.y);g.lineTo(p.x,p.y);g.strokeStyle=`rgba(${p.r},${p.g2},${p.b},${p.life*.72})`;g.lineWidth=1.3;g.stroke();
    g.beginPath();g.arc(p.x,p.y,1.4,0,Math.PI*2);g.fillStyle=`rgba(${p.r},${p.g2},${p.b},${p.life})`;g.fill();});
  const magR=Math.max(19,36-rN*9);const mg=g.createRadialGradient(cx,cy,17,cx,cy,magR+13);
  const mc=(rN>1.5)?'rgba(255,80,28,':'rgba(0,160,255,';

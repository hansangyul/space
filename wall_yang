<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>☀ Solar Physics Lab — Interactive</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@300;400;600;700&family=Share+Tech+Mono&family=Exo+2:wght@200;400;700&display=swap');
:root{
  --c1:#00c8ff;--c1a:rgba(0,200,255,.12);--c1b:rgba(0,200,255,.06);
  --c2:#00ff88;--cr:#ff4444;--cw:#ffaa00;--cp:#a855ff;
  --bg:rgba(0,3,18,.96);--bga:rgba(0,3,18,.88);
  --border:rgba(0,200,255,.12);--border2:rgba(0,200,255,.06);
  --txt:rgba(0,200,255,.55);--txt2:rgba(0,200,255,.35);
}
*{margin:0;padding:0;box-sizing:border-box;}
html,body{width:100%;height:100%;overflow:hidden;background:#000;font-family:'Exo 2',sans-serif;}
#c{position:fixed;inset:0;display:block;width:100%;height:100%;}

/* ────── TOP HUD ────── */
#hud{position:fixed;top:0;left:0;right:0;height:46px;z-index:500;pointer-events:none;
  display:flex;align-items:center;justify-content:space-between;padding:0 18px;
  background:linear-gradient(to bottom,rgba(0,3,18,.98) 55%,transparent);
  border-bottom:1px solid var(--border2);}
.hl{font-family:'Rajdhani',sans-serif;font-size:.9rem;font-weight:700;color:var(--c1);
  letter-spacing:5px;text-shadow:0 0 16px rgba(0,200,255,.5);pointer-events:all;cursor:pointer;}
.hc{display:flex;gap:18px;font-family:'Share Tech Mono',monospace;font-size:.55rem;color:var(--txt);letter-spacing:2px;}
.hr{display:flex;align-items:center;gap:10px;}
.ldot{width:5px;height:5px;border-radius:50%;background:var(--c2);box-shadow:0 0 5px var(--c2);animation:blink 1.8s infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.15}}
.ltxt{font-family:'Share Tech Mono',monospace;font-size:.5rem;color:rgba(0,255,136,.5);letter-spacing:2px;}

/* ────── LOCK-ON BANNER ────── */
#lockbanner{position:fixed;top:50px;left:50%;transform:translateX(-50%);z-index:500;
  display:flex;align-items:center;gap:8px;
  font-family:'Share Tech Mono',monospace;font-size:.62rem;letter-spacing:3px;color:var(--c1);
  background:rgba(0,200,255,.07);border:1px solid rgba(0,200,255,.22);
  border-radius:2px;padding:5px 16px;pointer-events:none;
  opacity:0;transition:opacity .4s;white-space:nowrap;}
#lockbanner.on{opacity:1;}
.lock-icon{font-size:.75rem;}

/* ────── PLANET LIST (left) ────── */
#plist{position:fixed;left:0;top:46px;bottom:0;width:190px;z-index:400;
  background:var(--bg);border-right:1px solid var(--border);
  backdrop-filter:blur(22px);display:flex;flex-direction:column;overflow:hidden;}
.pl-hdr{padding:12px 14px 10px;border-bottom:1px solid var(--border2);}
.pl-title{font-family:'Share Tech Mono',monospace;font-size:.5rem;letter-spacing:3px;color:var(--txt2);margin-bottom:2px;}
.pl-sub{font-size:.58rem;color:rgba(0,200,255,.4);}
.pl-body{flex:1;overflow-y:auto;padding:6px 0;}
.pl-body::-webkit-scrollbar{width:2px;}
.pl-body::-webkit-scrollbar-thumb{background:rgba(0,200,255,.15);}
.pl-sect{font-family:'Share Tech Mono',monospace;font-size:.46rem;letter-spacing:3px;
  color:var(--txt2);padding:8px 14px 4px;opacity:.7;}
.pl-item{display:flex;align-items:center;gap:8px;padding:7px 14px;cursor:pointer;
  transition:background .18s;border-left:2px solid transparent;}
.pl-item:hover{background:var(--c1a);}
.pl-item.active{background:var(--c1a);border-left-color:var(--c1);}
.pl-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.pl-info{flex:1;min-width:0;}
.pl-name{font-family:'Rajdhani',sans-serif;font-size:.75rem;font-weight:600;color:#d8f0ff;
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.pl-sub2{font-family:'Share Tech Mono',monospace;font-size:.46rem;color:var(--txt2);}
.pl-moon{padding:5px 14px 5px 28px;}
.pl-moon .pl-name{font-size:.68rem;color:rgba(200,230,240,.7);}

/* ────── LIVE DATA PANEL (center-left, appears on lock) ────── */
#livepanel{position:fixed;left:190px;top:46px;width:200px;z-index:400;
  background:var(--bga);border-right:1px solid var(--border);
  backdrop-filter:blur(18px);
  transform:translateX(-200px);transition:transform .38s cubic-bezier(.16,1,.3,1);
  display:flex;flex-direction:column;bottom:0;}
#livepanel.on{transform:translateX(0);}
.lv-hdr{padding:10px 13px 8px;border-bottom:1px solid var(--border2);}
.lv-tag{font-family:'Share Tech Mono',monospace;font-size:.46rem;letter-spacing:3px;color:var(--txt2);}
.lv-name{font-family:'Rajdhani',sans-serif;font-size:1rem;font-weight:700;color:#fff;letter-spacing:2px;}
.lv-en{font-family:'Share Tech Mono',monospace;font-size:.5rem;color:rgba(0,200,255,.5);letter-spacing:2px;}
.lv-body{flex:1;overflow-y:auto;padding:9px 12px;}
.lv-body::-webkit-scrollbar{width:2px;}
.lv-body::-webkit-scrollbar-thumb{background:rgba(0,200,255,.13);}
.lrow{display:flex;justify-content:space-between;align-items:baseline;
  padding:4px 0;border-bottom:1px solid var(--border2);}
.lk{font-family:'Share Tech Mono',monospace;font-size:.48rem;color:var(--txt2);}
.lval{font-family:'Share Tech Mono',monospace;font-size:.58rem;color:#c8f0ff;}
.lval.b{color:var(--c1);}.lval.r{color:var(--cr);}.lval.w{color:var(--cw);}.lval.g{color:var(--c2);}
.lsec{font-family:'Share Tech Mono',monospace;font-size:.45rem;letter-spacing:3px;
  color:var(--txt2);margin:7px 0 4px;border-top:1px solid var(--border2);padding-top:5px;}
.lbar-wrap{margin:4px 0;}
.lbar-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:2px;}
.lbar-k{font-family:'Share Tech Mono',monospace;font-size:.46rem;color:var(--txt2);}
.lbar-v{font-family:'Share Tech Mono',monospace;font-size:.46rem;color:var(--c1);}
.lbar{height:3px;background:rgba(0,200,255,.09);border-radius:2px;overflow:hidden;margin-bottom:3px;}
.lbar-f{height:100%;border-radius:2px;transition:width .3s ease;}

/* ────── SIM PANEL (right) ────── */
#simpanel{position:fixed;right:0;top:46px;bottom:0;width:310px;z-index:400;
  background:var(--bg);border-left:1px solid var(--border);
  backdrop-filter:blur(22px);display:flex;flex-direction:column;
  transform:translateX(100%);transition:transform .38s cubic-bezier(.16,1,.3,1);}
#simpanel.on{transform:translateX(0);}
.sp-hdr{padding:12px 16px 0;border-bottom:1px solid var(--border2);}
.sp-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.sp-nr{display:flex;align-items:center;gap:9px;}
.sp-dot{width:10px;height:10px;border-radius:50%;}
.sp-name{font-family:'Rajdhani',sans-serif;font-size:1.1rem;font-weight:700;color:#fff;letter-spacing:2px;}
.sp-en{font-family:'Share Tech Mono',monospace;font-size:.52rem;color:rgba(0,200,255,.5);letter-spacing:3px;margin-top:1px;}
#spc{width:24px;height:24px;background:var(--c1b);border:1px solid rgba(0,200,255,.2);
  color:var(--c1);border-radius:2px;cursor:pointer;font-size:.78rem;
  display:flex;align-items:center;justify-content:center;transition:all .2s;}
#spc:hover{background:var(--c1a);}
.sp-tabs{display:flex;border-bottom:1px solid var(--border2);}
.sptab{flex:1;font-family:'Share Tech Mono',monospace;font-size:.5rem;letter-spacing:1px;
  text-transform:uppercase;padding:8px 4px;background:none;border:none;
  color:rgba(0,200,255,.28);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .18s;}
.sptab.on,.sptab:hover{color:var(--c1);border-bottom-color:var(--c1);}
.sp-body{flex:1;overflow-y:auto;padding:11px 15px;}
.sp-body::-webkit-scrollbar{width:2px;}
.sp-body::-webkit-scrollbar-thumb{background:rgba(0,200,255,.13);}

/* data */
.dr{display:flex;justify-content:space-between;align-items:baseline;padding:4px 0;border-bottom:1px solid var(--border2);}
.dk{font-family:'Share Tech Mono',monospace;font-size:.52rem;color:var(--txt2);}
.dv{font-family:'Share Tech Mono',monospace;font-size:.62rem;color:#d0f0ff;text-align:right;}
.dv.b{color:var(--c1);}.dv.r{color:var(--cr);}.dv.w{color:var(--cw);}.dv.g{color:var(--c2);}
.sd{font-family:'Share Tech Mono',monospace;font-size:.48rem;letter-spacing:3px;color:var(--c1);
  margin:10px 0 6px;display:flex;align-items:center;gap:5px;}
.sd::after{content:'';flex:1;height:1px;background:rgba(0,200,255,.1);}
.pt{font-size:.6rem;color:rgba(0,200,255,.42);line-height:1.65;margin-bottom:4px;}
.pg{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin:6px 0;}
.pb{background:var(--c1b);border:1px solid var(--border2);border-radius:3px;padding:8px;}
.pbl{font-family:'Share Tech Mono',monospace;font-size:.46rem;color:var(--txt2);margin-bottom:2px;}
.pbv{font-family:'Rajdhani',sans-serif;font-size:.88rem;font-weight:600;color:var(--c1);}
.pbu{font-family:'Share Tech Mono',monospace;font-size:.44rem;color:var(--txt2);}

/* sliders */
.slb{margin-bottom:12px;}
.slh{display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;}
.sll{font-family:'Share Tech Mono',monospace;font-size:.55rem;color:rgba(0,200,255,.5);}
.slv{font-family:'Rajdhani',sans-serif;font-size:.78rem;font-weight:600;color:var(--c1);}
input[type=range]{width:100%;-webkit-appearance:none;height:2px;background:rgba(0,200,255,.13);
  border-radius:1px;outline:none;cursor:pointer;}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:11px;height:11px;
  border-radius:50%;background:var(--c1);cursor:pointer;box-shadow:0 0 7px rgba(0,200,255,.8);}
.sld{font-size:.56rem;color:var(--txt2);line-height:1.5;margin-top:2px;}

/* mini canvases */
.fcw{margin:7px 0;border:1px solid var(--border2);border-radius:3px;overflow:hidden;background:rgba(0,0,8,.8);}
.fcl{font-family:'Share Tech Mono',monospace;font-size:.46rem;letter-spacing:2px;
  color:var(--txt2);padding:4px 7px;border-bottom:1px solid var(--border2);}
.fc{display:block;width:100%;height:82px;}

/* tidal */
.tp{background:rgba(255,140,0,.03);border:1px solid rgba(255,140,0,.12);
  border-radius:3px;padding:9px;margin-top:6px;}
.tt{font-family:'Share Tech Mono',monospace;font-size:.5rem;color:var(--cw);letter-spacing:2px;margin-bottom:6px;}
.ml{display:flex;flex-wrap:wrap;gap:4px;margin-top:5px;}
.mc{display:inline-flex;align-items:center;gap:4px;background:var(--c1b);
  border:1px solid var(--border);border-radius:2px;padding:3px 7px;
  font-family:'Share Tech Mono',monospace;font-size:.5rem;color:rgba(0,200,255,.62);
  cursor:pointer;transition:all .18s;}
.mc:hover{background:var(--c1a);color:#fff;}
.mcd{width:5px;height:5px;border-radius:50%;}

/* ────── HELP OVERLAY ────── */
#help{position:fixed;bottom:42px;left:50%;transform:translateX(-50%);z-index:450;
  background:rgba(0,3,18,.82);border:1px solid var(--border);border-radius:4px;
  backdrop-filter:blur(14px);padding:10px 20px;pointer-events:none;
  transition:opacity .4s;display:flex;gap:20px;flex-wrap:wrap;justify-content:center;}
.hk{display:flex;align-items:center;gap:6px;}
.hkey{font-family:'Share Tech Mono',monospace;font-size:.52rem;
  background:rgba(0,200,255,.1);border:1px solid rgba(0,200,255,.25);
  border-radius:2px;padding:2px 6px;color:var(--c1);}
.hdesc{font-family:'Share Tech Mono',monospace;font-size:.5rem;color:var(--txt2);}
#help-toggle{position:fixed;bottom:42px;right:16px;z-index:460;
  font-family:'Share Tech Mono',monospace;font-size:.55rem;letter-spacing:2px;
  background:var(--c1b);border:1px solid var(--border);border-radius:2px;
  color:var(--c1);padding:5px 10px;cursor:pointer;transition:all .2s;}
#help-toggle:hover{background:var(--c1a);}

/* ────── BOTTOM BAR ────── */
#bot{position:fixed;bottom:0;left:0;right:0;height:38px;z-index:500;pointer-events:none;
  background:linear-gradient(to top,rgba(0,3,18,.95) 55%,transparent);
  display:flex;align-items:center;justify-content:space-between;padding:0 18px;
  border-top:1px solid var(--border2);}
.btxt{font-family:'Share Tech Mono',monospace;font-size:.52rem;color:var(--txt2);letter-spacing:1px;}

/* ────── TOOLTIP ────── */
#tip{position:fixed;pointer-events:none;z-index:600;background:rgba(0,3,18,.94);
  border:1px solid rgba(0,200,255,.28);border-radius:2px;padding:7px 11px;
  font-family:'Share Tech Mono',monospace;font-size:.58rem;color:#d0f0ff;
  letter-spacing:1px;opacity:0;transition:opacity .1s;max-width:220px;}

/* ────── SCANLINES ────── */
#scl{position:fixed;inset:0;pointer-events:none;z-index:1000;
  background:repeating-linear-gradient(0deg,rgba(0,0,0,.022) 0,rgba(0,0,0,.022) 1px,transparent 1px,transparent 4px);}

/* help hide */
.help-hidden{opacity:0!important;}
#intro{position:fixed;inset:0;z-index:2000;display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  background:radial-gradient(ellipse at 50% 40%, rgba(0,30,60,.98) 0%, rgba(0,3,18,1) 70%);
  transition:opacity .8s ease;}
#intro.hidden{opacity:0;pointer-events:none;}
.intro-stars{position:absolute;inset:0;overflow:hidden;pointer-events:none;}
.intro-star{position:absolute;border-radius:50%;background:#fff;animation:twinkle var(--d,3s) infinite var(--del,0s);}
@keyframes twinkle{0%,100%{opacity:.1}50%{opacity:1}}
.intro-logo{font-family:'Rajdhani',sans-serif;font-size:clamp(2rem,6vw,4.5rem);font-weight:700;
  color:#fff;letter-spacing:6px;text-align:center;margin-bottom:8px;
  text-shadow:0 0 40px rgba(0,200,255,.6),0 0 80px rgba(0,200,255,.2);}
.intro-logo span{color:var(--c1);}
.intro-sub{font-family:'Share Tech Mono',monospace;font-size:clamp(.6rem,1.5vw,.85rem);
  color:rgba(0,200,255,.55);letter-spacing:5px;text-align:center;margin-bottom:60px;}
.intro-btns{display:flex;gap:20px;flex-wrap:wrap;justify-content:center;}
.intro-btn{font-family:'Rajdhani',sans-serif;font-size:1.15rem;font-weight:600;
  letter-spacing:3px;padding:15px 42px;border-radius:3px;cursor:pointer;
  transition:all .25s;text-transform:uppercase;border:none;}
.intro-btn-primary{background:linear-gradient(135deg,var(--c1),#0088cc);color:#000;
  box-shadow:0 0 30px rgba(0,200,255,.45),0 4px 20px rgba(0,0,0,.4);}
.intro-btn-primary:hover{transform:translateY(-3px);box-shadow:0 0 50px rgba(0,200,255,.7),0 8px 30px rgba(0,0,0,.5);}
.intro-btn-secondary{background:transparent;color:var(--c1);
  border:1px solid rgba(0,200,255,.45);
  box-shadow:0 0 15px rgba(0,200,255,.15);}
.intro-btn-secondary:hover{background:rgba(0,200,255,.1);border-color:var(--c1);
  transform:translateY(-3px);box-shadow:0 0 30px rgba(0,200,255,.3);}
.intro-note{font-family:'Share Tech Mono',monospace;font-size:.55rem;
  color:rgba(0,200,255,.25);letter-spacing:2px;margin-top:40px;text-align:center;}

/* ────── ENCYCLOPEDIA MODAL ────── */
#encyc{position:fixed;inset:0;z-index:1900;display:flex;
  background:rgba(0,3,18,.96);backdrop-filter:blur(24px);
  transition:opacity .4s;opacity:0;pointer-events:none;}
#encyc.on{opacity:1;pointer-events:all;}
.enc-left{width:240px;flex-shrink:0;border-right:1px solid var(--border);
  display:flex;flex-direction:column;background:rgba(0,5,22,.8);}
.enc-lhdr{padding:20px 18px 12px;border-bottom:1px solid var(--border2);}
.enc-title{font-family:'Rajdhani',sans-serif;font-size:1.3rem;font-weight:700;
  color:var(--c1);letter-spacing:4px;margin-bottom:4px;}
.enc-sub2{font-family:'Share Tech Mono',monospace;font-size:.52rem;color:var(--txt2);}
.enc-list{flex:1;overflow-y:auto;padding:8px 0;}
.enc-list::-webkit-scrollbar{width:2px;}
.enc-list::-webkit-scrollbar-thumb{background:rgba(0,200,255,.2);}
.enc-item{display:flex;align-items:center;gap:10px;padding:10px 18px;
  cursor:pointer;transition:all .18s;border-left:2px solid transparent;}
.enc-item:hover{background:var(--c1a);border-left-color:rgba(0,200,255,.4);}
.enc-item.sel{background:var(--c1a);border-left-color:var(--c1);}
.enc-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.enc-iname{font-family:'Rajdhani',sans-serif;font-size:.88rem;font-weight:600;color:#d8f0ff;}
.enc-ien{font-family:'Share Tech Mono',monospace;font-size:.48rem;color:var(--txt2);}
.enc-right{flex:1;display:flex;flex-direction:column;overflow:hidden;}
.enc-rhdr{display:flex;align-items:center;justify-content:space-between;
  padding:18px 28px;border-bottom:1px solid var(--border2);}
.enc-pname{font-family:'Rajdhani',sans-serif;font-size:1.8rem;font-weight:700;
  color:#fff;letter-spacing:3px;}
.enc-pen{font-family:'Share Tech Mono',monospace;font-size:.65rem;
  color:var(--c1);letter-spacing:4px;margin-top:2px;}
.enc-close{font-family:'Share Tech Mono',monospace;font-size:.58rem;letter-spacing:2px;
  background:var(--c1b);border:1px solid var(--border);color:var(--c1);
  padding:7px 14px;border-radius:2px;cursor:pointer;transition:all .2s;}
.enc-close:hover{background:var(--c1a);}
.enc-body{flex:1;overflow-y:auto;padding:24px 28px;}
.enc-body::-webkit-scrollbar{width:3px;}
.enc-body::-webkit-scrollbar-thumb{background:rgba(0,200,255,.2);}
.enc-section{margin-bottom:22px;}
.enc-sh{font-family:'Share Tech Mono',monospace;font-size:.58rem;letter-spacing:3px;
  color:var(--c1);margin-bottom:10px;display:flex;align-items:center;gap:8px;}
.enc-sh::after{content:'';flex:1;height:1px;background:rgba(0,200,255,.15);}
.enc-txt{font-size:.82rem;color:rgba(200,228,242,.75);line-height:1.85;}
.enc-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:4px;}
.enc-box{background:rgba(0,200,255,.04);border:1px solid var(--border2);
  border-radius:3px;padding:11px 13px;}
.enc-bl{font-family:'Share Tech Mono',monospace;font-size:.5rem;color:var(--txt2);margin-bottom:3px;}
.enc-bv{font-family:'Rajdhani',sans-serif;font-size:1.05rem;font-weight:600;color:var(--c1);}
.enc-bu{font-family:'Share Tech Mono',monospace;font-size:.46rem;color:var(--txt2);}
.enc-badge{display:inline-block;font-family:'Share Tech Mono',monospace;font-size:.52rem;
  padding:3px 9px;border-radius:2px;margin:3px 3px 0 0;}
.enc-badge-b{background:rgba(0,200,255,.1);color:var(--c1);border:1px solid rgba(0,200,255,.25);}
.enc-badge-r{background:rgba(255,68,68,.08);color:#ff6666;border:1px solid rgba(255,68,68,.25);}
.enc-badge-g{background:rgba(0,255,136,.08);color:var(--c2);border:1px solid rgba(0,255,136,.25);}
.enc-badge-w{background:rgba(255,170,0,.08);color:var(--cw);border:1px solid rgba(255,170,0,.25);}
.enc-go{font-family:'Rajdhani',sans-serif;font-size:.85rem;font-weight:600;letter-spacing:2px;
  background:linear-gradient(135deg,var(--c1),#0088cc);color:#000;border:none;
  padding:10px 24px;border-radius:2px;cursor:pointer;margin-top:16px;
  transition:all .2s;text-transform:uppercase;}
.enc-go:hover{transform:translateY(-2px);box-shadow:0 4px 20px rgba(0,200,255,.4);}
.enc-placeholder{display:flex;flex-direction:column;align-items:center;justify-content:center;
  height:100%;color:var(--txt2);text-align:center;gap:12px;}
.enc-placeholder-icon{font-size:3rem;opacity:.3;}
.enc-placeholder-txt{font-family:'Share Tech Mono',monospace;font-size:.62rem;letter-spacing:3px;}

</style>
</head>
<body>
<canvas id="c"></canvas>
<div id="scl"></div>

<!-- ═══ INTRO SCREEN ═══ -->
<div id="intro">
  <div class="intro-stars" id="istars"></div>
  <div class="intro-logo">☀ SOLAR PHYSICS<br><span>LAB</span></div>
  <div class="intro-sub">INTERACTIVE SOLAR SYSTEM EXPLORER · NASA JPL DATA</div>
  <div class="intro-btns">
    <button class="intro-btn intro-btn-primary" onclick="startExplore()">🚀 탐험 시작!</button>
    <button class="intro-btn intro-btn-secondary" onclick="openEncyc()">📚 백과사전</button>
  </div>
  <div class="intro-note">수성 · 금성 · 화성 · 목성 · 토성 · 천왕성 · 해왕성 + 전체 위성 시스템</div>
</div>

<!-- ═══ ENCYCLOPEDIA MODAL ═══ -->
<div id="encyc">

function makeGlowTex(S=128,c0='rgba(255,250,200,.8)',c1='rgba(0,0,0,0)'){
  const cv2=document.createElement('canvas');cv2.width=cv2.height=S;
  const g=cv2.getContext('2d'),h=S*.5;
  const gr=g.createRadialGradient(h,h,0,h,h,h);
  gr.addColorStop(0,c0);gr.addColorStop(.4,'rgba(200,180,80,.25)');gr.addColorStop(1,c1);
  g.fillStyle=gr;g.fillRect(0,0,S,S);
  return new THREE.CanvasTexture(cv2);
}

function makePlanetTex(bd,radN=1,atmN=.5){
  const S=512,cx=S/2,R=S/2-1;
  const cv2=document.createElement('canvas');cv2.width=cv2.height=S;
  const g=cv2.getContext('2d');
  const bc=new THREE.Color(bd.col);
  const heat=Math.max(0,radN-1);
  const r=Math.min(1,bc.r+heat*.38),gv=Math.max(0,bc.g-heat*.2),b=Math.max(0,bc.b-heat*.3);
  const bg=g.createRadialGradient(cx-R*.28,cx*.72,R*.04,cx,cx,R);
  bg.addColorStop(0,`rgb(${Math.min(255,r*255+82)},${Math.min(255,gv*255+82)},${Math.min(255,b*255+82)})`);
  bg.addColorStop(.38,`rgb(${Math.round(r*255)},${Math.round(gv*255)},${Math.round(b*255)})`);
  bg.addColorStop(1,`rgb(${Math.round(r*78)},${Math.round(gv*68)},${Math.round(b*72)})`);
  g.beginPath();g.arc(cx,cx,R,0,Math.PI*2);g.fillStyle=bg;g.fill();
  g.save();g.beginPath();g.arc(cx,cx,R,0,Math.PI*2);g.clip();
  bd.bands.forEach(([yf,wf,c])=>{
    const [br,bg2,bb,ba]=c;
    const by=cx+yf*S,bh=wf*S;
    const hbr=Math.min(255,br+heat*55);
    const bgr=g.createLinearGradient(0,by-bh/2,0,by+bh/2);
    bgr.addColorStop(0,`rgba(${hbr},${bg2},${bb},0)`);
    bgr.addColorStop(.5,`rgba(${hbr},${bg2},${bb},${ba})`);
    bgr.addColorStop(1,`rgba(${hbr},${bg2},${bb},0)`);
    g.fillStyle=bgr;g.fillRect(0,by-bh/2,S,bh);
  });
  if(bd.grs){
    const gx=cx+S*.16,gy=cx+S*.02,grx=S*.13*(1+heat*.25),gry=S*.075;
    const gg=g.createRadialGradient(gx,gy,0,gx,gy,grx);
    gg.addColorStop(0,`rgba(${Math.min(255,205+heat*52)},${Math.max(22,68-heat*44)},14,.96)`);
    gg.addColorStop(.45,`rgba(${Math.min(255,172+heat*38)},${Math.max(12,42-heat*28)},7,.62)`);
    gg.addColorStop(1,'rgba(0,0,0,0)');
    g.save();g.scale(1,gry/grx);
    g.beginPath();g.arc(gx,gy*(grx/gry),grx,0,Math.PI*2);g.fillStyle=gg;g.fill();
    for(let i=0;i<5;i++){
      g.beginPath();g.ellipse(gx,gy,grx*(1.04+i*.12),gry*(1.04+i*.12),0,i*.4,(i+.8)*Math.PI*.9);
      g.strokeStyle=`rgba(${Math.min(255,155+heat*32)},58,18,.17)`;g.lineWidth=1.8;g.stroke();
    }
    g.restore();
  }
  if(bd.polar){
    const capH=S*.1+atmN*S*.04;
    const ng=g.createLinearGradient(0,0,0,capH);
    ng.addColorStop(0,bd.polar[0]);ng.addColorStop(1,'rgba(0,0,0,0)');
    g.fillStyle=ng;g.fillRect(0,0,S,capH);
    const sg=g.createLinearGradient(0,S-capH,0,S);
    sg.addColorStop(0,'rgba(0,0,0,0)');sg.addColorStop(1,bd.polar[1]);
    g.fillStyle=sg;g.fillRect(0,S-capH,S,capH);
  }
  g.restore();
  if(atmN>.06){
    const atmCols={venus:[240,210,80],mars:[212,108,60],jupiter:[200,162,84],
      saturn:[220,192,112],uranus:[80,222,222],neptune:[60,100,242]};
    const ac=atmCols[bd.id]||[100,180,255];
    const ag=g.createRadialGradient(cx,cx,R*.72,cx,cx,R);
    ag.addColorStop(0,'rgba(0,0,0,0)');
    ag.addColorStop(1,`rgba(${ac[0]},${ac[1]},${ac[2]},${atmN*.34})`);
    g.beginPath();g.arc(cx,cx,R,0,Math.PI*2);g.fillStyle=ag;g.fill();
  }
  const rim=g.createRadialGradient(cx,cx,R*.8,cx,cx,R);
  rim.addColorStop(0,'rgba(255,255,255,0)');rim.addColorStop(1,'rgba(255,255,255,.065)');
  g.beginPath();g.arc(cx,cx,R,0,Math.PI*2);g.fillStyle=rim;g.fill();
  return new THREE.CanvasTexture(cv2);
}

function makeMoonTex(m){
  const S=128,cx=S/2,R=S/2-1;
  const cv2=document.createElement('canvas');cv2.width=cv2.height=S;
  const g=cv2.getContext('2d');
  const mc=new THREE.Color(m.col);
  const bg=g.createRadialGradient(cx-R*.28,cx*.72,R*.04,cx,cx,R);
  bg.addColorStop(0,`rgb(${Math.min(255,mc.r*255+68)},${Math.min(255,mc.g*255+68)},${Math.min(255,mc.b*255+68)})`);
  bg.addColorStop(.45,`rgb(${Math.round(mc.r*255)},${Math.round(mc.g*255)},${Math.round(mc.b*255)})`);
  bg.addColorStop(1,`rgb(${Math.round(mc.r*70)},${Math.round(mc.g*70)},${Math.round(mc.b*70)})`);
  g.beginPath();g.arc(cx,cx,R,0,Math.PI*2);g.fillStyle=bg;g.fill();
  g.save();g.beginPath();g.arc(cx,cx,R,0,Math.PI*2);g.clip();
  if(m.id==='io'){for(let i=0;i<9;i++){
    const vx=Math.random()*S,vy=Math.random()*S;
    const vg=g.createRadialGradient(vx,vy,0,vx,vy,7+Math.random()*9);
    vg.addColorStop(0,'rgba(255,72,0,.78)');vg.addColorStop(1,'rgba(0,0,0,0)');
    g.beginPath();g.arc(vx,vy,13,0,Math.PI*2);g.fillStyle=vg;g.fill();
  }}
  if(m.id==='europa'){g.strokeStyle='rgba(165,145,215,.52)';g.lineWidth=1.2;
    for(let i=0;i<8;i++){g.beginPath();g.moveTo(Math.random()*S,Math.random()*S);g.lineTo(Math.random()*S,Math.random()*S);g.stroke();}}
  if(m.id==='titan'){const h2=g.createRadialGradient(cx,cx,R*.5,cx,cx,R);
    h2.addColorStop(0,'rgba(0,0,0,0)');h2.addColorStop(1,'rgba(202,116,16,.44)');
    g.beginPath();g.arc(cx,cx,R,0,Math.PI*2);g.fillStyle=h2;g.fill();}
  if(m.id==='triton'){g.strokeStyle='rgba(32,52,92,.52)';g.lineWidth=1.5;
    for(let i=0;i<5;i++){const sx=cx+Math.random()*28-14,sy=cx+18;
      g.beginPath();g.moveTo(sx,sy);g.lineTo(sx+(Math.random()-.5)*18,sy-28);g.stroke();}}
  if(m.id==='enceladus'){g.strokeStyle='rgba(158,212,255,.42)';g.lineWidth=1;
    for(let i=0;i<5;i++){const sx=cx+Math.random()*20-10,sy=cx+20;
      g.beginPath();g.moveTo(sx,sy);g.lineTo(sx+(Math.random()-.5)*12,sy-24);g.stroke();}}
  const nCr=(m.id==='callisto'||m.id==='rhea'||m.id==='mimas')?10:4;
  for(let i=0;i<nCr;i++){
    const cx2=Math.random()*S,cy2=Math.random()*S,cr=2+Math.random()*6;
    const ch=g.createRadialGradient(cx2-cr*.3,cy2-cr*.3,cr*.08,cx2,cy2,cr);
    ch.addColorStop(0,'rgba(255,255,255,.14)');ch.addColorStop(1,'rgba(0,0,0,.22)');
    g.beginPath();g.arc(cx2,cy2,cr,0,Math.PI*2);
    g.strokeStyle='rgba(0,0,0,.26)';g.lineWidth=.9;g.stroke();g.fillStyle=ch;g.fill();
  }
  g.restore();
  return new THREE.CanvasTexture(cv2);
}

function makeSaturnRingTex(){
  const W=512,H=4;const cv2=document.createElement('canvas');cv2.width=W;cv2.height=H;
  const g=cv2.getContext('2d');
  const segs=[
    {s:.0,  e:.22,a:.17,'r':170,'g':140,'b':100},
    {s:.22, e:.54,a:.64,'r':218,'g':195,'b':158},
    {s:.54, e:.57,a:.02,'r':0,  'g':0,  'b':0  },
    {s:.57, e:.87,a:.44,'r':202,'g':178,'b':140},
    {s:.87, e:.94,a:.10,'r':188,'g':165,'b':125},
    {s:.94, e:1.0,a:.04,'r':162,'g':142,'b':108},
  ];
  segs.forEach(s=>{
    const grd=g.createLinearGradient(s.s*W,0,s.e*W,0);
    grd.addColorStop(0,`rgba(${s.r},${s.g},${s.b},${s.a*.45})`);
    grd.addColorStop(.3,`rgba(${s.r},${s.g},${s.b},${s.a})`);
    grd.addColorStop(.7,`rgba(${s.r},${s.g},${s.b},${s.a})`);
    grd.addColorStop(1,`rgba(${s.r},${s.g},${s.b},${s.a*.38})`);
    g.fillStyle=grd;g.fillRect(s.s*W,0,(s.e-s.s)*W,H);
  });
  const tex=new THREE.CanvasTexture(cv2);
  tex.wrapS=tex.wrapT=THREE.ClampToEdgeWrapping;
  return tex;
}

// Atmosphere rim shader
function makeAtmoShader(r,gv,b){
  return new THREE.ShaderMaterial({
    uniforms:{c:{value:.18},p:{value:3.5},gColor:{value:new THREE.Color(r/255,gv/255,b/255)},vv:{value:new THREE.Vector3()}},
    vertexShader:`uniform vec3 vv;uniform float c,p;varying float intensity;
      void main(){vec3 n=normalize(normalMatrix*normal);vec3 e=normalize(normalMatrix*vv);
      intensity=pow(c-dot(n,e),p);gl_Position=projectionMatrix*modelViewMatrix*vec4(position,1.);}`,
    fragmentShader:`uniform vec3 gColor;varying float intensity;
      void main(){gl_FragColor=vec4(gColor*intensity,intensity);}`,
    side:THREE.BackSide,blending:THREE.AdditiveBlending,transparent:true,depthWrite:false
  });
}


      <div class="factor-canvas-wrap">
        <div class="factor-canvas-label">☄ 충돌 & 대기 방어</div>
        <canvas class="fcanvas" id="mc-impact" height="100"></canvas>
      </div>
      ${isEuropa?`
      <div class="factor-canvas-wrap">
        <div class="factor-canvas-label">🌊 목성 기조력 & 에우로파 내부열</div>
        <canvas class="fcanvas" id="mc-tidal" height="100"></canvas>
      </div>`:''}

      <div style="font-size:.52rem;color:rgba(0,200,255,.2);margin-top:8px;line-height:1.8">
        물리 공식: F=GMm/r² · v_esc=√(2GM/r) · T_eff=(F(1-A)/4σ)^0.25<br>
        NASA JPL Planetary Fact Sheets 기반
      </div>
    `;
    setTimeout(()=>startMiniSims(bodyId),60);

  } else { // physics
    const gN = ss.gravConst;

// Build encyclopedia list (planets + major moons)
(function buildEncList(){
  const list=document.getElementById('enclist');
  let html='';
  BODIES.forEach(pl=>{
    const col=`#${new THREE.Color(pl.col).getHexString()}`;
    html+=`<div class="enc-item" data-eid="${pl.id}" onclick="showEnc('${pl.id}','planet')">
      <div class="enc-dot" style="background:${col};box-shadow:0 0 5px ${col}60"></div>
      <div><div class="enc-iname">${pl.emoji} ${pl.name}</div><div class="enc-ien">${pl.en}</div></div>
    </div>`;
  });
  html+=`<div style="font-family:'Share Tech Mono',monospace;font-size:.46rem;letter-spacing:3px;color:rgba(0,200,255,.28);padding:10px 18px 4px;">주요 위성</div>`;
  Object.entries(ENC_MOONS).forEach(([id,m])=>{
    const col=`#${new THREE.Color(m.col).getHexString()}`;
    html+=`<div class="enc-item" data-eid="${id}" onclick="showEnc('${id}','moon')">
      <div class="enc-dot" style="background:${col};width:8px;height:8px"></div>
      <div><div class="enc-iname" style="font-size:.78rem">${m.name}</div><div class="enc-ien">${m.en} · ${m.parent}계</div></div>
    </div>`;
  });
  list.innerHTML=html;
})();

function showEnc(pid, type='planet'){
  const data = type==='moon' ? ENC_MOONS[pid] : ENC_DATA[pid];
  const bd   = type==='moon' ? null : BODIES.find(p=>p.id===pid);
  if(!data) return;

  document.querySelectorAll('.enc-item').forEach(el=>el.classList.toggle('sel',el.dataset.eid===pid));
  const col = bd ? `#${new THREE.Color(bd.col).getHexString()}` : `#${new THREE.Color(data.col||0x88aacc).getHexString()}`;
  document.getElementById('encpname').textContent = `${bd?.emoji||'🌑'} ${data.name||bd?.name}`;
  document.getElementById('encpen').textContent   = (data.en||bd?.en||'').toUpperCase() + (bd?' — '+bd.a.toFixed(3)+' AU':'');

  const body=document.getElementById('encbody');
  body.innerHTML=`
    <div class="enc-section">
      <div class="enc-sh">개요</div>
      <div class="enc-txt">${data.overview}</div>
    </div>
    <div class="enc-section">
      <div class="enc-sh">핵심 데이터</div>
      <div class="enc-grid">${data.facts.map(f=>`<div class="enc-box"><div class="enc-bl">${f.l}</div><div class="enc-bv">${f.v}</div><div class="enc-bu">${f.u}</div></div>`).join('')}</div>
    </div>
    ${data.sections.map(s=>`<div class="enc-section"><div class="enc-sh">${s.icon} ${s.title}</div><div class="enc-txt">${s.text}</div></div>`).join('')}
    ${data.mystery?`<div class="enc-mystery"><div class="enc-mystery-title">🔮 ${data.mystery.title}</div><div class="enc-txt" style="font-size:.78rem">${data.mystery.text}</div></div>`:''}
    <div class="enc-section">
      <div class="enc-sh">키워드</div>
      <div>${data.tags.map(t=>`<span class="enc-badge ${t.cls}">${t.t}</span>`).join('')}</div>
    </div>
    <div style="margin-top:20px">
      <button class="enc-go" onclick="closeEncycAndExplore('${pid}')">🚀 ${data.name||bd?.name} 탐험하기</button>
    </div>
  `;
  body.scrollTop=0;
}

function openEncyc(){document.getElementById('encyc').classList.add('on');}
function closeEncyc(){document.getElementById('encyc').classList.remove('on');}
function closeEncycAndExplore(pid){
  closeEncyc();
  const intro=document.getElementById('intro');
  if(!intro.classList.contains('hidden')){intro.classList.add('hidden');setTimeout(()=>{intro.style.display='none';lockOn(pid);},900);}
  else lockOn(pid);
}


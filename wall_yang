// ═══════════════════════════════════════════════════════════════════════
//  MODULE 17: ORBITAL TRAILS SYSTEM
// ═══════════════════════════════════════════════════════════════════════
let trailsEnabled = false;
const TRAIL_MAX = 320;   // max points per trail
const TRAIL_INTERVAL = 3; // record every N frames
let trailFrameCount = 0;

// Trail geometry per planet
const trailGeo = {}, trailMesh = {}, trailData = {};

// Colors: trail uses planet color at low opacity
function buildTrailMesh(pl){
  const geo = new THREE.BufferGeometry();
  const positions = new Float32Array(TRAIL_MAX*3);
  geo.setAttribute('position', new THREE.BufferAttribute(positions,3));
  geo.setDrawRange(0,0);
  const col = new THREE.Color(pl.col);
  const mat = new THREE.LineBasicMaterial({
    color:col, transparent:true, opacity:.45,
    blending:THREE.AdditiveBlending, depthWrite:false,linewidth:1
  });
  const mesh = new THREE.Line(geo, mat);
  scene.add(mesh);
  trailGeo[pl.id]=geo; trailMesh[pl.id]=mesh;
  trailData[pl.id]=[];
}

BODIES.forEach(pl=> buildTrailMesh(pl));

function updateTrails(){
  if(!trailsEnabled) return;
  trailFrameCount++;
  if(trailFrameCount%TRAIL_INTERVAL!==0) return;

  BODIES.forEach(pl=>{
    const mesh = P_MESH[pl.id]; if(!mesh) return;
    const arr = trailData[pl.id];
    arr.push(mesh.position.clone());
    if(arr.length>TRAIL_MAX) arr.shift();
    const geo = trailGeo[pl.id];
    const pos = geo.attributes.position.array;
    arr.forEach((v,i)=>{pos[i*3]=v.x;pos[i*3+1]=v.y;pos[i*3+2]=v.z;});
    geo.attributes.position.needsUpdate=true;
    geo.setDrawRange(0,arr.length);
  });
}

function clearAllTrails(){
  BODIES.forEach(pl=>{
    trailData[pl.id]=[];
    if(trailGeo[pl.id]){
      trailGeo[pl.id].setDrawRange(0,0);
      trailGeo[pl.id].attributes.position.needsUpdate=true;
    }
  });
  trailFrameCount=0;
}

function toggleTrails(){
  trailsEnabled=!trailsEnabled;
  const btn=document.getElementById('trail-toggle');
  btn.textContent=`🌀 궤도 잔상: ${trailsEnabled?'ON':'OFF'}`;
  btn.classList.toggle('active',trailsEnabled);
  // Show/hide existing meshes
  BODIES.forEach(pl=>{if(trailMesh[pl.id]) trailMesh[pl.id].visible=trailsEnabled;});
  if(!trailsEnabled) clearAllTrails();
}
// Initialize hidden
BODIES.forEach(pl=>{if(trailMesh[pl.id]) trailMesh[pl.id].visible=false;});

// Predicted path (dashed future trajectory) — shown when gravity modified
const PRED_STEPS = 80;
const PRED_DT    = 0.05;
const predGeo={}, predMesh={};

BODIES.forEach(pl=>{
  const geo=new THREE.BufferGeometry();
  const pos=new Float32Array(PRED_STEPS*3);
  geo.setAttribute('position',new THREE.BufferAttribute(pos,3));
  geo.setDrawRange(0,0);
  const col=new THREE.Color(pl.col);
  const mat=new THREE.LineBasicMaterial({
    color:col,transparent:true,opacity:.28,
    blending:THREE.AdditiveBlending,depthWrite:false,linewidth:1
  });
  const m=new THREE.Line(geo,mat); m.visible=false;
  scene.add(m); predGeo[pl.id]=geo; predMesh[pl.id]=m;
});

// Gravity anomaly detection (for prediction display)
let gravityModified = {};
BODIES.forEach(pl=>gravityModified[pl.id]=false);

function updatePredictedPaths(){
  // Only compute prediction for planets with modified gravity
  BODIES.forEach(pl=>{
    const isModified = Math.abs((SIM[pl.id]?.grav||1)-1)>0.1 || nbodyEnabled;
    predMesh[pl.id].visible = isModified && trailsEnabled;
    if(!isModified){ predGeo[pl.id].setDrawRange(0,0); return; }

    const r = logOrb(pl.a);
    const T = pl.a**1.5;
    const omega = Math.PI*2/T;
    const gmod = SIM[pl.id].grav||1;
    // Simulate future N steps using modified Kepler
    const pos=predGeo[pl.id].attributes.position.array;
    let t=simTime;
    for(let i=0;i<PRED_STEPS;i++){
      t+=PRED_DT*gmod; // gravity mod affects effective orbital period
      const ang=t*omega*(2-gmod*.5); // perturbation
      const rmod=r*(1+(gmod-1)*0.08*Math.sin(i/PRED_STEPS*Math.PI));
      pos[i*3]=Math.cos(ang)*rmod;
      pos[i*3+1]=0;
      pos[i*3+2]=Math.sin(ang)*rmod;
    }
    predGeo[pl.id].attributes.position.needsUpdate=true;
    predGeo[pl.id].setDrawRange(0,PRED_STEPS);
  });
}

// ═══════════════════════════════════════════════════════════════════════
//  MODULE 18: SPACETIME GRAVITY GRID
// ═══════════════════════════════════════════════════════════════════════
let gravGridEnabled = false;
let gravGridCanvas = null, gravGridCtx = null;

// We use an offscreen canvas texture on a Three.js PlaneGeometry
const GRID_SIZE   = 200;   // scene units wide
const GRID_SEGS   = 60;    // vertex grid resolution
const gravGridGeo = new THREE.PlaneGeometry(GRID_SIZE, GRID_SIZE, GRID_SEGS, GRID_SEGS);
gravGridGeo.rotateX(-Math.PI/2); // lay flat

// Displacement shader material for spacetime warp
const gravGridMat = new THREE.ShaderMaterial({
  uniforms:{
    time:{value:0},
    gridColor:{value:new THREE.Color(0.05,0.20,0.45)},
    warpStrength:{value:0.0},
    planetPos:{value:[new THREE.Vector3(),new THREE.Vector3(),new THREE.Vector3(),new THREE.Vector3(),new THREE.Vector3(),new THREE.Vector3(),new THREE.Vector3()]},
    planetMass:{value:[0,0,0,0,0,0,0]},
    planetCount:{value:7},
  },
  vertexShader:`
    uniform float time;
    uniform vec3 planetPos[7];
    uniform float planetMass[7];
    uniform int planetCount;
    uniform float warpStrength;
    varying float vDepth;
    varying vec2 vUv;

    void main(){
      vUv = uv;
      vec3 pos = position;
      float totalWarp = 0.0;
      for(int i=0;i<7;i++){
        vec2 pFlat = planetPos[i].xz;
        vec2 vFlat = pos.xz;
        float dist = length(vFlat - pFlat);
        float mass = planetMass[i];
        // Gravity well: inversely proportional to distance
        float warp = mass * warpStrength / (dist*dist*0.01 + 1.0);
        totalWarp -= warp * 0.8;
      }
      totalWarp = max(totalWarp,-35.0); // clamp max depth
      pos.y += totalWarp;
      vDepth = abs(totalWarp) / 35.0;
      gl_Position = projectionMatrix * modelViewMatrix * vec4(pos,1.0);
    }`,
  fragmentShader:`
    uniform vec3 gridColor;
    uniform float time;
    varying float vDepth;
    varying vec2 vUv;

    float grid(vec2 uv, float size){
      vec2 g = abs(fract(uv*size)-.5);
      return min(g.x,g.y);
    }

    void main(){
      float g1 = 1.0 - smoothstep(0.0,0.04,grid(vUv,30.0));
      float g2 = 1.0 - smoothstep(0.0,0.02,grid(vUv,6.0));
      float gLine = max(g1*0.6, g2*0.15);
      vec3 warpColor = mix(gridColor, vec3(0.6,0.2,0.9), vDepth*0.8);
      float alpha = gLine * (0.18 + vDepth*0.55);
      gl_FragColor = vec4(warpColor, alpha);
    }`,
  transparent:true,
  blending:THREE.AdditiveBlending,
  depthWrite:false,
  side:THREE.DoubleSide,
  wireframe:false,
});

const gravGridMesh = new THREE.Mesh(gravGridGeo, gravGridMat);
gravGridMesh.position.y = -18; // below planet orbits
gravGridMesh.visible = false;
scene.add(gravGridMesh);

function updateGravGrid(physDt){
  if(!gravGridEnabled) return;
  gravGridMat.uniforms.time.value += physDt;

  // Update planet positions and masses in shader
  BODIES.forEach((pl,i)=>{
    const mesh = P_MESH[pl.id];
    if(mesh) gravGridMat.uniforms.planetPos.value[i].copy(mesh.position);
    const ss = SIM[pl.id];
    const gmod = ss ? ss.grav : 1;
    // Normalize mass: Jupiter=1.0, others proportional
    gravGridMat.uniforms.planetMass.value[i] = (pl.mass/1.898e27) * gmod;
  });
  gravGridMat.uniforms.warpStrength.value = 1.2;
}

function toggleGravGrid(){
  gravGridEnabled=!gravGridEnabled;
  gravGridMesh.visible=gravGridEnabled;
  const btn=document.getElementById('grid-toggle');
  btn.textContent=`📐 중력 그리드: ${gravGridEnabled?'ON':'OFF'}`;
  btn.classList.toggle('active',gravGridEnabled);
}

// ═══════════════════════════════════════════════════════════════════════
//  MODULE 19: ROCHE LIMIT & COLLISION EFFECTS
// ═══════════════════════════════════════════════════════════════════════
// Roche limit = 2.456 * R_primary * (rho_primary/rho_secondary)^(1/3)
// Simplified: compare planet distance to Sun Roche limit in scene units
const SUN_ROCHE_SCENE = 7.5; // scene units from sun center
const PLANET_ROCHE = {}; // planet id -> Roche limit vs each other
BODIES.forEach(pl=>PLANET_ROCHE[pl.id]=pl.sz*2.8); // ~2.456 x radius (visual)

// Collision particle system
const collisionParticles = [];
const COL_MAX = 2000;
const colBuf = {pos:new Float32Array(COL_MAX*3), col:new Float32Array(COL_MAX*3)};
const colGeo = new THREE.BufferGeometry();
colGeo.setAttribute('position',new THREE.BufferAttribute(colBuf.pos,3));
colGeo.setAttribute('color',   new THREE.BufferAttribute(colBuf.col,3));
const colMesh = new THREE.Points(colGeo, new THREE.PointsMaterial({
  size:.55,vertexColors:true,transparent:true,opacity:.9,
  blending:THREE.AdditiveBlending,depthWrite:false
}));
scene.add(colMesh);

function spawnCollisionBurst(pos, color=0xff4400, count=120){
  for(let i=0;i<count&&collisionParticles.length<COL_MAX;i++){
    const spd=0.8+Math.random()*3.5;
    const theta=Math.random()*Math.PI*2, phi=Math.acos(2*Math.random()-1);
    const c=new THREE.Color(color);
    const hv=Math.random();
    collisionParticles.push({
      x:pos.x, y:pos.y, z:pos.z,
      vx:Math.sin(phi)*Math.cos(theta)*spd,
      vy:Math.sin(phi)*Math.sin(theta)*spd*0.5,
      vz:Math.cos(phi)*spd,
      life:1.0, decay:0.012+Math.random()*0.018,
      r:c.r*(0.8+hv*0.2), g:c.g*(0.5+hv*0.3), b:c.b*(0.3+hv*0.4),
    });
  }
}

function updateCollisionParticles(physDt){
  for(let i=collisionParticles.length-1;i>=0;i--){
    const p=collisionParticles[i];
    p.life-=p.decay;
    if(p.life<=0){collisionParticles.splice(i,1);continue;}
    p.x+=p.vx*physDt*40; p.y+=p.vy*physDt*40; p.z+=p.vz*physDt*40;
    p.vx*=0.97; p.vy*=0.97; p.vz*=0.97; // drag
  }
  // Flush to GPU
  for(let i=0;i<collisionParticles.length;i++){
    const p=collisionParticles[i],idx=i*3;
    colBuf.pos[idx]=p.x; colBuf.pos[idx+1]=p.y; colBuf.pos[idx+2]=p.z;
    colBuf.col[idx]=p.r*p.life; colBuf.col[idx+1]=p.g*p.life; colBuf.col[idx+2]=p.b*p.life;
  }
  for(let i=collisionParticles.length;i<COL_MAX;i++) colBuf.pos[i*3]=colBuf.pos[i*3+1]=colBuf.pos[i*3+2]=9999;
  colGeo.attributes.position.needsUpdate=true;
  colGeo.attributes.color.needsUpdate=true;
}

// Planet blink state (Roche danger)
const rocheBlink={};
let rocheAlertActive=false;
let rocheAlertTimer=0;

function checkRocheLimits(){
  let closestWarning='';
  BODIES.forEach(pl=>{
    const mesh=P_MESH[pl.id]; if(!mesh) return;
    const ss=SIM[pl.id];
    const gmod=ss?.grav||1;

    // Check vs Sun
    const distSun=mesh.position.length();
    const rocheVsSun=SUN_ROCHE_SCENE*(1+(gmod-1)*.3);
    if(distSun<rocheVsSun*1.5){
      closestWarning=`⚠ ${pl.name} — 태양 로슈 한계 진입!`;
      if(distSun<rocheVsSun&&!rocheBlink[pl.id]){
        rocheBlink[pl.id]=true;
        spawnCollisionBurst(mesh.position.clone(),pl.col,150);
        setTimeout(()=>{ rocheBlink[pl.id]=false; },3000);
      }
    }

    // Planet vs planet
    BODIES.forEach(pl2=>{
      if(pl.id===pl2.id) return;
      const mesh2=P_MESH[pl2.id]; if(!mesh2) return;
      const d=mesh.position.distanceTo(mesh2.position);
      const roche=PLANET_ROCHE[pl.id]*(ss?.grav||1)*0.8;
      if(d<roche){
        closestWarning=`💥 ${pl.name} ↔ ${pl2.name} 충돌 위험!`;
        if(!rocheBlink[pl.id+pl2.id]){
          rocheBlink[pl.id+pl2.id]=true;
          const mid=mesh.position.clone().add(mesh2.position).multiplyScalar(.5);
          spawnCollisionBurst(mid,0xff2200,200);
          setTimeout(()=>{ rocheBlink[pl.id+pl2.id]=false; },4000);
        }
      }
    });

    // Red blink when gravity very high
    if(gmod>2.2){
      const blink=Math.sin(Date.now()*.008)>.3;
      if(mesh.material){
        mesh.material.emissiveIntensity=blink?1.5:Math.max(mesh.material.emissiveIntensity,(gmod-1)*.6);
      }
    }
  });

  // Roche alert banner
  const alertEl=document.getElementById('roche-alert');
  if(closestWarning){
    document.getElementById('roche-msg').textContent=closestWarning;
    alertEl.classList.add('on');
    rocheAlertTimer=60;
  } else if(rocheAlertTimer>0){
    rocheAlertTimer--;
    if(rocheAlertTimer===0) alertEl.classList.remove('on');
  }
}

// ═══════════════════════════════════════════════════════════════════════
//  PATCH: Integrate new systems into animate loop
//  (Hook into existing animate function via overriding the animate call)
// ═══════════════════════════════════════════════════════════════════════
// We patch by wrapping the existing render call at end of each frame
const _origAnimate = animate;
// Override: add post-render hooks by injecting into the requestAnimationFrame cycle
// Since animate() is already running, we patch by adding our systems
// into a separate per-frame extension function called from within animate.

// Store original animate end-of-frame hooks
window._gravExtHooks = window._gravExtHooks || [];

// The cleanest way: intercept via a proxy on renderer.render
const _origRender = renderer.render.bind(renderer);
renderer.render = function(scene, camera){
  _origRender(scene, camera);
  // Run post-render frame hooks (physDt captured from closure below)
  if(window._lastPhysDt !== undefined){
    updateTrails();
    updatePredictedPaths();
    updateGravGrid(window._lastPhysDt||0);
    updateCollisionParticles(window._lastPhysDt||0);
    checkRocheLimits();
  }
};

// Expose physDt to the post-render hooks — patch into animate loop
// We do this by patching simTime update to also capture physDt
const _origUpdateFn = null;

// Simplest reliable approach: use MutationObserver-style polling on simTime
// Actually: just set window._lastPhysDt each frame from the existing animate closure
// We patch the existing animate function's physDt assignment:
(function patchAnimatePhysDt(){
  // The animate function references physDt as a local. We can't easily patch locals.
  // Instead we shadow dt via the renderer.render hook + a global frame counter.
  let lastSimTime=0;
  const origRenderInner=renderer.render.bind(renderer);
  // Already patched above — just make sure _lastPhysDt updates each frame.
  // We track change in simTime to infer physDt:
  setInterval(()=>{
    const dt=(simTime-lastSimTime);
    window._lastPhysDt=dt>0?dt/PHYS.BASE_SPEED:0;
    lastSimTime=simTime;
  },16);
})();

// ═══════════════════════════════════════════════════════════════════════
//  MODULE 20: ENCYCLOPEDIA SYNC (Real-time gravity/mass update)
// ═══════════════════════════════════════════════════════════════════════
// Patch upd() to also sync encyclopedia if it's open for that body
const _origUpd = upd;
// Override upd to add encyclopedia sync
window.upd = function(bid, param, val){
  _origUpd(bid, param, val);
  // If encyclopedia is open and showing this body, refresh data boxes
  const encBody=document.getElementById('encbody');
  const selEid=document.querySelector('.enc-item.sel')?.dataset?.eid;
  if(selEid===bid&&encBody){
    // Update the fact boxes in place
    const bd=BODIES.find(p=>p.id===bid);
    const ss=SIM[bid]||{rad:1,grav:1,atm:.5};
    if(!bd)return;
    const gMod=surfG(bd.mass,bd.radius,ss.grav).toFixed(3);
    const eMod=escVel(bd.mass,bd.radius,ss.grav).toFixed(3);
    // Find and update gravity box if present
    const boxes=encBody.querySelectorAll('.enc-box');
    boxes.forEach(box=>{
      const lbl=box.querySelector('.enc-bl')?.textContent;
      const valEl=box.querySelector('.enc-bv');
      if(!valEl)return;
      if(lbl==='표면 중력') valEl.textContent=gMod;
      if(lbl==='탈출 속도') valEl.textContent=eMod;
      // Visual pulse on change
      valEl.style.color='#ffaa00';
      setTimeout(()=>valEl.style.color='',600);
    });
  }
  // Mark gravity as modified for predicted path system
  if(param==='grav'&&BODIES.find(p=>p.id===bid)){
    gravityModified[bid]=Math.abs(parseFloat(val)-1)>0.05;
  }
};


  SIM[bid][param]=v;
  if(document.getElementById('svr'))  document.getElementById('svr').textContent=(SIM[bid].rad||1).toFixed(2)+'×';
  if(document.getElementById('svg2')) document.getElementById('svg2').textContent=(SIM[bid].grav||1).toFixed(2)+'×';
  if(document.getElementById('sva2')) document.getElementById('sva2').textContent=Math.round((SIM[bid].atm||0)*100)+'%';

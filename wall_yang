//  ANIMATE
// ═══════════════════════════════════════════════════
let simTime=0, lastT=0, frameC=0, lastFpsT=performance.now();
const raycaster=new THREE.Raycaster();
const mouse2=new THREE.Vector2();

function animate(){
  requestAnimationFrame(animate);
  const now=performance.now(), dt=Math.min((now-lastT)/1000,.08); lastT=now;
  simTime+=dt*.08;

  frameC++;
  if(now-lastFpsT>600){
    document.getElementById('hfps').textContent=Math.round(frameC*1000/(now-lastFpsT))+' FPS';
    frameC=0;lastFpsT=now;
  }
  document.getElementById('stime').textContent='T+'+simTime.toFixed(2)+'yr';

  // Camera lerp
  if(ct.active){
    ct.t=Math.min(1,ct.t+dt*1.1);
    const e=1-Math.pow(1-ct.t,3);
    camera.position.lerpVectors(ct.sp,ct.tp,e);
    oc.target.lerpVectors(ct.sl,ct.tl,e);
    camera.lookAt(oc.target);
  } else applyOC();

  // Solar wind
  const maxRad=getMaxRad();
  spawnSolarWind(maxRad);
  for(let i=swParticles.length-1;i>=0;i--){
    const p=swParticles[i];
    const dist=Math.hypot(p.x,p.y,p.z);
    p.life-=.008+.004*(maxRad-1);
    if(p.life<=0||dist>p.maxR){swParticles.splice(i,1);continue;}
    p.x+=p.vx*dt*60; p.y+=p.vy*dt*60; p.z+=p.vz*dt*60;
  }
  updateSolarWindGPU();

  // Planets & moons
  BODIES.forEach(b=>{
    const T=Math.pow(b.a,1.5);
    const ang=simTime*(Math.PI*2/T);
    const r=b.a*AU;
    const bx=Math.cos(ang)*r, bz=Math.sin(ang)*r;
    const mesh=pMesh[b.id];
    mesh.position.set(bx,0,bz);
    mesh.rotation.y+=dt*(b.id==='venus'?-.25:.35);

    const ss=simS[b.id];
    // Update texture if slider changed
    if(texDirty[b.id]&&now-lastTexUpdate>100){
      mesh.material.map=makeTexture(b,ss.rad,ss.atm);
      mesh.material.map.needsUpdate=true;
      texDirty[b.id]=false; lastTexUpdate=now;
    }

    // Atmosphere shell scale/opacity
    const atmN=ss.atm;
    pAtm[b.id].material.opacity=atmN*.22+.025+Math.max(0,ss.rad-1)*.08;
    pAtm[b.id].scale.setScalar(1+(atmN*.18+Math.max(0,ss.rad-1)*.12));

    // Glow scale (atm + radiation)
    const gs=1+atmN*.7+Math.max(0,ss.rad-1)*.9;
    pGlow[b.id].scale.set(b.size*4*gs,b.size*4*gs,1);
    pGlow[b.id].material.opacity=.18+atmN*.15+Math.max(0,ss.rad-1)*.2;

    // Emissive (heat glow when radiation high)
    const heat=Math.max(0,ss.rad-1);
    const ec=new THREE.Color(b.emcol);
    mesh.material.emissive.set(ec.r*heat*.6,ec.g*heat*.4,ec.b*heat*.2);
    mesh.material.emissiveIntensity=heat*.5;

    // Moons
    const moons=MOONS_DATA[b.id]||[];
    moons.forEach(m=>{
      const retro=m.period<0;
      const mT=Math.abs(m.period)/365.25;
      const mAng=simTime*(Math.PI*2/mT)*(retro?-1:1);
      const mx=bx+Math.cos(mAng)*m.orb, mz=bz+Math.sin(mAng)*m.orb;
      const mmesh=mMesh[m.id];
      mmesh.position.set(mx,0,mz);
      mmesh.rotation.y+=dt*.4;
      // Moon orbit line follows parent
      if(mmesh.userData.orbitLine){
        mmesh.userData.orbitLine.position.set(bx,0,bz);
      }
      // Io: volcanic glow when tidal force high
      if(m.tidal&&ss.grav>1.2){
        const tg=Math.max(0,ss.grav-1);
        mmesh.material.emissive=new THREE.Color(tg*.4,tg*.08,0);
        mmesh.material.emissiveIntensity=tg*.8;
        if(pGlow[m.id]) pGlow[m.id]=null; // skip
        const mg=mmesh.children[0];
        if(mg&&mg.isSprite){mg.material.color.set(0xff6600);mg.material.opacity=.15+tg*.3;}
      }
    });
  });

  // Sun pulse
  const sp=1+Math.sin(simTime*5)*.02;
  sunMesh.scale.set(sp,sp,sp);

  const bc=Object.keys(pMesh).length+Object.keys(mMesh).length;
  document.getElementById('hbodies').textContent='BODIES: '+(bc+1);

  renderer.render(scene,camera);
}
animate();


function drawMSolar(ss,bd){
  const g=getMC('s');if(!g)return;
  const W=g.canvas.width,H=g.canvas.height,cx=W/2,cy=H/2;
  g.fillStyle='rgba(0,1,8,.22)';g.fillRect(0,0,W,H);
  const rN=ss.rad;
  // spawn
  const spN=Math.ceil(rN*7);
  for(let i=0;i<spN;i++) mParts.solar.push({
    x:-4,y:Math.random()*H,vx:2.5+rN*3,vy:(Math.random()-.5)*.8,life:1,
    r:rN>1.8?255:rN>1.2?220:80, g2:rN>1.8?60:rN>1.2?120:160, b:rN>1.5?20:200
  });
  mParts.solar=mParts.solar.filter(p=>p.life>0);
  mParts.solar.forEach(p=>{
    p.x+=p.vx;p.y+=p.vy;p.life-=.011;
    if(p.x>W||p.y<0||p.y>H){p.life=0;return;}
    if(Math.hypot(p.x-cx,p.y-cy)<18){p.life=0;return;}
    g.beginPath();g.moveTo(p.x-p.vx*5,p.y);g.lineTo(p.x,p.y);
    g.strokeStyle=`rgba(${p.r},${p.g2},${p.b},${p.life*.75})`;g.lineWidth=1.3;g.stroke();
    g.beginPath();g.arc(p.x,p.y,1.3,0,Math.PI*2);
    g.fillStyle=`rgba(${p.r},${p.g2},${p.b},${p.life})`;g.fill();
  });
  // Magnetosphere — compressed when radiation high
  const magR=Math.max(20,38-rN*8);
  const mg=g.createRadialGradient(cx,cy,18,cx,cy,magR+14);
  const mc=rN>1.5?`rgba(255,80,30,`:`rgba(0,160,255,`;
  mg.addColorStop(0,mc+'0)');mg.addColorStop(.7,mc+((.06+rN*.04)+')'));mg.addColorStop(1,mc+'0)');
  g.beginPath();g.arc(cx,cy,magR+14,0,Math.PI*2);g.fillStyle=mg;g.fill();
  // Aurora ring (visible when rad>1)
  if(rN>1.1){
    const aR=20; const aA=Math.min(.8,(rN-1)*1.2);
    for(let i=0;i<12;i++){
      const a=mT*.05+i*(Math.PI*2/12);
      const ax=cx+Math.cos(a)*aR, ay=cy+Math.sin(a)*aR;
      g.beginPath();g.arc(ax,ay,2.5,0,Math.PI*2);
      g.fillStyle=rN>1.8?`rgba(255,120,40,${aA})`:`rgba(80,255,160,${aA*.7})`;g.fill();
    }
  }
  // Planet
  const heat=Math.max(0,rN-1);
  const pc=new THREE.Color(bd?.col||0x4488ff);
  const pr=Math.min(1,pc.r+heat*.4),pg=Math.max(0,pc.g-heat*.2),pb=Math.max(0,pc.b-heat*.3);
  const pgg=g.createRadialGradient(cx-5,cy-5,1,cx,cy,18);
  pgg.addColorStop(0,'rgba(255,255,255,.8)');
  pgg.addColorStop(.3,`rgb(${Math.round(pr*255)},${Math.round(pg*255)},${Math.round(pb*255)})`);
  pgg.addColorStop(1,`rgb(${Math.round(pr*80)},${Math.round(pg*50)},${Math.round(pb*60)})`);
  g.beginPath();g.arc(cx,cy,18,0,Math.PI*2);g.fillStyle=pgg;g.fill();
  // Temp label
  const teff=Math.round((bd?.baseT||0)+(rN-1)*80);
  g.font="8px 'Share Tech Mono'";g.fillStyle=rN>1.5?'rgba(255,120,40,.7)':'rgba(0,200,255,.5)';
  g.textAlign='left';g.fillText(`복사×${rN.toFixed(2)}  T:${teff>0?'+':''}${teff}°C`,4,H-4);
}

function drawMGrav(ss,bd){
  const g=getMC('g');if(!g)return;
  const W=g.canvas.width,H=g.canvas.height,cx=W*.38,cy=H/2;
  g.fillStyle='rgba(0,1,8,.22)';g.fillRect(0,0,W,H);
  const gN=ss.grav;
  const M=bd?.mass||1e24,R=bd?.radius||1e6;
  const gv=G*M*gN/(R*R);
  const ev=escV(M,R,gN)/1e3;
  // Field lines
  const nL=3+Math.round(gN*2);
  for(let i=0;i<nL;i++){
    const a=mT*.008+i*(Math.PI*2/nL);
    const rx=48+gN*18,ry=28+gN*10;
    g.beginPath();g.ellipse(cx,cy,rx,ry,a,0,Math.PI*2);
    g.strokeStyle=`rgba(140,60,255,${.08+gN*.07})`;g.lineWidth=1;g.stroke();
  }
  // Tidal stretch
  const stR=1+Math.max(0,gN-1)*.1;
  g.save();g.translate(cx,cy);g.scale(stR,1/stR);
  const pgg=g.createRadialGradient(-5,-5,1,0,0,19);
  pgg.addColorStop(0,'#aaeeff');pgg.addColorStop(1,'#223388');
  g.beginPath();g.arc(0,0,19,0,Math.PI*2);g.fillStyle=pgg;g.fill();
  g.restore();
  // Orbiting moon
  const mR=44+gN*9,mA=mT*.022;
  g.beginPath();g.arc(cx+Math.cos(mA)*mR,cy+Math.sin(mA)*mR*.45,5,0,Math.PI*2);
  g.fillStyle='rgba(180,200,255,.9)';g.fill();
  // External planet (gravity source) if gN>1.2
  if(gN>1.1){
    const epX=W*.83,epY=cy;
    g.beginPath();g.arc(epX,epY,12+gN*4,0,Math.PI*2);
    g.fillStyle=`rgba(255,150,50,${.45+gN*.2})`;g.fill();
    g.setLineDash([4,5]);
    g.beginPath();g.moveTo(epX-15,epY);g.lineTo(cx+21,cy);
    g.strokeStyle=`rgba(255,150,50,${.3+gN*.2})`;g.lineWidth=1.5;g.stroke();
    g.setLineDash([]);
  }
  g.font="8px 'Share Tech Mono'";g.fillStyle='rgba(140,60,255,.6)';g.textAlign='left';
  g.fillText(`g=${gv.toFixed(2)}m/s²  v_esc=${ev.toFixed(2)}km/s`,4,H-4);
}

function drawMImpact(ss,bd){
  const g=getMC('i');if(!g)return;
  const W=g.canvas.width,H=g.canvas.height,cx=W/2,cy=H/2;
  g.fillStyle='rgba(0,1,8,.22)';g.fillRect(0,0,W,H);
  const aN=ss.atm;
  const shR=20+aN*24;
  // Atmo shield
  if(aN>.08){
    const sg=g.createRadialGradient(cx,cy,20,cx,cy,shR+8);
    const aC=bd?.id==='venus'?`rgba(240,200,80,`:`rgba(80,180,255,`;
    sg.addColorStop(0,aC+'0)');sg.addColorStop(1,aC+(aN*.2)+')');
    g.beginPath();g.arc(cx,cy,shR+8,0,Math.PI*2);g.fillStyle=sg;g.fill();
  }
  // spawn asteroid
  const ivl=Math.max(18,110-aN*80);
  if(mT%Math.round(ivl)===0){
    const ang=Math.random()*Math.PI*2;const spd=1.8+Math.random()*2;
    mParts.impact.push({x:cx+Math.cos(ang)*150,y:cy+Math.sin(ang)*90,vx:-Math.cos(ang)*spd,vy:-Math.sin(ang)*spd*.6,life:1,size:3+aN*.5,exp:false,burn:false});
  }
  mParts.impact=mParts.impact.filter(p=>p.life>0);
  mParts.impact.forEach(p=>{
    p.x+=p.vx;p.y+=p.vy;p.life-=.015;
    const d=Math.hypot(p.x-cx,p.y-cy);
    if(d<shR+5&&!p.exp&&!p.burn){
      if(aN>.35&&Math.random()<aN*.95){
        p.burn=true;p.life=0;
        for(let i=0;i<8;i++) mParts.impact.push({x:p.x,y:p.y,vx:(Math.random()-.5)*5,vy:(Math.random()-.5)*3,life:.5,size:1.5,exp:true,burn:true,flame:true});
        return;
      }
    }
    if(d<22&&!p.exp){
      p.exp=true;p.life=0;
      for(let i=0;i<25+Math.round(aN*10);i++){
        const ea=Math.random()*Math.PI*2,es=2+Math.random()*5;
        mParts.impact.push({x:p.x,y:p.y,vx:Math.cos(ea)*es,vy:Math.sin(ea)*es*.5,life:.9,size:2,exp:true,burn:false});
      }
    }
    const fc=p.flame?`rgba(255,200,50,${p.life})`:`rgba(${p.exp?'255,120,40':'180,150,120'},${p.life*.8})`;
    g.beginPath();g.arc(p.x,p.y,p.size,0,Math.PI*2);g.fillStyle=fc;g.fill();
  });
  // Planet
  const pc=new THREE.Color(bd?.col||0x4488ff);
  const pgg=g.createRadialGradient(cx-5,cy-5,1,cx,cy,20);
  pgg.addColorStop(0,'rgba(255,255,255,.7)');
  pgg.addColorStop(1,`rgb(${Math.round(pc.r*200)},${Math.round(pc.g*180)},${Math.round(pc.b*180)})`);
  g.beginPath();g.arc(cx,cy,20,0,Math.PI*2);g.fillStyle=pgg;g.fill();
  g.font="8px 'Share Tech Mono'";g.fillStyle='rgba(255,100,40,.6)';g.textAlign='left';
  g.fillText(`대기밀도:${Math.round(aN*100)}%  방어:${Math.round(aN*92)}%`,4,H-4);
}

function drawMTidal(ss,bd){
  const g=getMC('t');if(!g)return;
  const W=g.canvas.width,H=g.canvas.height,jcx=W*.23,jcy=H*.5,ecx=W*.7,ecy=H*.5;
  g.fillStyle='rgba(0,1,8,.22)';g.fillRect(0,0,W,H);
  const gN=ss.grav||1;
  const tf=tidalF(1.898e27*gN,bd?.mass||4.8e22,6.71e8,bd?.radius||1.56e6);
  const th=(bd?.tidalHeat||83.5e9)*gN;
  // Jupiter
  const jgg=g.createRadialGradient(jcx-5,jcy-5,2,jcx,jcy,22);
  jgg.addColorStop(0,'#ffe');jgg.addColorStop(.4,'#c89860');jgg.addColorStop(1,'#6a4020');
  g.beginPath();g.arc(jcx,jcy,22,0,Math.PI*2);g.fillStyle=jgg;g.fill();
  // Tidal arrows
  const tS=Math.min(28,(tf/1e18)*gN*25);
  g.strokeStyle='rgba(255,100,50,.75)';g.lineWidth=2;
  // stretch (horizontal)
  [[ecx-14,ecy,ecx-14-tS,ecy],[ecx+14,ecy,ecx+14+tS,ecy]].forEach(([x1,y1,x2,y2])=>{
    g.beginPath();g.moveTo(x1,y1);g.lineTo(x2,y2);g.stroke();
    const aDir=x2>x1?1:-1;
    g.beginPath();g.moveTo(x2,y2);g.lineTo(x2-aDir*5,y2-3);g.moveTo(x2,y2);g.lineTo(x2-aDir*5,y2+3);g.stroke();
  });
  // compress (vertical)
  g.strokeStyle='rgba(50,160,255,.7)';
  [[ecx,ecy-14,ecx,ecy-14+tS*.6],[ecx,ecy+14,ecx,ecy+14-tS*.6]].forEach(([x1,y1,x2,y2])=>{
    g.beginPath();g.moveTo(x1,y1);g.lineTo(x2,y2);g.stroke();
  });
  // Europa (deformed ellipse)
  const str=1+gN*.05; const pulse=1+Math.sin(mT*.12)*.04*gN;
  g.save();g.translate(ecx,ecy);g.scale(str*pulse,pulse/str);
  const egg=g.createRadialGradient(-3,-3,1,0,0,13);
  egg.addColorStop(0,'#ffffff');egg.addColorStop(.5,'#aac8e8');egg.addColorStop(1,'#334466');
  g.beginPath();g.arc(0,0,13,0,Math.PI*2);g.fillStyle=egg;g.fill();
  // Ice cracks (more intense with high gravity)
  g.strokeStyle=`rgba(255,150,100,${.15+gN*.2})`;g.lineWidth=.9;
  [[-9,2,9,-2],[-5,-8,5,8],[-8,-5,8,5]].forEach(([x1,y1,x2,y2])=>{g.beginPath();g.moveTo(x1,y1);g.lineTo(x2,y2);g.stroke();});
  g.restore();
  // Internal heat glow
  const heatA=Math.min(.55,gN*.22);
  const hgg=g.createRadialGradient(ecx,ecy,0,ecx,ecy,14);
  hgg.addColorStop(0,`rgba(255,90,0,${heatA})`);hgg.addColorStop(1,'rgba(255,90,0,0)');
  g.beginPath();g.arc(ecx,ecy,14,0,Math.PI*2);g.fillStyle=hgg;g.fill();
  // Connecting line
  g.setLineDash([3,5]);g.strokeStyle='rgba(255,165,0,.22)';g.lineWidth=1;
  g.beginPath();g.moveTo(jcx+24,jcy);g.lineTo(ecx-15,ecy);g.stroke();g.setLineDash([]);
  g.font="8px 'Share Tech Mono'";g.fillStyle='rgba(255,165,0,.55)';g.textAlign='left';
  g.fillText(`ΔF:${(tf/1e18).toFixed(2)}×10¹⁸N  열:${(th/1e9).toFixed(0)}GW`,4,H-4);
}

// ═══════════════════════════════════════════════════
//  INTERACTION
// ═══════════════════════════════════════════════════
const tip=document.getElementById('tip');
let mdPos={x:0,y:0},dragged=false;

function getAllMeshes(){
  return[...Object.values(pMesh),...Object.values(mMesh),sunMesh];
}
function getRayHit(ex,ey){
  const rect=cv.getBoundingClientRect();
  mouse2.x=((ex-rect.left)/rect.width)*2-1;
  mouse2.y=-((ey-rect.top)/rect.height)*2+1;
  raycaster.setFromCamera(mouse2,camera);
  const hits=raycaster.intersectObjects(getAllMeshes(),false);
  return hits.length>0&&hits[0].object.userData.bid?hits[0]:null;
}

cv.addEventListener('mousemove',e=>{
  const hit=getRayHit(e.clientX,e.clientY);
  if(hit){
    cv.style.cursor='pointer';
    tip.style.opacity='1';tip.style.left=(e.clientX+14)+'px';tip.style.top=(e.clientY-8)+'px';
    const bid=hit.object.userData.bid;
    const bd=getBodyData(bid);
    tip.innerHTML=`<b>${bd?.name||bid} ${bd?.en||''}</b><br><span style="opacity:.6">클릭 → 시뮬레이션</span>`;
  } else {cv.style.cursor='grab';tip.style.opacity='0';}
  if(oc.drag&&!ct.active){
    const dx=(e.clientX-oc.lx)*.006,dy=(e.clientY-oc.ly)*.006;
    oc.sph.theta-=dx;oc.sph.phi-=dy;
    oc.lx=e.clientX;oc.ly=e.clientY;dragged=true;
  }
});
cv.addEventListener('mousedown',e=>{
  oc.drag=true;oc.lx=e.clientX;oc.ly=e.clientY;
  mdPos={x:e.clientX,y:e.clientY};dragged=false;
});
cv.addEventListener('mouseup',e=>{
  oc.drag=false;
  if(!dragged&&Math.hypot(e.clientX-mdPos.x,e.clientY-mdPos.y)<5){
    const hit=getRayHit(e.clientX,e.clientY);
    if(hit){
      const bid=hit.object.userData.bid;
      const mesh=hit.object;
      const isBig=bid==='jupiter'||bid==='saturn';
      const dist=isBig?45:bid==='uranus'||bid==='neptune'?30:bid==='sun'?20:
                  Object.values(MOONS_DATA).flat().find(m=>m.id===bid)?8:18;
      camFocus(mesh.position.clone(),dist);
      openSB(bid);
      const fl=document.getElementById('focus-lbl');
      fl.textContent=(getBodyData(bid)?.en||bid).toUpperCase();
      fl.classList.add('on');setTimeout(()=>fl.classList.remove('on'),2500);
    } else closeSB();
  }
});
cv.addEventListener('wheel',e=>{e.preventDefault();oc.sph.radius*=e.deltaY>0?1.1:.9;},{passive:false});
window.addEventListener('resize',()=>{
  camera.aspect=innerWidth/innerHeight;camera.updateProjectionMatrix();
  renderer.setSize(innerWidth,innerHeight);
});

function clickMoon(mid){
  const mm=mMesh[mid]; if(!mm)return;
  camFocus(mm.position.clone(),8);
  openSB(mid);
  const fl=document.getElementById('focus-lbl');
  fl.textContent=(getBodyData(mid)?.en||mid).toUpperCase();
  fl.classList.add('on');setTimeout(()=>fl.classList.remove('on'),2500);
}
</script>

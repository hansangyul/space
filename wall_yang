const PHYS = {
  G:      6.674e-11,
  AU_M:   1.496e11,
  SUN_M:  1.989e30,
  L_SUN:  3.828e26,
  SIGMA:  5.67e-8,
  C_LIGHT:2.998e8,
  BASE_SPEED: 0.012,
};

const surfG    = (M,R,gm=1) => PHYS.G*M*gm/(R*R);
const escVel   = (M,R,gm=1) => Math.sqrt(2*gm*PHYS.G*M/R)/1e3;
const solFlux  = (d,r=1)    => PHYS.L_SUN*r/(4*Math.PI*(d*PHYS.AU_M)**2);
const effTemp  = (d,A,r=1)  => (solFlux(d,r)*(1-A)/(4*PHYS.SIGMA))**0.25 - 273;
const tidalF   = (Mj,m,d,dr)=> 2*PHYS.G*Mj*m*dr/d**3;
const keplerV  = (a_au)     => Math.sqrt(PHYS.G*PHYS.SUN_M/(a_au*PHYS.AU_M))/1e3;

// LOG-SCALE ORBIT: guarantees visual spacing between planets
function logOrb(a) {
  if(a<=0.45)  return 10 + a*44;
  if(a<=0.80)  return 30 + (a-0.45)*62;
  if(a<=1.70)  return 52 + (a-0.80)*32;
  if(a<=2.20)  return 81 + (a-1.70)*18;
  if(a<=6.50)  return 90 + (a-2.20)*11.6;
  if(a<=11.0)  return 140 + (a-6.50)*15.6;
  if(a<=22.0)  return 210 + (a-11.0)*7.3;
  return        290 + (a-22.0)*4.4;
}


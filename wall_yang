const swP=[];
function spawnSW(rN){
  const n=Math.ceil(rN*5);
  for(let i=0;i<n;i++){
    const t2=Math.random()*Math.PI*2,p2=Math.acos(2*Math.random()-1);const r2=5.5;
    swP.push({x:r2*Math.sin(p2)*Math.cos(t2),y:r2*Math.sin(p2)*Math.sin(t2)*.18,z:r2*Math.sin(p2)*Math.sin(t2),
      vx:Math.sin(p2)*Math.cos(t2)*(1.8+rN*1.5),vy:Math.sin(p2)*Math.sin(t2)*.14*(1.8+rN),vz:Math.sin(p2)*Math.sin(t2)*(1.8+rN*1.5),
      life:1,maxR:70+Math.random()*80,r:rN>1.8?1:.7,g2:rN>1.8?.36:.72,b:rN>1.5?.12:.92});
  }
  while(swP.length>SW_MAX)swP.shift();
}
function flushSW(){
  for(let i=0;i<swP.length;i++){
    const p2=swP[i],idx=i*3;
    swBuf.pos[idx]=p2.x;swBuf.pos[idx+1]=p2.y;swBuf.pos[idx+2]=p2.z;
    swBuf.col[idx]=p2.r*p2.life;swBuf.col[idx+1]=p2.g2*p2.life*.8;swBuf.col[idx+2]=p2.b*p2.life;
  }
  for(let i=swP.length;i<SW_MAX;i++)swBuf.pos[i*3]=swBuf.pos[i*3+1]=swBuf.pos[i*3+2]=9999;
  swGeo.attributes.position.needsUpdate=true;swGeo.attributes.color.needsUpdate=true;
}


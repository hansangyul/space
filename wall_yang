function dr(key,val,unit='',cls=''){
  return`<div class="drow"><span class="dkey">${key}</span><span class="dval ${cls}">${val}${unit?` <span style="opacity:.4;font-size:.5rem">${unit}</span>`:''}</span></div>`;
}

function updateSlider(bodyId, param, val){
  const v = parseFloat(val);
  const ss = bodyId==='europa' ? europaSimState : simState[bodyId];
  ss[param] = v;
  // Update display values
  if(document.getElementById('sv-solar')) document.getElementById('sv-solar').textContent=(ss.solarRad||1).toFixed(2)+'×';
  if(document.getElementById('sv-grav'))  document.getElementById('sv-grav').textContent=(ss.gravConst||1).toFixed(2)+'×';
  if(document.getElementById('sv-atmo')) document.getElementById('sv-atmo').textContent=((ss.atmoDensity||0)*100).toFixed(0)+'%';
  // Sync 3D planet material if exists
  const mesh = bodyId==='europa'?moonMeshes['europa']:planetMeshes[bodyId];
  if(mesh && param==='solarRad'){
    // Will be picked up in animate loop
  }
  // Re-render physics tab if open
  if(currentSbTab==='physics') renderSidebar();
}

function switchSbTab(tab, btn){
  currentSbTab = tab;
  document.querySelectorAll('.sbtab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  stopMiniSims();
  renderSidebar();
}

function focusEuropa(){
  const europaMesh = moonMeshes['europa'];
  if(!europaMesh) return;
  selectedBody = 'europa';
  focusObject(europaMesh.position, 8);
  document.getElementById('focus-label').textContent = 'EUROPA';
  document.getElementById('focus-label').classList.add('show');
  setTimeout(()=>document.getElementById('focus-label').classList.remove('show'),2500);
  renderSidebar();
}

// ═══════════════════════════════════════════════════════════════════════════
//  FOCUS / CAMERA
// ═══════════════════════════════════════════════════════════════════════════
function focusObject(pos, dist){
  camTarget.startPos.copy(camera.position);
  camTarget.startLook.copy(orbitCtrl.target);
  const offset = new THREE.Vector3(dist*.8, dist*.4, dist*.8);
  camTarget.targetPos.copy(pos).add(offset);
  camTarget.targetLook.copy(pos);
  orbitCtrl.spherical.radius = dist;
  camTarget.t = 0;
  camTarget.active = true;
  setTimeout(()=>{
    camTarget.active = false;
    orbitCtrl.target.copy(pos);
    const newPos = pos.clone().add(offset);
    orbitCtrl.spherical.setFromVector3(newPos.clone().sub(pos));
  }, 1200);
}

function openSidebar(bodyId){
  selectedBody = bodyId;
  currentSbTab = 'data';
  document.querySelectorAll('.sbtab').forEach((b,i)=>{b.classList.toggle('active',i===0);});
  document.getElementById('sidebar').classList.add('open');
  document.getElementById('crosshair').classList.add('show');
  renderSidebar();
}

function closeSidebar(){
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('crosshair').classList.remove('show');
  selectedBody = null;
  stopMiniSims();
}

// ═══════════════════════════════════════════════════════════════════════════
//  EVENTS
// ═══════════════════════════════════════════════════════════════════════════
const tooltip = document.getElementById('tooltip');
const mousePos = new THREE.Vector2();
let isDragging = false, mouseDownPos = {x:0,y:0};

canvas.addEventListener('mousemove', e=>{
  const rect = canvas.getBoundingClientRect();
  mousePos.x = ((e.clientX-rect.left)/rect.width)*2-1;
  mousePos.y = -((e.clientY-rect.top)/rect.height)*2+1;

  // Raycasting for hover
  raycaster.setFromCamera(mousePos, camera);
  const meshList = Object.values(planetMeshes).concat(Object.values(moonMeshes)).concat([sunMesh]);
  const hits = raycaster.intersectObjects(meshList, false);

  if(hits.length>0 && hits[0].object.userData.bodyId){
    const bid = hits[0].object.userData.bodyId;
    canvas.style.cursor='pointer';
    tooltip.style.opacity='1';
    tooltip.style.left=(e.clientX+16)+'px';
    tooltip.style.top=(e.clientY-10)+'px';
    if(bid==='sun') tooltip.innerHTML='<b>☀ 태양 Sun</b><br>L☉ = 3.828×10²⁶ W';
    else {
      const bd=bid==='europa'?EUROPA:BODIES.find(b=>b.id===bid);
      tooltip.innerHTML=`<b>${bd?.name||bid} ${bd?.en||''}</b><br>클릭 → 시뮬레이션`;
    }
  } else {
    canvas.style.cursor='grab';
    tooltip.style.opacity='0';
  }

  // Orbit control
  if(orbitCtrl.isDragging && !camTarget.active){
    const dx=(e.clientX-orbitCtrl.lastX)*.006;
    const dy=(e.clientY-orbitCtrl.lastY)*.006;
    orbitCtrl.spherical.theta -= dx;
    orbitCtrl.spherical.phi   -= dy;
    orbitCtrl.lastX=e.clientX; orbitCtrl.lastY=e.clientY;
    isDragging = true;
  }
});

canvas.addEventListener('mousedown', e=>{
  orbitCtrl.isDragging=true;
  orbitCtrl.lastX=e.clientX; orbitCtrl.lastY=e.clientY;
  mouseDownPos={x:e.clientX,y:e.clientY};
  isDragging=false;
  canvas.style.cursor='grabbing';
});

canvas.addEventListener('mouseup', e=>{
  orbitCtrl.isDragging=false;
  canvas.style.cursor='grab';
  const dd=Math.hypot(e.clientX-mouseDownPos.x,e.clientY-mouseDownPos.y);
  if(dd<5){
    // Click
    raycaster.setFromCamera(mousePos,camera);
    const meshList=Object.values(planetMeshes).concat(Object.values(moonMeshes));
    const hits=raycaster.intersectObjects(meshList,false);
    if(hits.length>0){
      const bid=hits[0].object.userData.bodyId;
      if(bid){
        const hitMesh=hits[0].object;
        const dist = bid==='europa'?6:
                     bid==='jupiter'||bid==='saturn'?40:
                     bid==='uranus'||bid==='neptune'?25:15;
        focusObject(hitMesh.position.clone(), dist);
        openSidebar(bid);
        document.getElementById('focus-label').textContent=
          (bid==='europa'?'EUROPA':BODIES.find(b=>b.id===bid)?.en.toUpperCase()||bid.toUpperCase());
        document.getElementById('focus-label').classList.add('show');
        setTimeout(()=>document.getElementById('focus-label').classList.remove('show'),2500);
      }
    }
  }
});

canvas.addEventListener('wheel', e=>{
  e.preventDefault();
  orbitCtrl.spherical.radius *= e.deltaY>0?1.1:0.9;
},{passive:false});

window.addEventListener('resize',()=>{
  camera.aspect=window.innerWidth/window.innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(window.innerWidth,window.innerHeight);
});
</script>

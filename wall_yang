function makeGlowTex(S=128, c0='rgba(255,250,200,.8)', c1='rgba(0,0,0,0)') {
  const cv2=document.createElement('canvas'); cv2.width=cv2.height=S;
  const g=cv2.getContext('2d'), h=S*.5;
  const gr=g.createRadialGradient(h,h,0,h,h,h);
  gr.addColorStop(0,c0); gr.addColorStop(.4,'rgba(200,180,80,.22)'); gr.addColorStop(1,c1);
  g.fillStyle=gr; g.fillRect(0,0,S,S);
  return new THREE.CanvasTexture(cv2);
}

function makePlanetTex(bd, radN=1, atmN=0.5) {
  const S=512, cx=S/2, R=S/2-1;
  const cv2=document.createElement('canvas'); cv2.width=cv2.height=S;
  const g=cv2.getContext('2d');
  const bc=new THREE.Color(bd.col);
  const heat=Math.max(0, radN-1);
  const r=Math.min(1,bc.r+heat*.38), gv=Math.max(0,bc.g-heat*.2), b=Math.max(0,bc.b-heat*.3);
  const bg=g.createRadialGradient(cx-R*.28,cx*.72,R*.04,cx,cx,R);
  bg.addColorStop(0,`rgb(${Math.min(255,r*255+82)},${Math.min(255,gv*255+82)},${Math.min(255,b*255+82)})`);
  bg.addColorStop(.38,`rgb(${Math.round(r*255)},${Math.round(gv*255)},${Math.round(b*255)})`);
  bg.addColorStop(1,`rgb(${Math.round(r*78)},${Math.round(gv*68)},${Math.round(b*72)})`);
  g.beginPath(); g.arc(cx,cx,R,0,Math.PI*2); g.fillStyle=bg; g.fill();
  g.save(); g.beginPath(); g.arc(cx,cx,R,0,Math.PI*2); g.clip();
  bd.bands.forEach(([yf,wf,c]) => {
    const [br,bg2,bb,ba]=c, by=cx+yf*S, bh=wf*S;
    const hbr=Math.min(255,br+heat*55);
    const bgr=g.createLinearGradient(0,by-bh/2,0,by+bh/2);
    bgr.addColorStop(0,`rgba(${hbr},${bg2},${bb},0)`);
    bgr.addColorStop(.5,`rgba(${hbr},${bg2},${bb},${ba})`);
    bgr.addColorStop(1,`rgba(${hbr},${bg2},${bb},0)`);
    g.fillStyle=bgr; g.fillRect(0,by-bh/2,S,bh);
  });
  if(bd.grs) {
    const gx=cx+S*.16,gy=cx+S*.02,grx=S*.13*(1+heat*.25),gry=S*.075;
    const gg=g.createRadialGradient(gx,gy,0,gx,gy,grx);
    gg.addColorStop(0,`rgba(${Math.min(255,205+heat*52)},${Math.max(22,68-heat*44)},14,.96)`);
    gg.addColorStop(.45,`rgba(${Math.min(255,172+heat*38)},${Math.max(12,42-heat*28)},7,.62)`);
    gg.addColorStop(1,'rgba(0,0,0,0)');
    g.save(); g.scale(1,gry/grx);
    g.beginPath(); g.arc(gx,gy*(grx/gry),grx,0,Math.PI*2); g.fillStyle=gg; g.fill();
    for(let i=0;i<5;i++){
      g.beginPath(); g.ellipse(gx,gy,grx*(1.04+i*.12),gry*(1.04+i*.12),0,i*.4,(i+.8)*Math.PI*.9);
      g.strokeStyle=`rgba(${Math.min(255,155+heat*32)},58,18,.17)`; g.lineWidth=1.8; g.stroke();
    }
    g.restore();
  }
  if(bd.polar) {
    const capH=S*.1+atmN*S*.04;
    const ng=g.createLinearGradient(0,0,0,capH);
    ng.addColorStop(0,bd.polar[0]); ng.addColorStop(1,'rgba(0,0,0,0)');
    g.fillStyle=ng; g.fillRect(0,0,S,capH);
    const sg=g.createLinearGradient(0,S-capH,0,S);
    sg.addColorStop(0,'rgba(0,0,0,0)'); sg.addColorStop(1,bd.polar[1]);
    g.fillStyle=sg; g.fillRect(0,S-capH,S,capH);
  }
  g.restore();
  if(atmN>.06) {
    const AC={venus:[240,210,80],mars:[212,108,60],jupiter:[200,162,84],
      saturn:[220,192,112],uranus:[80,222,222],neptune:[60,100,242]};
    const ac=AC[bd.id]||[100,180,255];
    const ag=g.createRadialGradient(cx,cx,R*.72,cx,cx,R);
    ag.addColorStop(0,'rgba(0,0,0,0)');
    ag.addColorStop(1,`rgba(${ac[0]},${ac[1]},${ac[2]},${atmN*.34})`);
    g.beginPath(); g.arc(cx,cx,R,0,Math.PI*2); g.fillStyle=ag; g.fill();
  }
  const rim=g.createRadialGradient(cx,cx,R*.8,cx,cx,R);
  rim.addColorStop(0,'rgba(255,255,255,0)'); rim.addColorStop(1,'rgba(255,255,255,.065)');
  g.beginPath(); g.arc(cx,cx,R,0,Math.PI*2); g.fillStyle=rim; g.fill();
  return new THREE.CanvasTexture(cv2);
}

function makeMoonTex(m) {

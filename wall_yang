// ═══════════════════════════════════════════════════════════════════════════
//  ANIMATION LOOP
// ═══════════════════════════════════════════════════════════════════════════
const clock = new THREE.Clock();

function animate(){
  requestAnimationFrame(animate);
  const dt = clock.getDelta();
  simTime += dt * 0.08; // ~1 year / 12.5 sec

  // FPS counter
  frameCount++;
  const now = performance.now();
  if(now - lastFpsTime > 500){
    const fps = Math.round(frameCount*1000/(now-lastFpsTime));
    document.getElementById('hud-fps').textContent = fps+' FPS';
    fpsArr.push(fps); if(fpsArr.length>10)fpsArr.shift();
    frameCount=0; lastFpsTime=now;
  }

  // Sim time display
  document.getElementById('sim-time').textContent = 'T+'+simTime.toFixed(2)+'yr';

  // Sun pulse
  const sp = 1 + Math.sin(simTime*6)*0.02;
  sunMesh.scale.set(sp,sp,sp);

  // Update planets
  BODIES.forEach(b=>{
    // Kepler angular velocity: ω = 2π / T(years), T = a^1.5
    const T_yr = Math.pow(b.a, 1.5);
    const omega = (Math.PI*2) / T_yr;
    const angle = simTime * omega;
    const r = auToScene(b.a);
    const x = Math.cos(angle)*r;
    const z = Math.sin(angle)*r;

    const mesh = planetMeshes[b.id];
    mesh.position.set(x, 0, z);
    mesh.rotation.y += dt * (b.id==='venus'?-0.3:0.4);

    // Dynamic visual from sim state
    const ss = simState[b.id];
    const ds = dynState[b.id];

    // Solar radiation → color hue shift toward red
    const radEffect = (ss.solarRad - 1.0); // -1 to +1 extra
    const baseColor = new THREE.Color(b.color);
    const hsl = {};
    baseColor.getHSL(hsl);
    // Shift hue toward red (0) when radiation high
    let newHue = hsl.h - radEffect * 0.08;
    let newSat = Math.min(1, hsl.s + radEffect * 0.15);
    let newLight = Math.min(0.9, hsl.l + radEffect * 0.05);
    mesh.material.color.setHSL(newHue, newSat, newLight);
    mesh.material.emissive.setHSL(newHue, newSat, radEffect*0.06);

    // Atmosphere scale (density slider)
    const atmScale = 0.3 + ss.atmoDensity * 1.7;
    mesh.userData.atm.scale.setScalar(atmScale);
    mesh.userData.atm.material.opacity = ss.atmoDensity * 0.25;

    // Glow scale (atmospheric density)
    const gs = 1 + ss.atmoDensity * 0.8 + radEffect * 0.5;
    planetGlows[b.id].scale.set(b.size*3.5*gs, b.size*3.5*gs, 1);

    // Europa orbit
    if(b.id==='jupiter' && moonMeshes['europa']){
      const europaOrbitR = 7; // scene units (6.71e8m ≈ 7 artistic)
      const europaT = 1.769/365.25; // years
      const europaOmega = Math.PI*2/europaT;
      const ea = simTime*europaOmega;
      const ex = x + Math.cos(ea)*europaOrbitR;
      const ez = z + Math.sin(ea)*europaOrbitR;
      moonMeshes['europa'].position.set(ex,0,ez);
      moonMeshes['europa'].rotation.y += dt*0.5;
    }
    if(b.id==='jupiter' && moonMeshes['titan']){
      const sto = auToScene(9.537); // use Saturn's actual pos
    }
  });

  // Saturn → Titan
  const saturnMesh = planetMeshes['saturn'];
  if(saturnMesh && moonMeshes['titan']){
    const sp2 = saturnMesh.position;
    const titanOrbitR = 9;
    const titanT = 15.945/365.25;
    const titanOmega = Math.PI*2/titanT;
    const ta = simTime*titanOmega;
    moonMeshes['titan'].position.set(sp2.x+Math.cos(ta)*titanOrbitR, 0, sp2.z+Math.sin(ta)*titanOrbitR);
    moonMeshes['titan'].rotation.y += dt*0.3;
  }

  // Camera lerp to focus
  if(camTarget.active){
    camTarget.t = Math.min(1, camTarget.t + dt*1.2);
    const ease = 1-Math.pow(1-camTarget.t,3);
    camera.position.lerpVectors(camTarget.startPos, camTarget.targetPos, ease);
    orbitCtrl.target.lerpVectors(camTarget.startLook, camTarget.targetLook, ease);
    camera.lookAt(orbitCtrl.target);
    if(camTarget.t >= 1) camTarget.active = false;
  } else {
    updateCamera();
  }

  renderer.render(scene, camera);
}
animate();


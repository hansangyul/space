.mc{display:inline-flex;align-items:center;gap:5px;background:rgba(0,200,255,.05);border:1px solid rgba(0,200,255,.13);border-radius:2px;padding:4px 8px;font-family:'Share Tech Mono',monospace;font-size:.56rem;color:rgba(0,200,255,.7);cursor:pointer;transition:all .2s;}
.mc:hover{background:rgba(0,200,255,.13);color:#fff;}
.md{width:5px;height:5px;border-radius:50%;}

#bottom-bar{position:fixed;bottom:0;left:0;right:0;height:38px;background:linear-gradient(to top,rgba(0,3,18,.95),transparent);display:flex;align-items:center;justify-content:space-between;padding:0 22px;z-index:100;pointer-events:none;}
.bb{font-family:'Share Tech Mono',monospace;font-size:.56rem;color:rgba(0,200,255,.3);letter-spacing:1px;}
#stime{color:rgba(0,200,255,.55);}

#focus-lbl{position:fixed;top:58px;left:50%;transform:translateX(-50%);font-family:'Rajdhani',sans-serif;font-size:1.5rem;font-weight:300;color:rgba(0,200,255,.65);letter-spacing:8px;text-transform:uppercase;pointer-events:none;z-index:100;opacity:0;transition:opacity .5s;text-shadow:0 0 28px rgba(0,200,255,.4);}

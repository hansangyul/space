const G=6.674e-11, AU_M=1.496e11, SUN_M=1.989e30, L_SUN=3.828e26, SB=5.67e-8;
const surfG=(M,R,gm=1)=>G*M*gm/(R*R);
const escVel=(M,R,gm=1)=>Math.sqrt(2*gm*G*M/R)/1e3;
const solFlux=(d,r=1)=>L_SUN*r/(4*Math.PI*(d*AU_M)**2);
const effTemp=(d,A,r=1)=>(solFlux(d,r)*(1-A)/(4*SB))**0.25 - 273;
const tidalF=(Mj,m,d,dr)=>2*G*Mj*m*dr/d**3;

// ═══════════════════════════════════════════════════
//  LOG-SCALE ORBIT  (guarantees ≥14 unit gap between planets)
// ═══════════════════════════════════════════════════
function logOrb(a){
  // 실제 비율 반영한 충분한 간격
  // mercury≈30  venus≈52  mars≈80
  // jupiter≈140  saturn≈210  uranus≈290  neptune≈360
  if(a<=0.45)  return 10 + a*44;                          // 수성 ≈ 30
  if(a<=0.80)  return 30 + (a-0.45)*62;                   // 금성 ≈ 52
  if(a<=1.70)  return 52 + (a-0.80)*32;                   // (지구 건너뜀)
  if(a<=2.20)  return 81 + (a-1.70)*18;                   // 화성 ≈ 80
  if(a<=6.50)  return 90 + (a-2.20)*11.6;                 // 목성 ≈ 140
  if(a<=11.0)  return 140 + (a-6.50)*15.6;                // 토성 ≈ 210
  if(a<=22.0)  return 210 + (a-11.0)*7.3;                 // 천왕성 ≈ 290
  return        290 + (a-22.0)*4.4;                       // 해왕성 ≈ 362
}


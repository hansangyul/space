const SW_MAX=4000;
const swBuf={pos:new Float32Array(SW_MAX*3),col:new Float32Array(SW_MAX*3)};
const swGeo=new THREE.BufferGeometry();
swGeo.setAttribute('position',new THREE.BufferAttribute(swBuf.pos,3));
swGeo.setAttribute('color',new THREE.BufferAttribute(swBuf.col,3));
const swMesh=new THREE.Points(swGeo,new THREE.PointsMaterial({size:.42,vertexColors:true,transparent:true,opacity:.68,blending:THREE.AdditiveBlending,depthWrite:false}));

<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Interactive Solar Physics Lab</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@300;400;500;600;700&family=Share+Tech+Mono&family=Exo+2:wght@200;400;700&display=swap');
*{margin:0;padding:0;box-sizing:border-box;}
html,body{width:100%;height:100%;overflow:hidden;background:#000;font-family:'Exo 2',sans-serif;}
#c{display:block;width:100%;height:100%;}

/* ── HUD OVERLAY ── */
#hud-top{
  position:fixed;top:0;left:0;right:0;height:52px;
  background:linear-gradient(to bottom,rgba(0,4,20,.95),rgba(0,4,20,.0));
  display:flex;align-items:center;justify-content:space-between;
  padding:0 24px;z-index:100;pointer-events:none;
  border-bottom:1px solid rgba(0,200,255,.08);
}
.hud-logo{
  font-family:'Rajdhani',sans-serif;font-size:1.1rem;font-weight:700;
  color:#00c8ff;letter-spacing:6px;text-transform:uppercase;
  text-shadow:0 0 20px rgba(0,200,255,.6);
}
.hud-logo span{color:rgba(0,200,255,.4);}
.hud-center{
  font-family:'Share Tech Mono',monospace;font-size:.65rem;
  color:rgba(0,200,255,.5);letter-spacing:3px;
  display:flex;gap:32px;
}
.hud-status{display:flex;gap:16px;align-items:center;}
.status-dot{width:6px;height:6px;border-radius:50%;background:#00ff88;box-shadow:0 0 6px #00ff88;animation:pulse 2s infinite;}
.status-txt{font-family:'Share Tech Mono',monospace;font-size:.6rem;color:rgba(0,255,136,.7);letter-spacing:2px;}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.3;}}

/* ── SIDEBAR ── */
#sidebar{
  position:fixed;right:0;top:0;bottom:0;width:340px;
  background:rgba(0,4,20,.94);
  border-left:1px solid rgba(0,200,255,.12);
  transform:translateX(100%);
  transition:transform .5s cubic-bezier(.16,1,.3,1);
  z-index:50;display:flex;flex-direction:column;
  backdrop-filter:blur(20px);
}
#sidebar.open{transform:translateX(0);}

.sb-header{
  padding:20px 20px 0;border-bottom:1px solid rgba(0,200,255,.1);
  padding-bottom:16px;
}
.sb-planet-row{display:flex;align-items:center;gap:12px;margin-bottom:12px;}
.sb-planet-dot{width:12px;height:12px;border-radius:50%;}
.sb-planet-name{font-family:'Rajdhani',sans-serif;font-size:1.3rem;font-weight:700;color:#fff;letter-spacing:2px;}
.sb-planet-en{font-family:'Share Tech Mono',monospace;font-size:.62rem;color:rgba(0,200,255,.6);letter-spacing:3px;margin-top:2px;}
#sb-close{
  position:absolute;top:16px;right:16px;width:28px;height:28px;
  background:rgba(0,200,255,.08);border:1px solid rgba(0,200,255,.25);
  color:#00c8ff;border-radius:2px;cursor:pointer;font-size:.9rem;
  display:flex;align-items:center;justify-content:center;transition:background .2s;
}
#sb-close:hover{background:rgba(0,200,255,.2);}

/* tabs */
.sb-tabs{display:flex;border-bottom:1px solid rgba(0,200,255,.1);}
.sbtab{
  flex:1;font-family:'Share Tech Mono',monospace;font-size:.58rem;
  letter-spacing:2px;text-transform:uppercase;padding:10px 4px;
  background:none;border:none;color:rgba(0,200,255,.35);cursor:pointer;
  border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .2s;
}
.sbtab.active,.sbtab:hover{color:#00c8ff;border-bottom-color:#00c8ff;}

.sb-body{flex:1;overflow-y:auto;padding:14px 18px;}
.sb-body::-webkit-scrollbar{width:2px;}
.sb-body::-webkit-scrollbar-thumb{background:rgba(0,200,255,.2);border-radius:2px;}

/* data rows */
.drow{
  display:flex;justify-content:space-between;align-items:baseline;
  padding:6px 0;border-bottom:1px solid rgba(0,200,255,.05);
}
.dkey{font-family:'Share Tech Mono',monospace;font-size:.58rem;color:rgba(0,200,255,.4);letter-spacing:1px;}
.dval{font-family:'Share Tech Mono',monospace;font-size:.68rem;color:#e0f8ff;text-align:right;}
.dval.hi{color:#00c8ff;}
.dval.warn{color:#ffaa00;}
.dval.danger{color:#ff4444;}
.dval.good{color:#00ff88;}

.sdiv{
  font-family:'Share Tech Mono',monospace;font-size:.55rem;letter-spacing:3px;
  color:#00c8ff;margin:13px 0 8px;display:flex;align-items:center;gap:6px;
}
.sdiv::after{content:'';flex:1;height:1px;background:rgba(0,200,255,.15);}

/* sliders */
.slider-block{margin-bottom:14px;}
.slider-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;}
.slider-label{font-family:'Share Tech Mono',monospace;font-size:.6rem;color:rgba(0,200,255,.6);letter-spacing:1px;}
.slider-val{font-family:'Rajdhani',monospace;font-size:.85rem;font-weight:600;color:#00c8ff;}
input[type=range]{
  width:100%;-webkit-appearance:none;height:2px;
  background:rgba(0,200,255,.15);border-radius:1px;outline:none;margin:4px 0;
}
input[type=range]::-webkit-slider-thumb{
  -webkit-appearance:none;width:12px;height:12px;border-radius:50%;
  background:#00c8ff;cursor:pointer;box-shadow:0 0 8px rgba(0,200,255,.8);
  transition:transform .15s;
}
input[type=range]::-webkit-slider-thumb:hover{transform:scale(1.3);}
.slider-desc{font-size:.62rem;color:rgba(0,200,255,.35);line-height:1.6;margin-top:3px;}

/* physics readout */
.phys-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px;}
.phys-box{
  background:rgba(0,200,255,.04);border:1px solid rgba(0,200,255,.1);
  border-radius:3px;padding:10px;
}
.phys-label{font-family:'Share Tech Mono',monospace;font-size:.52rem;color:rgba(0,200,255,.4);letter-spacing:1px;margin-bottom:4px;}
.phys-value{font-family:'Rajdhani',sans-serif;font-size:1rem;font-weight:600;color:#00c8ff;}
.phys-unit{font-family:'Share Tech Mono',monospace;font-size:.5rem;color:rgba(0,200,255,.4);}

/* mini canvas for factor viz */
.factor-canvas-wrap{
  margin:10px 0;border:1px solid rgba(0,200,255,.1);border-radius:3px;overflow:hidden;
  background:rgba(0,0,10,.6);
}
.factor-canvas-label{
  font-family:'Share Tech Mono',monospace;font-size:.52rem;
  letter-spacing:2px;color:rgba(0,200,255,.4);padding:5px 8px;
  border-bottom:1px solid rgba(0,200,255,.07);
}
canvas.fcanvas{display:block;width:100%;height:100px;}

/* jupiter-europa special */
.tidal-panel{
  background:rgba(255,165,0,.04);border:1px solid rgba(255,165,0,.15);
  border-radius:3px;padding:12px;margin-top:10px;
}
.tidal-title{font-family:'Share Tech Mono',monospace;font-size:.58rem;
  color:#ffaa00;letter-spacing:2px;margin-bottom:10px;}

/* bottom bar */
#bottom-bar{
  position:fixed;bottom:0;left:0;right:0;height:44px;
  background:linear-gradient(to top,rgba(0,4,20,.95),rgba(0,4,20,0));
  display:flex;align-items:center;justify-content:space-between;
  padding:0 24px;z-index:100;pointer-events:none;
  border-top:1px solid rgba(0,200,255,.06);
}
.bb-info{font-family:'Share Tech Mono',monospace;font-size:.6rem;color:rgba(0,200,255,.35);letter-spacing:2px;}
#sim-time{color:rgba(0,200,255,.6);}

/* focus indicator */
#focus-label{
  position:fixed;top:60px;left:50%;transform:translateX(-50%);
  font-family:'Rajdhani',sans-serif;font-size:1.6rem;font-weight:300;
  color:rgba(0,200,255,.7);letter-spacing:8px;text-transform:uppercase;
  pointer-events:none;z-index:100;
  opacity:0;transition:opacity .6s;
  text-shadow:0 0 30px rgba(0,200,255,.4);
}
#focus-label.show{opacity:1;}

/* crosshair */
#crosshair{
  position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);
  pointer-events:none;z-index:90;opacity:0;transition:opacity .4s;
}
#crosshair.show{opacity:1;}
.ch-ring{
  width:40px;height:40px;border-radius:50%;
  border:1px solid rgba(0,200,255,.5);
  box-shadow:0 0 12px rgba(0,200,255,.3);
  animation:spin 4s linear infinite;
}
.ch-ring2{
  position:absolute;top:4px;left:4px;
  width:32px;height:32px;border-radius:50%;
  border:1px dashed rgba(0,200,255,.3);
  animation:spin 6s linear infinite reverse;
}
@keyframes spin{from{transform:rotate(0deg);}to{transform:rotate(360deg);}}

/* tooltip */
#tooltip{
  position:fixed;pointer-events:none;z-index:200;
  background:rgba(0,4,20,.92);border:1px solid rgba(0,200,255,.3);
  border-radius:2px;padding:8px 12px;
  font-family:'Share Tech Mono',monospace;font-size:.62rem;
  color:#e0f8ff;letter-spacing:1px;opacity:0;transition:opacity .12s;
}

/* scanlines */
#scanlines{
  position:fixed;inset:0;pointer-events:none;z-index:1000;
  background:repeating-linear-gradient(0deg,rgba(0,0,0,.04) 0px,rgba(0,0,0,.04) 1px,transparent 1px,transparent 3px);
}
</style>
</head>
<body>
<canvas id="c"></canvas>
<div id="scanlines"></div>

<div id="hud-top">
  <div class="hud-logo">Solar Physics <span>//</span> Lab</div>
  <div class="hud-center">
    <span id="hud-bodies">8 BODIES ACTIVE</span>
    <span id="hud-fps">60 FPS</span>
    <span id="hud-scale">SCALE: ARTISTIC</span>
  </div>
  <div class="hud-status">
    <div class="status-dot"></div>
    <div class="status-txt">SIMULATION LIVE</div>
  </div>
</div>

<div id="focus-label"></div>
<div id="crosshair"><div class="ch-ring"><div class="ch-ring2"></div></div></div>

<div id="sidebar">
  <div class="sb-header">
    <div class="sb-planet-row">
      <div class="sb-planet-dot" id="sb-dot"></div>
      <div>
        <div class="sb-planet-name" id="sb-name">—</div>
        <div class="sb-planet-en" id="sb-en">—</div>
      </div>
    </div>
    <button id="sb-close" onclick="closeSidebar()">✕</button>
    <div class="sb-tabs">
      <button class="sbtab active" onclick="switchSbTab('data',this)">📊 데이터</button>
      <button class="sbtab" onclick="switchSbTab('sim',this)">⚡ 시뮬</button>
      <button class="sbtab" onclick="switchSbTab('physics',this)">🔬 물리</button>
    </div>
  </div>
  <div class="sb-body" id="sb-body"></div>
</div>

<div id="bottom-bar">
  <div class="bb-info">클릭: 천체 포커스 · 드래그: 회전 · 스크롤: 줌</div>
  <div class="bb-info">경과: <span id="sim-time">T+0.00yr</span></div>
  <div class="bb-info">NASA JPL 물리 데이터 기반</div>
</div>

<div id="tooltip"></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>
// ═══════════════════════════════════════════════════════════════════════════
//  PHYSICS CONSTANTS & FORMULAS  (SI units, then scaled for display)
// ═══════════════════════════════════════════════════════════════════════════
const G_REAL = 6.674e-11;       // N·m²/kg²
const AU_M   = 1.496e11;        // metres per AU
const SUN_M  = 1.989e30;        // kg

// Kepler: orbital velocity v = sqrt(GM/a), period T = 2π√(a³/GM)
function keplerPeriod(a_au){return 2*Math.PI*Math.sqrt(Math.pow(a_au*AU_M,3)/(G_REAL*SUN_M));}
function keplerSpeed(a_au){return Math.sqrt(G_REAL*SUN_M/(a_au*AU_M));}
// Surface gravity
function surfGravity(M,R){return G_REAL*M/(R*R);}
// Escape velocity
function escapeVel(M,R,Gmod=1){return Math.sqrt(2*Gmod*G_REAL*M/R);}
// Tidal force (simplified): ΔF = 2GMm·Δr/d³
function tidalForce(M_planet, m_moon, d_m, delta_r){
  return 2*G_REAL*M_planet*m_moon*delta_r/Math.pow(d_m,3);
}
// Radiation flux at distance d: F = L☉/(4π·d²)
const L_SUN = 3.828e26; // W
function solarFlux(d_au){return L_SUN/(4*Math.PI*Math.pow(d_au*AU_M,2));}
// Effective temperature: T_eff = (F(1-A)/(4σ))^0.25
const SIGMA = 5.67e-8;
function effectiveTemp(d_au, albedo){return Math.pow(solarFlux(d_au)*(1-albedo)/(4*SIGMA),0.25);}

// ═══════════════════════════════════════════════════════════════════════════
//  PLANET DATABASE  (NASA JPL Planetary Fact Sheets)
// ═══════════════════════════════════════════════════════════════════════════
const BODIES = [
  {id:'mercury',name:'수성',en:'Mercury',
   a:0.387,e:0.2056,color:0xa0a0b0,radius:2.44e6,mass:3.285e23,
   albedo:0.119,size:2.2,ringCol:null,
   gravity:3.70,escVel:4.25,baseTemp:167,
   desc:'태양계 최소 행성. 2:3 조석 공명. 대기 없음.',
   atmosphere:'거의 없음 (Na 29%, O₂ 22%)',
   moons:[]},
  {id:'venus',name:'금성',en:'Venus',
   a:0.723,e:0.0067,color:0xe8c870,radius:6.052e6,mass:4.867e24,
   albedo:0.75,size:3.8,ringCol:null,
   gravity:8.87,escVel:10.36,baseTemp:464,
   desc:'역방향 자전(-243일). 극단적 온실효과. 기압 92bar.',
   atmosphere:'CO₂ 96.5%, N₂ 3.5%',
   moons:[]},
  {id:'mars',name:'화성',en:'Mars',
   a:1.524,e:0.0934,color:0xc1440e,radius:3.390e6,mass:6.39e23,
   albedo:0.25,size:2.8,ringCol:null,
   gravity:3.72,escVel:5.03,baseTemp:-65,
   desc:'얇은 CO₂ 대기(0.6%). 올림포스 몬스(21.9km). 과거 바다 존재 흔적.',
   atmosphere:'CO₂ 95.3%, N₂ 2.6%, Ar 1.9%',
   moons:['포보스 Phobos','데이모스 Deimos']},
  {id:'jupiter',name:'목성',en:'Jupiter',
   a:5.203,e:0.0489,color:0xc8a870,radius:7.149e7,mass:1.898e27,
   albedo:0.52,size:12,ringCol:0x886644,
   gravity:24.79,escVel:59.5,baseTemp:-110,
   desc:'태양계 최대 행성. 대적점(300년+ 폭풍). 자기장 지구의 20,000배.',
   atmosphere:'H₂ 89.8%, He 10.2%',
   moons:['이오 Io','에우로파 Europa','가니메데 Ganymede','칼리스토 Callisto'],
   special:'europa'},
  {id:'saturn',name:'토성',en:'Saturn',
   a:9.537,e:0.0565,color:0xe8d8a0,radius:6.027e7,mass:5.683e26,
   albedo:0.47,size:10,ringCol:0xd4b890,hasRings:true,
   gravity:10.44,escVel:35.5,baseTemp:-140,
   desc:'밀도 0.687g/cm³ (물보다 가벼움). 고리 주로 얼음(93%).',
   atmosphere:'H₂ 96.3%, He 3.25%',
   moons:['타이탄 Titan','엔켈라두스 Enceladus','레아 Rhea','디오네 Dione']},
  {id:'uranus',name:'천왕성',en:'Uranus',
   a:19.19,e:0.0472,color:0x7de8e8,radius:2.556e7,mass:8.681e25,
   albedo:0.51,size:7,ringCol:0x4488aa,
   gravity:8.69,escVel:21.3,baseTemp:-195,
   desc:'자전축 97.77° 기울기. 역방향 자전. 얼음 거인.',
   atmosphere:'H₂ 83%, He 15%, CH₄ 2.3%',
   moons:['미란다 Miranda','아리엘 Ariel','움브리엘 Umbriel','티타니아 Titania']},
  {id:'neptune',name:'해왕성',en:'Neptune',
   a:30.07,e:0.0113,color:0x3060e0,radius:2.476e7,mass:1.024e26,
   albedo:0.41,size:7,ringCol:0x224488,
   gravity:11.15,escVel:23.5,baseTemp:-200,
   desc:'수학으로 발견. 최대 풍속 2,100km/h. 내부 잔열 방출.',
   atmosphere:'H₂ 80%, He 19%, CH₄ 1.5%',
   moons:['트리톤 Triton','프로테우스 Proteus','네레이드 Nereid']},
];

// Europa special data
const EUROPA = {
  id:'europa', name:'에우로파', en:'Europa',
  radius:1.561e6, mass:4.80e22,
  orbit_r:6.71e8,   // m from Jupiter
  gravity:1.315, escVel:2.025,
  desc:'지하 액체 바다 존재. 생명체 후보지. 목성 조석력으로 내부 가열.',
  tidalHeat:83.5e9,  // W estimated
  iceThickness:15e3, // m
};

// ═══════════════════════════════════════════════════════════════════════════
//  THREE.JS SETUP
// ═══════════════════════════════════════════════════════════════════════════
const canvas = document.getElementById('c');
const renderer = new THREE.WebGLRenderer({canvas, antialias:true, alpha:false});
renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.toneMapping = THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure = 1.2;

const scene = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(55, window.innerWidth/window.innerHeight, 0.01, 10000);
camera.position.set(0, 35, 80);
camera.lookAt(0,0,0);

// Orbital scale: 1 AU = 16 units (artistic, not real scale)
const AU = 16;
function auToScene(au){return au*AU;}

// ── Orbit Controls (manual implementation) ──
let orbitCtrl = {
  target: new THREE.Vector3(0,0,0),
  spherical: new THREE.Spherical(100, Math.PI/3, 0),
  isDragging: false,
  lastX:0, lastY:0,
  zoomDelta:0,
};
function updateCamera(){
  const sp = orbitCtrl.spherical;
  sp.phi = Math.max(0.1, Math.min(Math.PI-0.1, sp.phi));
  sp.radius = Math.max(2, Math.min(600, sp.radius));
  camera.position.setFromSpherical(sp).add(orbitCtrl.target);
  camera.lookAt(orbitCtrl.target);
}
updateCamera();

// Camera lerp target (for focus)
let camTarget = {
  active: false,
  targetPos: new THREE.Vector3(),
  targetLook: new THREE.Vector3(),
  t: 0,
  startPos: new THREE.Vector3(),
  startLook: new THREE.Vector3(),
};

// ── Raycaster ──
const raycaster = new THREE.Raycaster();
const mouse = new THREE.Vector2();

// ═══════════════════════════════════════════════════════════════════════════
//  STARFIELD — 35,000 stars, single Points draw call
// ═══════════════════════════════════════════════════════════════════════════
(function buildStars(){
  const N = 35000;
  const pos = new Float32Array(N*3);
  const col = new Float32Array(N*3);
  const palette = [
    [1.0,0.97,1.0],[0.85,0.92,1.0],[1.0,0.9,0.8],
    [0.9,0.85,1.0],[0.75,0.88,1.0]
  ];
  for(let i=0;i<N;i++){
    const r = 800 + Math.random()*800;
    const theta = Math.random()*Math.PI*2;
    const phi = Math.acos(2*Math.random()-1);
    pos[i*3]   = r*Math.sin(phi)*Math.cos(theta);
    pos[i*3+1] = r*Math.sin(phi)*Math.sin(theta);
    pos[i*3+2] = r*Math.cos(phi);
    const c = palette[Math.floor(Math.random()*palette.length)];
    const bright = 0.4+Math.random()*0.6;
    col[i*3]=c[0]*bright; col[i*3+1]=c[1]*bright; col[i*3+2]=c[2]*bright;
  }
  const geo = new THREE.BufferGeometry();
  geo.setAttribute('position', new THREE.BufferAttribute(pos,3));
  geo.setAttribute('color', new THREE.BufferAttribute(col,3));
  const mat = new THREE.PointsMaterial({
    size:0.6, vertexColors:true, transparent:true, opacity:0.9,
    sizeAttenuation:true
  });
  scene.add(new THREE.Points(geo,mat));
})();

// ═══════════════════════════════════════════════════════════════════════════
//  SUN
// ═══════════════════════════════════════════════════════════════════════════
const sunGeo = new THREE.SphereGeometry(4.5, 32, 32);
// Simple emissive sun with animated glow
const sunMat = new THREE.MeshBasicMaterial({color:0xffe840});
const sunMesh = new THREE.Mesh(sunGeo, sunMat);
scene.add(sunMesh);

// Sun glow sprite
const sunGlowTex = createGlowTexture(256);
const sunGlow = new THREE.Sprite(new THREE.SpriteMaterial({
  map:sunGlowTex, color:0xffaa00,
  transparent:true, opacity:0.6,
  blending:THREE.AdditiveBlending, depthWrite:false
}));
sunGlow.scale.set(28,28,1);
scene.add(sunGlow);

// Point light from sun
const sunLight = new THREE.PointLight(0xfff5e0, 3, 1000, 1.5);
scene.add(sunLight);
const ambLight = new THREE.AmbientLight(0x111122, 0.4);
scene.add(ambLight);

function createGlowTexture(size){
  const cv = document.createElement('canvas');
  cv.width=cv.height=size;
  const g=cv.getContext('2d');
  const grad=g.createRadialGradient(size/2,size/2,0,size/2,size/2,size/2);
  grad.addColorStop(0,'rgba(255,240,150,0.8)');
  grad.addColorStop(0.3,'rgba(255,160,40,0.4)');
  grad.addColorStop(0.6,'rgba(255,80,10,0.15)');
  grad.addColorStop(1,'rgba(0,0,0,0)');
  g.fillStyle=grad; g.fillRect(0,0,size,size);
  const tex=new THREE.CanvasTexture(cv);
  return tex;
}


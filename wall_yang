// ── Smooth transition ──
function startTransition(toBid, toMesh){
  const bd=ALL_BODIES[toBid];
  if(!bd)return;
  // Desired radius based on body size
  const sz=bd.sz||1;
  const desiredR=bd.isMoon?sz*22+10:sz*5.5+14;
  const desiredMin=bd.isMoon?sz*3:sz*2.2;
  const desiredMax=desiredR*40;

  cam.animFrom.pos.copy(camera.position);
  cam.animFrom.target.copy(cam.orbitTarget);
  cam.animFrom.r=cam.radius;
  cam.animFrom.phi=cam.phi;
  cam.animFrom.theta=cam.theta;

  cam.animTo.target.copy(toMesh.position);
  cam.animTo.r=desiredR;
  // Keep current angles during transition
  cam.animTo.phi=cam.phi;
  cam.animTo.theta=cam.theta;

  cam.animating=true;
  cam.animT=0;

  // Set min/max after transition
  setTimeout(()=>{
    cam.minR=desiredMin;
    cam.maxR=desiredMax;
  },600);
}


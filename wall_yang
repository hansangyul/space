//  MODULE 8: CAMERA & LOCK-ON SYSTEM
// ═══════════════════════════════════════════════════════════════════════
function startTransition(bid, mesh) {
  const bd = ALL_BODIES[bid]; if(!bd) return;
  const sz = bd.sz || 1;
  const desiredR  = bd.isMoon ? sz*22+10 : sz*5.5+14;
  const desiredMin = bd.isMoon ? sz*3     : sz*2.2;
  const desiredMax = desiredR*40;

  cam.animFrom.target.copy(cam.orbitTarget);
  cam.animFrom.r     = cam.radius;
  cam.animFrom.phi   = cam.phi;
  cam.animFrom.theta = cam.theta;
  cam.animTo.target.copy(mesh.position);
  cam.animTo.r     = desiredR;
  cam.animTo.phi   = cam.phi;
  cam.animTo.theta = cam.theta;
  cam.animating = true; cam.animT = 0;
  setTimeout(()=>{ cam.minR=desiredMin; cam.maxR=desiredMax; }, 700);
}

function lockOn(bid) {
  const bd = ALL_BODIES[bid]; if(!bd) return;
  const mesh = P_MESH[bid] || M_MESH[bid]; if(!mesh) return;
  lockedId = bid; lockedMesh = mesh;
  startTransition(bid, mesh);
  document.getElementById('lockbanner').classList.add('on');
  document.getElementById('lbn').textContent = bd.en || bd.name;
  document.getElementById('htrack').textContent = '🔒 '+(bd.en||bid).toUpperCase();
  document.getElementById('livepanel').classList.add('on');
  document.getElementById('btn-back').classList.add('on');
  document.querySelectorAll('.pl-item').forEach(el=>el.classList.toggle('active',el.dataset.bid===bid));
  openSP(bid);
  syncLivePanelPos();
  refreshLivePanel();
}

function releaseLock() {
  lockedId=null; lockedMesh=null;
  document.getElementById('lockbanner').classList.remove('on');
  document.getElementById('htrack').textContent='FREE CAM';
  document.getElementById('livepanel').classList.remove('on');
  document.getElementById('btn-back').classList.remove('on');
  cam.minR=2; cam.maxR=2200;
  document.querySelectorAll('.pl-item').forEach(el=>el.classList.remove('active'));
  syncLivePanelPos();
}

function syncLivePanelPos() {
  const lp = document.getElementById('livepanel');
  const isOpen = lp.classList.contains('on');
  document.getElementById('btn-back').style.left = isOpen ? '402px' : '200px';
}

function resetCamera() {
  releaseLock();
  cam.animFrom.target.copy(cam.orbitTarget);
  cam.animFrom.r=cam.radius; cam.animFrom.phi=cam.phi; cam.animFrom.theta=cam.theta;
  cam.animTo.target.set(0,0,0); cam.animTo.r=380; cam.animTo.phi=1.05; cam.animTo.theta=0.2;
  cam.animating=true; cam.animT=0;
  cam.minR=2; cam.maxR=2200;
  closeSP();
}


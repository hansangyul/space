      transparent:true, opacity:.14, blending:THREE.AdditiveBlending, depthWrite:false
    }));
    mgl.scale.set(mn.sz*4, mn.sz*4, 1); mmesh.add(mgl);
    // Moon orbit line with 3D inclination
    const mol = makeOrbitLine(mn.orb, 0x003344, .32);
    mol.rotation.x = mn.incl || 0;
    mol.rotation.z = mn.az   || 0;
    scene.add(mol); M_OL[mn.id] = mol;
  });
});


function createOrbitLine(a_au, segments=128){
  const r = auToScene(a_au);
  const pts = [];
  for(let i=0;i<=segments;i++){
    const theta = (i/segments)*Math.PI*2;
    pts.push(new THREE.Vector3(Math.cos(theta)*r, 0, Math.sin(theta)*r));
  }
  const geo = new THREE.BufferGeometry().setFromPoints(pts);
  const mat = new THREE.LineBasicMaterial({color:0x003355, transparent:true, opacity:0.35});
  return new THREE.Line(geo, mat);
}

function createAtmosphere(radius, color, opacity){
  const geo = new THREE.SphereGeometry(radius*1.25, 32, 32);
  const mat = new THREE.MeshBasicMaterial({
    color, transparent:true, opacity,
    blending:THREE.AdditiveBlending,
    side:THREE.BackSide, depthWrite:false
  });
  return new THREE.Mesh(geo, mat);
}

BODIES.forEach(b=>{
